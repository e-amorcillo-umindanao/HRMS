@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<Router AppAssembly="typeof(MauiProgram).Assembly">
    <Found Context="routeData">
        @{
            var route = GetCurrentRoute();
        }

        @if (!AuthService.IsAuthenticated && !IsAnonymousRoute(route))
        {
            <RedirectTo Href="/login" />
        }
        else if (AuthService.IsAuthenticated && route == "/login")
        {
            <RedirectTo Href="/dashboard" />
        }
        else if (AuthService.IsAuthenticated && route != "/" && !AuthService.CanAccessRoute(route))
        {
            <RedirectTo Href="/dashboard" />
        }
        else
        {
            <RouteView RouteData="routeData" DefaultLayout="GetDefaultLayout(route)" />
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        }
    </Found>
    <NotFound>
        @if (!AuthService.IsAuthenticated)
        {
            <RedirectTo Href="/login" />
        }
        else
        {
            <LayoutView Layout="typeof(MainLayout)">
                <DynamicComponent Type="typeof(HRMS.Components.Pages.NotFound)" />
            </LayoutView>
        }
    </NotFound>
</Router>

@code {
    protected override void OnInitialized()
    {
        AuthService.StateChanged += HandleStateChanged;
    }

    public void Dispose()
    {
        AuthService.StateChanged -= HandleStateChanged;
    }

    private string GetCurrentRoute() =>
        HRMS.Services.AuthService.NormalizeRoute(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));

    private static bool IsAnonymousRoute(string route) =>
        route is "/" or "/login";

    private static Type GetDefaultLayout(string route) =>
        route is "/" or "/login" ? typeof(AuthLayout) : typeof(MainLayout);

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
