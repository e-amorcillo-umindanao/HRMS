@page "/homeowners/{Id:int}"
@page "/profile"
@inject HomeownerService HomeownerService
@inject AttendanceService AttendanceService
@inject DuesService DuesService
@inject ViolationService ViolationService
@inject ClearanceService ClearanceService
@inject InteractionService InteractionService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_homeowner is null)
{
    <PageHeader Title="Homeowner" Subtitle="The requested profile could not be loaded." />
    <MudPaper Class="hrms-page-card" Elevation="0">
        <EmptyState Title="No profile available"
                    Subtitle="This account does not have a linked homeowner record yet."
                    Icon="@Icons.Material.Filled.PersonOff" />
    </MudPaper>
}
else
{
    <div style="display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; margin-bottom: 24px; flex-wrap: wrap;">
        <PageHeader Title="@GetFullName(_homeowner)" Subtitle="Homeowner profile" />
        <div style="display: flex; gap: 12px;">
            <MudButton Variant="Variant.Outlined" OnClick="GenerateStatementAsync">
                Generate Statement
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="GoBack">Back</MudButton>
            @if (!AuthService.IsHomeowner())
            {
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => NavigationManager.NavigateTo($"/homeowners/edit/{_homeowner.HomeownerId}"))">
                    Edit
                </MudButton>
            }
        </div>
    </div>

    <MudPaper Class="hrms-page-card" Style="padding: 24px; margin-bottom: 24px;" Elevation="0">
        <div style="font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Personal Information</div>
        <MudDivider Style="margin: 8px 0 20px;" />
        <MudGrid>
            <MudItem xs="12" sm="4"><MudText><strong>First Name:</strong> @DisplayValue(_homeowner.FirstName)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Middle Name:</strong> @DisplayValue(_homeowner.MiddleName)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Last Name:</strong> @DisplayValue(_homeowner.LastName)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Birth Date:</strong> @FormatDate(_homeowner.BirthDate)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Gender:</strong> @DisplayValue(_homeowner.Gender)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Civil Status:</strong> @DisplayValue(_homeowner.CivilStatus)</MudText></MudItem>
        </MudGrid>

        <div style="margin-top: 28px; font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Contact Details</div>
        <MudDivider Style="margin: 8px 0 20px;" />
        <MudGrid>
            <MudItem xs="12" sm="4"><MudText><strong>Contact Number:</strong> @DisplayValue(_homeowner.ContactNumber)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Email:</strong> @DisplayValue(_homeowner.Email)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Address:</strong> @DisplayValue(_homeowner.Address)</MudText></MudItem>
        </MudGrid>

        <div style="margin-top: 28px; font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Assignment &amp; Classification</div>
        <MudDivider Style="margin: 8px 0 20px;" />
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudText><strong>Status:</strong> @DisplayValue(_homeowner.Status)</MudText>
            </MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Phase:</strong> @DisplayValue(_homeowner.Phase?.Name)</MudText></MudItem>
            <MudItem xs="12" sm="4"><MudText><strong>Unit:</strong> @DisplayValue(_homeowner.Unit?.UnitNumber)</MudText></MudItem>
            <MudItem xs="12" sm="6">
                <MudText><strong>Categories:</strong></MudText>
                @if (GetCategories(_homeowner).Count == 0)
                {
                    <MudText>-</MudText>
                }
                else
                {
                    @foreach (var category in GetCategories(_homeowner))
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Style="margin-right: 4px; margin-top: 6px;">
                            @category
                        </MudChip>
                    }
                }
            </MudItem>
            <MudItem xs="12" sm="6"><MudText><strong>Residency Since:</strong> @FormatDate(_homeowner.ResidencySince)</MudText></MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="hrms-page-card" Style="padding: 8px 16px 16px;" Elevation="0">
        <MudTabs Rounded="true">
            <MudTabPanel Text="Attendance History">
                @if (_attendanceHistory.Count == 0)
                {
                    <MudText>No records yet.</MudText>
                }
                else
                {
                    <MudTable T="Attendance" Items="_attendanceHistory" Hover="false" Striped="false">
                        <HeaderContent>
                            <MudTh>Event</MudTh>
                            <MudTh>Event Type</MudTh>
                            <MudTh>Event Date</MudTh>
                            <MudTh>Venue</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Event">@DisplayValue(context.Event?.Title)</MudTd>
                            <MudTd DataLabel="Event Type">@DisplayValue(context.Event?.EventType)</MudTd>
                            <MudTd DataLabel="Event Date">@FormatDate(context.Event?.EventDate)</MudTd>
                            <MudTd DataLabel="Venue">@DisplayValue(context.Event?.Venue)</MudTd>
                            <MudTd DataLabel="Status">@((MarkupString)RenderAttendanceStatusChip(context.Status))</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <TableRecordCount Count="_attendanceHistory.Count" EntityLabel="attendance records" />
                }
            </MudTabPanel>
            <MudTabPanel Text="Dues History">
                @if (_duesHistory.Count == 0)
                {
                    <MudText>No records yet.</MudText>
                }
                else
                {
                    <MudTable T="DuesRecord" Items="_duesHistory" Hover="false" Striped="false">
                        <HeaderContent>
                            <MudTh>Month/Year</MudTh>
                            <MudTh>Amount</MudTh>
                            <MudTh>Due Date</MudTh>
                            <MudTh>Paid Date</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Month/Year">@FormatMonthYear(context.Month, context.Year)</MudTd>
                            <MudTd DataLabel="Amount">@FormatCurrency(context.Amount)</MudTd>
                            <MudTd DataLabel="Due Date">@FormatDate(context.DueDate)</MudTd>
                            <MudTd DataLabel="Paid Date">@FormatDate(context.PaidDate)</MudTd>
                            <MudTd DataLabel="Status">@((MarkupString)RenderDuesStatusChip(context.Status))</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <TableRecordCount Count="_duesHistory.Count" EntityLabel="dues records" />
                }
            </MudTabPanel>
            <MudTabPanel Text="Violations">
                @if (_violations.Count == 0)
                {
                    <MudText>No records yet.</MudText>
                }
                else
                {
                    <MudTable T="ViolationRecord" Items="_violations" Hover="false" Striped="false">
                        <HeaderContent>
                            <MudTh>Violation Number</MudTh>
                            <MudTh>Violation Type</MudTh>
                            <MudTh>Violation Date</MudTh>
                            <MudTh>Status</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Violation Number">@DisplayValue(context.ViolationNumber)</MudTd>
                            <MudTd DataLabel="Violation Type">@DisplayValue(context.ViolationType)</MudTd>
                            <MudTd DataLabel="Violation Date">@FormatDate(context.ViolationDate)</MudTd>
                            <MudTd DataLabel="Status">@((MarkupString)RenderViolationStatusChip(context.Status))</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <TableRecordCount Count="_violations.Count" EntityLabel="violations" />
                }
            </MudTabPanel>
            <MudTabPanel Text="Clearance Requests">
                @if (_clearanceRequests.Count == 0)
                {
                    <MudText>No records yet.</MudText>
                }
                else
                {
                    <MudTable T="ClearanceRequest" Items="_clearanceRequests" Hover="false" Striped="false">
                        <HeaderContent>
                            <MudTh>Clearance Type</MudTh>
                            <MudTh>Purpose</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Requested At</MudTh>
                            <MudTh>Processed At</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Clearance Type">@DisplayValue(context.ClearanceType)</MudTd>
                            <MudTd DataLabel="Purpose">@DisplayValue(context.Purpose)</MudTd>
                            <MudTd DataLabel="Status">@((MarkupString)RenderClearanceStatusChip(context.Status))</MudTd>
                            <MudTd DataLabel="Requested At">@FormatDate(context.RequestedAt)</MudTd>
                            <MudTd DataLabel="Processed At">@FormatDate(context.ProcessedAt)</MudTd>
                        </RowTemplate>
                    </MudTable>
                    <TableRecordCount Count="_clearanceRequests.Count" EntityLabel="clearance requests" />
                }
            </MudTabPanel>
            <MudTabPanel Text="Interaction History">
                @if (!AuthService.IsHomeowner() && _homeowner is not null && AuthService.IsAtLeast("Board Member"))
                {
                    <div style="display: flex; justify-content: flex-end; margin-bottom: 16px;">
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="NavigateToLogInteraction">
                            Log Interaction
                        </MudButton>
                    </div>
                }

                <InteractionTimeline Logs="_interactionLogs" />
            </MudTabPanel>
        </MudTabs>
    </MudPaper>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private Homeowner? _homeowner;
    private List<Attendance> _attendanceHistory = [];
    private List<DuesRecord> _duesHistory = [];
    private List<ViolationRecord> _violations = [];
    private List<ClearanceRequest> _clearanceRequests = [];
    private List<InteractionLog> _interactionLogs = [];
    private bool _isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        var targetId = Id;
        if (!targetId.HasValue && AuthService.IsHomeowner())
        {
            targetId = AuthService.CurrentUser?.HomeownerId;
        }

        _homeowner = targetId.HasValue
            ? await HomeownerService.GetByIdAsync(targetId.Value)
            : null;

        _attendanceHistory = targetId.HasValue
            ? await AttendanceService.GetByHomeownerAsync(targetId.Value)
            : [];

        _duesHistory = targetId.HasValue
            ? await DuesService.GetByHomeownerAsync(targetId.Value)
            : [];

        _violations = targetId.HasValue
            ? await ViolationService.GetByHomeownerAsync(targetId.Value)
            : [];

        _clearanceRequests = targetId.HasValue
            ? await ClearanceService.GetByHomeownerAsync(targetId.Value)
            : [];

        _interactionLogs = targetId.HasValue
            ? await InteractionService.GetByHomeownerAsync(targetId.Value)
            : [];

        _isLoading = false;
    }

    private async Task GenerateStatementAsync()
    {
        if (_homeowner is null)
        {
            return;
        }

        var document = await DocumentService.GenerateDuesStatementAsync(_homeowner.HomeownerId);
        if (document is null)
        {
            Snackbar.Add("Unable to generate dues statement.", Severity.Error);
            return;
        }

        var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
        await File.WriteAllBytesAsync(filePath, document.Bytes);

        await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
            new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                document.FileName,
                new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo(AuthService.IsHomeowner() ? "/dashboard" : "/homeowners");
    }

    private void NavigateToLogInteraction()
    {
        if (_homeowner is null)
        {
            return;
        }

        NavigationManager.NavigateTo($"/engagement/log?homeownerId={_homeowner.HomeownerId}&returnUrl=/homeowners/{_homeowner.HomeownerId}");
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static List<string> GetCategories(Homeowner homeowner) =>
        string.IsNullOrWhiteSpace(homeowner.Categories)
            ? []
            : homeowner.Categories
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

    private static string RenderAttendanceStatusChip(string? status)
    {
        var (background, foreground) = status switch
        {
            "Present" => ("#DCFCE7", "#166534"),
            "Absent" => ("#FEE2E2", "#991B1B"),
            "Excused" => ("#FEF3C7", "#92400E"),
            _ => ("#E2E8F0", "#475569")
        };

        var text = string.IsNullOrWhiteSpace(status) ? "-" : status;
        return $"<span style=\"display:inline-block;padding:4px 10px;border-radius:4px;background:{background};color:{foreground};font-size:0.75rem;font-weight:600;\">{text}</span>";
    }

    private static string FormatMonthYear(int month, int year) =>
        $"{GetMonthName(month)} {year}";

    private static string GetMonthName(int month)
    {
        if (month < 1 || month > 12)
        {
            return "-";
        }

        return System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month);
    }

    private static string FormatCurrency(decimal amount) => $"PHP {amount:N2}";

    private static string RenderDuesStatusChip(string? status)
    {
        var (background, foreground) = status switch
        {
            "Paid" => ("#DCFCE7", "#166534"),
            "Unpaid" => ("#FEF3C7", "#92400E"),
            "Overdue" => ("#FEE2E2", "#991B1B"),
            _ => ("#E2E8F0", "#475569")
        };

        var text = string.IsNullOrWhiteSpace(status) ? "-" : status;
        return $"<span style=\"display:inline-block;padding:4px 10px;border-radius:4px;background:{background};color:{foreground};font-size:0.75rem;font-weight:600;\">{text}</span>";
    }

    private static string RenderViolationStatusChip(string? status)
    {
        var (background, foreground) = status switch
        {
            "Open" => ("#FEE2E2", "#991B1B"),
            "Under Review" => ("#FEF3C7", "#92400E"),
            "Resolved" => ("#DCFCE7", "#166534"),
            "Closed" => ("#E2E8F0", "#475569"),
            _ => ("#E2E8F0", "#475569")
        };

        var text = string.IsNullOrWhiteSpace(status) ? "-" : status;
        return $"<span style=\"display:inline-block;padding:4px 10px;border-radius:4px;background:{background};color:{foreground};font-size:0.75rem;font-weight:600;\">{text}</span>";
    }

    private static string RenderClearanceStatusChip(string? status)
    {
        var (background, foreground) = status switch
        {
            "Pending" => ("#FEF3C7", "#92400E"),
            "Approved" => ("#DCFCE7", "#166534"),
            "Rejected" => ("#FEE2E2", "#991B1B"),
            _ => ("#E2E8F0", "#475569")
        };

        var text = string.IsNullOrWhiteSpace(status) ? "-" : status;
        return $"<span style=\"display:inline-block;padding:4px 10px;border-radius:4px;background:{background};color:{foreground};font-size:0.75rem;font-weight:600;\">{text}</span>";
    }
}
