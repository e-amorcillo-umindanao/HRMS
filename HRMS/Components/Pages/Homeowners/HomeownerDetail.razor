@page "/homeowners/{Id:int}"
@inject HomeownerService HomeownerService
@inject AttendanceService AttendanceService
@inject DuesService DuesService
@inject ViolationService ViolationService
@inject ClearanceService ClearanceService
@inject InteractionService InteractionService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_homeowner is null)
{
    <PageHeader Title="Homeowner" Subtitle="The requested profile could not be loaded." />
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No profile available"
                    Subtitle="This account does not have a linked homeowner record yet."
                    Icon="○" />
    </div>
}
else
{
    <PageHeader Title="@GetFullName(_homeowner)" Subtitle="Homeowner profile and history.">
        <Actions>
            @if (AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "documents"))
            {
                <button class="btn btn-outline btn-sm" @onclick="GenerateStatementAsync">Generate Statement</button>
            }
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">Back</button>
            @if (CanWriteHomeowners)
            {
                <button class="btn btn-primary btn-sm"
                        @onclick='() => NavigationManager.NavigateTo($"/homeowners/{_homeowner.HomeownerId}/edit")'>
                    Edit
                </button>
            }
        </Actions>
    </PageHeader>

    <div class="mb-4 grid grid-cols-1 gap-4 xl:grid-cols-3">
        <div class="card border border-base-300 bg-base-100 shadow-none xl:col-span-1">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <p class="text-sm font-semibold text-base-content">Profile</p>
                </div>
                <div class="p-5">
                    <div class="mb-5 flex items-center gap-4">
                        <div class="avatar placeholder">
                            <div class="w-12 rounded-full bg-neutral text-neutral-content">
                                <span class="text-lg font-semibold">@GetInitials(_homeowner)</span>
                            </div>
                        </div>
                        <div>
                            <p class="font-semibold text-base-content">@GetFullName(_homeowner)</p>
                            <div class="mt-1"><StatusChip Status="@_homeowner.Status" /></div>
                        </div>
                    </div>

                    <div class="space-y-3">
                        @DetailField("Birth Date", FormatDate(_homeowner.BirthDate))
                        @DetailField("Gender", DisplayValue(_homeowner.Gender))
                        @DetailField("Civil Status", DisplayValue(_homeowner.CivilStatus))
                        @DetailField("Contact Number", DisplayValue(_homeowner.ContactNumber))
                        @DetailField("Email", DisplayValue(_homeowner.Email))
                        @DetailField("Address", DisplayValue(_homeowner.Address))
                        @DetailField("Phase", DisplayValue(_homeowner.Phase?.Name))
                        @DetailField("Unit", DisplayValue(_homeowner.Unit?.UnitNumber))
                        @DetailField("Resident Since", FormatDate(_homeowner.ResidencySince))
                        <div>
                            <p class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40">Categories</p>
                            <div class="mt-1">
                                @if (GetCategories(_homeowner).Count == 0)
                                {
                                    <p class="text-sm text-base-content">-</p>
                                }
                                else
                                {
                                    @foreach (var category in GetCategories(_homeowner))
                                    {
                                        <span class="badge badge-info badge-sm mr-1">@category</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-base-300 bg-base-100 shadow-none xl:col-span-2">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-semibold text-base-content">Record History</p>
                            <p class="mt-0.5 text-xs text-base-content/40">Attendance, dues, violations, clearances, and interactions.</p>
                        </div>
                        @if (AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "engagement"))
                        {
                            <button class="btn btn-primary btn-sm" @onclick="NavigateToLogInteraction">Log Interaction</button>
                        }
                    </div>
                </div>

                <div class="px-5 pt-5">
                    <div role="tablist" class="tabs tabs-bordered">
                        <button role="tab" class="tab @GetTabClass("attendance")" @onclick='() => _activeTab = "attendance"'>Attendance</button>
                        <button role="tab" class="tab @GetTabClass("dues")" @onclick='() => _activeTab = "dues"'>Dues</button>
                        <button role="tab" class="tab @GetTabClass("violations")" @onclick='() => _activeTab = "violations"'>Violations</button>
                        <button role="tab" class="tab @GetTabClass("clearances")" @onclick='() => _activeTab = "clearances"'>Clearances</button>
                        <button role="tab" class="tab @GetTabClass("interactions")" @onclick='() => _activeTab = "interactions"'>Interactions</button>
                    </div>
                </div>

                <div class="p-5">
                    @if (_activeTab == "attendance")
                    {
                        @if (_attendanceHistory.Count == 0)
                        {
                            <EmptyState Title="No attendance records"
                                        Subtitle="Attendance history will appear here once events are recorded."
                                        Icon="○" />
                        }
                        else
                        {
                            <div class="overflow-x-auto">
                                <table class="table table-sm">
                                    <thead>
                                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                            <th>Event</th>
                                            <th>Event Type</th>
                                            <th>Event Date</th>
                                            <th>Venue</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var attendance in _attendanceHistory)
                                        {
                                            <tr class="h-[52px] hover">
                                                <td class="text-sm text-base-content">@DisplayValue(attendance.Event?.Title)</td>
                                                <td class="text-sm text-base-content/60">@DisplayValue(attendance.Event?.EventType)</td>
                                                <td class="text-sm text-base-content/60">@FormatDate(attendance.Event?.EventDate)</td>
                                                <td class="text-sm text-base-content/60">@DisplayValue(attendance.Event?.Venue)</td>
                                                <td>
                                                    <span class="badge badge-sm @GetAttendanceBadgeClass(attendance.Status)">
                                                        @DisplayValue(attendance.Status)
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <TableRecordCount From="1" To="@_attendanceHistory.Count" Total="@_attendanceHistory.Count" Entity="attendance records" />
                        }
                    }
                    else if (_activeTab == "dues")
                    {
                        @if (_duesHistory.Count == 0)
                        {
                            <EmptyState Title="No dues records"
                                        Subtitle="Dues history will appear here once records are added."
                                        Icon="○" />
                        }
                        else
                        {
                            <div class="overflow-x-auto">
                                <table class="table table-sm">
                                    <thead>
                                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                            <th>Month/Year</th>
                                            <th>Amount</th>
                                            <th>Due Date</th>
                                            <th>Paid Date</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var dues in _duesHistory)
                                        {
                                            <tr class="h-[52px] hover">
                                                <td class="text-sm text-base-content">@FormatMonthYear(dues.Month, dues.Year)</td>
                                                <td class="text-sm font-medium text-base-content">@FormatHelper.Peso(dues.Amount)</td>
                                                <td class="text-sm text-base-content/60">@FormatDate(dues.DueDate)</td>
                                                <td class="text-sm text-base-content/60">@FormatDate(dues.PaidDate)</td>
                                                <td><StatusChip Status="@dues.Status" /></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <TableRecordCount From="1" To="@_duesHistory.Count" Total="@_duesHistory.Count" Entity="dues records" />
                        }
                    }
                    else if (_activeTab == "violations")
                    {
                        @if (_violations.Count == 0)
                        {
                            <EmptyState Title="No violations"
                                        Subtitle="Violation records will appear here once incidents are filed."
                                        Icon="○" />
                        }
                        else
                        {
                            <div class="overflow-x-auto">
                                <table class="table table-sm">
                                    <thead>
                                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                            <th>Violation Number</th>
                                            <th>Violation Type</th>
                                            <th>Violation Date</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var violation in _violations)
                                        {
                                            <tr class="h-[52px] hover">
                                                <td><span class="violation-pill">@DisplayValue(violation.ViolationNumber)</span></td>
                                                <td class="text-sm text-base-content">@DisplayValue(violation.ViolationType)</td>
                                                <td class="text-sm text-base-content/60">@FormatDate(violation.ViolationDate)</td>
                                                <td><StatusChip Status="@violation.Status" /></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <TableRecordCount From="1" To="@_violations.Count" Total="@_violations.Count" Entity="violations" />
                        }
                    }
                    else if (_activeTab == "clearances")
                    {
                        @if (_clearanceRequests.Count == 0)
                        {
                            <EmptyState Title="No clearance requests"
                                        Subtitle="Clearance requests will appear here once they are submitted."
                                        Icon="○" />
                        }
                        else
                        {
                            <div class="overflow-x-auto">
                                <table class="table table-sm">
                                    <thead>
                                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                            <th>Clearance Type</th>
                                            <th>Purpose</th>
                                            <th>Status</th>
                                            <th>Requested At</th>
                                            <th>Processed At</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var request in _clearanceRequests)
                                        {
                                            <tr class="h-[52px] hover">
                                                <td class="text-sm text-base-content">@DisplayValue(request.ClearanceType)</td>
                                                <td class="text-sm text-base-content/60">@DisplayValue(request.Purpose)</td>
                                                <td><StatusChip Status="@request.Status" /></td>
                                                <td class="text-sm text-base-content/60">@FormatDate(request.RequestedAt)</td>
                                                <td class="text-sm text-base-content/60">@FormatDate(request.ProcessedAt)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            <TableRecordCount From="1" To="@_clearanceRequests.Count" Total="@_clearanceRequests.Count" Entity="clearance requests" />
                        }
                    }
                    else
                    {
                        <InteractionTimeline Logs="_interactionLogs" />
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? Id { get; set; }

    private Homeowner? _homeowner;
    private List<Attendance> _attendanceHistory = [];
    private List<DuesRecord> _duesHistory = [];
    private List<ViolationRecord> _violations = [];
    private List<ClearanceRequest> _clearanceRequests = [];
    private List<InteractionLog> _interactionLogs = [];
    private bool _isLoading = true;
    private string _activeTab = "attendance";
    private bool CanWriteHomeowners => AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "homeowners");

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;

        var targetId = Id;
        if (!targetId.HasValue && AuthService.IsHomeowner())
        {
            targetId = AuthService.CurrentUser?.HomeownerId;
        }

        _homeowner = targetId.HasValue
            ? await HomeownerService.GetByIdAsync(targetId.Value)
            : null;

        _attendanceHistory = targetId.HasValue
            ? await AttendanceService.GetByHomeownerAsync(targetId.Value)
            : [];

        _duesHistory = targetId.HasValue
            ? await DuesService.GetByHomeownerAsync(targetId.Value)
            : [];

        _violations = targetId.HasValue
            ? await ViolationService.GetByHomeownerAsync(targetId.Value)
            : [];

        _clearanceRequests = targetId.HasValue
            ? await ClearanceService.GetByHomeownerAsync(targetId.Value)
            : [];

        _interactionLogs = targetId.HasValue
            ? await InteractionService.GetByHomeownerAsync(targetId.Value)
            : [];

        _isLoading = false;
    }

    private async Task GenerateStatementAsync()
    {
        if (_homeowner is null || AuthService.CurrentUser is null)
        {
            return;
        }

        var document = await DocumentService.GenerateDuesStatementAsync(_homeowner.HomeownerId, AuthService.CurrentUser.UserId);
        if (document is null)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to generate dues statement.", "error");
            return;
        }

        var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
        await File.WriteAllBytesAsync(filePath, document.Bytes);

        await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
            new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                document.FileName,
                new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo(AuthService.IsHomeowner() ? "/profile" : "/homeowners");
    }

    private void NavigateToLogInteraction()
    {
        if (_homeowner is null)
        {
            return;
        }

        NavigationManager.NavigateTo($"/engagement/log?homeownerId={_homeowner.HomeownerId}&returnUrl=/homeowners/{_homeowner.HomeownerId}");
    }

    private string GetTabClass(string tab) => _activeTab == tab ? "tab-active" : string.Empty;

    private static string GetAttendanceBadgeClass(string? status) => status switch
    {
        "Present" => "badge-success",
        "Absent" => "badge-error",
        "Excused" => "badge-warning",
        _ => "badge-ghost"
    };

    private static string GetInitials(Homeowner homeowner)
    {
        var first = string.IsNullOrWhiteSpace(homeowner.FirstName) ? string.Empty : homeowner.FirstName[..1];
        var last = string.IsNullOrWhiteSpace(homeowner.LastName) ? string.Empty : homeowner.LastName[..1];
        return (first + last).ToUpperInvariant();
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static List<string> GetCategories(Homeowner homeowner) =>
        string.IsNullOrWhiteSpace(homeowner.Categories)
            ? []
            : homeowner.Categories
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static string FormatMonthYear(int month, int year) =>
        $"{GetMonthName(month)} {year}";

    private static string GetMonthName(int month)
    {
        if (month < 1 || month > 12)
        {
            return "-";
        }

        return System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month);
    }

    private static RenderFragment DetailField(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.OpenElement(1, "p");
        builder.AddAttribute(2, "class", "text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40");
        builder.AddContent(3, label);
        builder.CloseElement();
        builder.OpenElement(4, "p");
        builder.AddAttribute(5, "class", "mt-0.5 text-sm text-base-content");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };
}
