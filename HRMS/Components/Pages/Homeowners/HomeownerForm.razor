@page "/homeowners/add"
@page "/homeowners/new"
@page "/homeowners/edit/{HomeownerId:int}"
@page "/homeowners/{HomeownerId:int}/edit"
@inject AppDbContext DbContext
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="@(IsEdit ? "Edit Homeowner" : "Add Homeowner")"
            Subtitle="Capture personal, contact, and assignment information." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Personal Information</p>
            <div class="divider my-0 mb-4"></div>
            <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="First Name">
                    <input type="text" class="input input-bordered w-full" @bind="_model.FirstName" />
                </FieldGroup>
                <FieldGroup Label="Middle Name">
                    <input type="text" class="input input-bordered w-full" @bind="_model.MiddleName" />
                </FieldGroup>
                <FieldGroup Label="Last Name">
                    <input type="text" class="input input-bordered w-full" @bind="_model.LastName" />
                </FieldGroup>
                <FieldGroup Label="Birth Date">
                    <input type="date"
                           class="input input-bordered w-full"
                           max="@TodayDateString"
                           value="@FormatHtmlDate(_birthDate)"
                           @onchange="OnBirthDateChanged" />
                </FieldGroup>
                <FieldGroup Label="Gender">
                    <select class="select select-bordered w-full" @bind="_model.Gender">
                        <option value="">Select gender</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </FieldGroup>
                <FieldGroup Label="Civil Status">
                    <select class="select select-bordered w-full" @bind="_model.CivilStatus">
                        <option value="">-</option>
                        <option>Single</option>
                        <option>Married</option>
                        <option>Widowed</option>
                        <option>Separated</option>
                        <option>Annulled</option>
                    </select>
                </FieldGroup>
            </div>

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Contact Details</p>
            <div class="divider my-0 mb-4"></div>
            <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Contact Number">
                    <input type="text" class="input input-bordered w-full" @bind="_model.ContactNumber" />
                </FieldGroup>
                <FieldGroup Label="Email">
                    <input type="email" class="input input-bordered w-full" @bind="_model.Email" />
                </FieldGroup>
                <div class="md:col-span-2">
                    <FieldGroup Label="Address">
                        <input type="text" class="input input-bordered w-full" @bind="_model.Address" />
                    </FieldGroup>
                </div>
            </div>

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Assignment & Classification</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Status">
                    <select class="select select-bordered w-full" @bind="_model.Status">
                        @foreach (var status in StatusOptions)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Phase">
                    <select class="select select-bordered w-full" @bind="_model.PhaseId">
                        <option value="">-</option>
                        @foreach (var phase in _phases)
                        {
                            <option value="@phase.PhaseId">@phase.Name</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Unit">
                    <select class="select select-bordered w-full" @bind="_model.UnitId">
                        <option value="">-</option>
                        @foreach (var unit in _units)
                        {
                            <option value="@unit.UnitId">@($"{unit.UnitNumber} - {unit.Address}")</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Residency Since">
                    <input type="date"
                           class="input input-bordered w-full"
                           max="@TodayDateString"
                           value="@FormatHtmlDate(_residencySince)"
                           @onchange="OnResidencySinceChanged" />
                </FieldGroup>
                <div class="md:col-span-2">
                    <FieldGroup Label="Categories">
                        <div class="flex flex-wrap gap-3 pt-1">
                            @foreach (var category in CategoryOptions)
                            {
                                <label class="flex cursor-pointer items-center gap-2">
                                    <input type="checkbox"
                                           class="checkbox checkbox-primary checkbox-sm"
                                           checked="@_selectedCategories.Contains(category)"
                                           @onchange="args => ToggleCategory(category, args.Value is bool isChecked && isChecked)" />
                                    <span class="text-sm text-base-content">@category</span>
                                </label>
                            }
                        </div>
                    </FieldGroup>
                </div>
            </div>
        </div>

        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                @(IsEdit ? "Save Changes" : "Save")
            </button>
        </div>
    </div>
}

@code {
    private static readonly string[] StatusOptions = ["Active", "Inactive", "Transferred", "Deceased"];
    private static readonly string[] CategoryOptions = ["Senior", "PWD", "4Ps", "Indigent", "Youth", "Solo Parent"];

    [Parameter]
    public int? HomeownerId { get; set; }

    private readonly HomeownerFormModel _model = new();
    private List<Phase> _phases = [];
    private List<Unit> _units = [];
    private HashSet<string> _selectedCategories = [];
    private DateTime? _birthDate;
    private DateTime? _residencySince;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private static string TodayDateString => DateTime.Today.ToString("yyyy-MM-dd");
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin ? null : AuthService.CurrentSubdivisionId;

    private bool IsEdit => HomeownerId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _phases = await DbContext.Phases.AsNoTracking()
            .Where(phase => !ActiveSubdivisionId.HasValue || phase.SubdivisionId == ActiveSubdivisionId.Value)
            .OrderBy(p => p.Name)
            .ToListAsync();
        _units = await DbContext.Units.AsNoTracking()
            .Where(unit => !ActiveSubdivisionId.HasValue || unit.SubdivisionId == ActiveSubdivisionId.Value)
            .OrderBy(u => u.UnitNumber)
            .ToListAsync();

        if (IsEdit)
        {
            var homeowner = await HomeownerService.GetByIdAsync(HomeownerId.GetValueOrDefault(), ActiveSubdivisionId);
            if (homeowner is null)
            {
                _errorMessage = "Homeowner record not found.";
                _isLoading = false;
                return;
            }

            _model.HomeownerId = homeowner.HomeownerId;
            _model.FirstName = homeowner.FirstName;
            _model.MiddleName = homeowner.MiddleName ?? string.Empty;
            _model.LastName = homeowner.LastName;
            _model.Gender = homeowner.Gender;
            _model.CivilStatus = homeowner.CivilStatus ?? string.Empty;
            _model.ContactNumber = homeowner.ContactNumber ?? string.Empty;
            _model.Email = homeowner.Email ?? string.Empty;
            _model.Address = homeowner.Address ?? string.Empty;
            _model.Status = homeowner.Status;
            _model.PhaseId = homeowner.PhaseId;
            _model.UnitId = homeowner.UnitId;
            _selectedCategories = homeowner.Categories is null
                ? []
                : homeowner.Categories
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToHashSet(StringComparer.Ordinal);
            _birthDate = ParseDate(homeowner.BirthDate);
            _residencySince = ParseDate(homeowner.ResidencySince);
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null)
        {
            return;
        }

        _isSaving = true;

        var homeowner = new Homeowner
        {
            HomeownerId = _model.HomeownerId ?? 0,
            FirstName = _model.FirstName.Trim(),
            MiddleName = NullIfEmpty(_model.MiddleName),
            LastName = _model.LastName.Trim(),
            BirthDate = ToIsoDateString(_birthDate!.Value),
            Gender = _model.Gender,
            CivilStatus = NullIfEmpty(_model.CivilStatus),
            ContactNumber = NullIfEmpty(_model.ContactNumber),
            Email = NullIfEmpty(_model.Email),
            Address = NullIfEmpty(_model.Address),
            PhaseId = _model.PhaseId,
            UnitId = _model.UnitId,
            Status = _model.Status,
            Categories = _selectedCategories.Count == 0 ? null : string.Join(",", _selectedCategories.OrderBy(value => value)),
            ResidencySince = ToIsoDateString(_residencySince!.Value)
        };

        if (IsEdit)
        {
            var updated = await HomeownerService.UpdateAsync(homeowner, AuthService.CurrentUser.UserId);
            _isSaving = false;

            if (updated is null)
            {
                _errorMessage = "Unable to update homeowner.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "Homeowner updated successfully.", "success");
            NavigationManager.NavigateTo($"/homeowners/{updated.HomeownerId}");
            return;
        }

        await HomeownerService.AddAsync(homeowner, AuthService.CurrentUser.UserId);
        _isSaving = false;
        await JS.InvokeVoidAsync("hrms.showToast", "Homeowner added successfully.", "success");
        NavigationManager.NavigateTo("/homeowners");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(IsEdit ? $"/homeowners/{HomeownerId}" : "/homeowners");
    }

    private void ToggleCategory(string category, bool isChecked)
    {
        if (isChecked)
        {
            _selectedCategories.Add(category);
        }
        else
        {
            _selectedCategories.Remove(category);
        }
    }

    private void OnBirthDateChanged(ChangeEventArgs args) =>
        _birthDate = ParseInputDate(args.Value?.ToString());

    private void OnResidencySinceChanged(ChangeEventArgs args) =>
        _residencySince = ParseInputDate(args.Value?.ToString());

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.FirstName))
        {
            return "First Name is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.LastName))
        {
            return "Last Name is required.";
        }

        if (_birthDate is null)
        {
            return "Birth Date is required.";
        }

        if (_birthDate.Value.Date > DateTime.Today)
        {
            return "Birth Date cannot be in the future.";
        }

        if (string.IsNullOrWhiteSpace(_model.Gender))
        {
            return "Gender is required.";
        }

        if (_residencySince is null)
        {
            return "Residency Since is required.";
        }

        if (_residencySince.Value.Date > DateTime.Today)
        {
            return "Residency Since cannot be in the future.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.HomeownerId = null;
        _model.FirstName = string.Empty;
        _model.MiddleName = string.Empty;
        _model.LastName = string.Empty;
        _model.Gender = string.Empty;
        _model.CivilStatus = string.Empty;
        _model.ContactNumber = string.Empty;
        _model.Email = string.Empty;
        _model.Address = string.Empty;
        _model.Status = "Active";
        _model.PhaseId = null;
        _model.UnitId = null;
        _selectedCategories = [];
        _birthDate = null;
        _residencySince = null;
    }

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static DateTime? ParseInputDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static string ToIsoDateString(DateTime value) =>
        DateTime.SpecifyKind(value.Date, DateTimeKind.Utc).ToString("o");

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class HomeownerFormModel
    {
        public int? HomeownerId { get; set; }
        public string FirstName { get; set; } = string.Empty;
        public string MiddleName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Gender { get; set; } = string.Empty;
        public string CivilStatus { get; set; } = string.Empty;
        public string ContactNumber { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string Status { get; set; } = "Active";
        public int? PhaseId { get; set; }
        public int? UnitId { get; set; }
    }
}
