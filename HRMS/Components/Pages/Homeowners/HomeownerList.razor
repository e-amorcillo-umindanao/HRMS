@page "/homeowners"
@inject HomeownerService HomeownerService
@inject AppDbContext DbContext
@inject AuthService AuthService
@inject SubdivisionContextService SubdivisionContextService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Homeowners"
            Subtitle="Manage homeowner records, profile data, and CSV imports.">
    <Actions>
        @if (CanWriteHomeowners)
        {
            <label class="btn btn-outline btn-sm">
                Import CSV
                <InputFile OnChange="ImportCsvAsync" accept=".csv" hidden />
            </label>
            <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/homeowners/new")'>
                Add Homeowner
            </button>
        }
        else
        {
            <span class="badge badge-warning badge-md px-3 py-2 font-medium">Read-only mode</span>
        }
    </Actions>
</PageHeader>

<SubdivisionSelector OnSubdivisionSelected="HandleSubdivisionChange" />

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="form-control min-w-[200px] flex-1">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Name</span>
                </label>
                <input type="text"
                       class="input input-bordered input-sm w-full"
                       placeholder="Search name..."
                       value="@_nameFilter"
                       @oninput="OnNameInput" />
            </div>

            <div class="form-control min-w-[148px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Status</span>
                </label>
                <select class="select select-bordered select-sm" value="@_statusFilter" @onchange="OnStatusChanged">
                    <option value="">All Statuses</option>
                    @foreach (var status in StatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>

            <div class="form-control min-w-[148px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Phase</span>
                </label>
                <select class="select select-bordered select-sm" value="@GetPhaseValue()" @onchange="OnPhaseChanged">
                    <option value="">All Phases</option>
                    @foreach (var phase in _phases)
                    {
                        <option value="@phase.PhaseId">@phase.Name</option>
                    }
                </select>
            </div>

            <div class="form-control min-w-[148px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Category</span>
                </label>
                <select class="select select-bordered select-sm" value="@_categoryFilter" @onchange="OnCategoryChanged">
                    <option value="">All Categories</option>
                    @foreach (var category in CategoryOptions)
                    {
                        <option value="@category">@category</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_importMessage))
{
    <div role="alert" class="alert mb-4 @($"alert-{_importTone}")">
        <span>@_importMessage</span>
    </div>
}

@if (_importErrors.Count > 0)
{
    <div class="card mb-6 border border-base-300 bg-base-100 shadow-none">
        <div class="card-body gap-2 p-4">
            <p class="text-sm font-semibold text-base-content">Import Errors</p>
            @foreach (var error in _importErrors)
            {
                <p class="text-sm text-base-content/60">
                    @(error.RowNumber > 0 ? $"Row {error.RowNumber}: {error.Message}" : error.Message)
                </p>
            }
        </div>
    </div>
}

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_homeowners.Count == 0)
        {
            <EmptyState Title="No homeowners found"
                        Subtitle="Try adjusting your filters or add a new homeowner record."
                        Icon="○" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Full Name</th>
                            <th>Status</th>
                            <th>Phase</th>
                            <th>Unit</th>
                            <th>Categories</th>
                            <th>Residency Since</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var homeowner in _homeowners)
                        {
                            <tr class="h-[52px]">
                                <td class="text-sm font-semibold text-base-content">@GetFullName(homeowner)</td>
                                <td><StatusChip Status="@homeowner.Status" /></td>
                                <td class="text-sm text-base-content/60">@DisplayValue(homeowner.Phase?.Name)</td>
                                <td class="text-sm text-base-content/60">@DisplayValue(homeowner.Unit?.UnitNumber)</td>
                                <td>
                                    @if (GetCategories(homeowner).Count == 0)
                                    {
                                        <span class="text-sm text-base-content/30">-</span>
                                    }
                                    else
                                    {
                                        @foreach (var category in GetCategories(homeowner))
                                        {
                                            <span class="badge badge-info badge-sm mr-1">@category</span>
                                        }
                                    }
                                </td>
                                <td class="text-sm text-base-content/60">@FormatDate(homeowner.ResidencySince)</td>
                                <td class="text-right">
                                    <div class="flex items-center justify-end gap-1">
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/homeowners/{homeowner.HomeownerId}")'>
                                        View
                                    </button>
                                    @if (CanWriteHomeowners)
                                    {
                                        <button class="btn btn-ghost btn-xs"
                                                @onclick='() => NavigationManager.NavigateTo($"/homeowners/{homeowner.HomeownerId}/edit")'>
                                            Edit
                                        </button>
                                        <button class="btn btn-ghost btn-xs text-error"
                                                @onclick='() => AskDelete(homeowner)'>
                                            Delete
                                        </button>
                                    }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_homeowners.Count == 0 ? 0 : 1)"
                                  To="@_homeowners.Count"
                                  Total="@_homeowners.Count"
                                  Entity="homeowners" />
            </div>
        }
    </div>
</div>

<ConfirmDialog IsVisible="@_showConfirm"
               Title="Delete Homeowner"
               Message="@_confirmMessage"
               ConfirmLabel="Delete"
               OnConfirm="DeleteConfirmedAsync"
               OnCancel="CancelDelete" />

@code {
    private static readonly string[] StatusOptions = ["Active", "Inactive", "Transferred", "Deceased"];
    private static readonly string[] CategoryOptions = ["Senior", "PWD", "4Ps", "Indigent", "Youth"];
    private bool CanWriteHomeowners => AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "homeowners");
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin
        ? SubdivisionContextService.SelectedSubdivisionId
        : AuthService.CurrentSubdivisionId;

    private readonly List<CsvImportError> _importErrors = [];
    private List<Homeowner> _homeowners = [];
    private List<Phase> _phases = [];
    private string _nameFilter = string.Empty;
    private string _statusFilter = string.Empty;
    private string _categoryFilter = string.Empty;
    private int? _phaseFilter;
    private bool _isLoading = true;
    private string? _importMessage;
    private string _importTone = "success";
    private bool _showConfirm;
    private int? _pendingDeleteId;
    private string _confirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPhasesAsync();
        await LoadHomeownersAsync();
    }

    private async Task LoadPhasesAsync()
    {
        if (!ActiveSubdivisionId.HasValue)
        {
            _phases = [];
            return;
        }

        _phases = await DbContext.Phases
            .AsNoTracking()
            .Where(phase => phase.SubdivisionId == ActiveSubdivisionId.Value)
            .OrderBy(phase => phase.Name)
            .ToListAsync();
    }

    private async Task LoadHomeownersAsync()
    {
        if (!ActiveSubdivisionId.HasValue)
        {
            _homeowners = [];
            _isLoading = false;
            return;
        }

        _isLoading = true;
        StateHasChanged();

        _homeowners = await HomeownerService.SearchAsync(
            ActiveSubdivisionId,
            NullIfEmpty(_nameFilter),
            NullIfEmpty(_statusFilter),
            _phaseFilter,
            null,
            NullIfEmpty(_categoryFilter));

        _isLoading = false;
    }

    private async Task HandleSubdivisionChange(int? subdivisionId)
    {
        _phaseFilter = null;
        await LoadPhasesAsync();
        await LoadHomeownersAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnNameInput(ChangeEventArgs args)
    {
        _nameFilter = args.Value?.ToString() ?? string.Empty;
        await LoadHomeownersAsync();
    }

    private async Task OnStatusChanged(ChangeEventArgs args)
    {
        _statusFilter = args.Value?.ToString() ?? string.Empty;
        await LoadHomeownersAsync();
    }

    private async Task OnCategoryChanged(ChangeEventArgs args)
    {
        _categoryFilter = args.Value?.ToString() ?? string.Empty;
        await LoadHomeownersAsync();
    }

    private async Task OnPhaseChanged(ChangeEventArgs args)
    {
        _phaseFilter = int.TryParse(args.Value?.ToString(), out var phaseId) ? phaseId : null;
        await LoadHomeownersAsync();
    }

    private async Task ImportCsvAsync(InputFileChangeEventArgs args)
    {
        _importErrors.Clear();
        _importMessage = null;

        var file = args.File;
        if (!CanWriteHomeowners || file is null || AuthService.CurrentUser is null)
        {
            return;
        }

        await using var stream = file.OpenReadStream(5 * 1024 * 1024);
        var result = await HomeownerService.ImportFromCsvAsync(stream, AuthService.CurrentUser.UserId);

        _importErrors.AddRange(result.Errors);
        _importTone = result.Errors.Count == 0
            ? "success"
            : result.ImportedCount > 0
                ? "warning"
                : "error";

        _importMessage = result.Errors.Count == 0
            ? $"Imported {result.ImportedCount} homeowner record(s) successfully."
            : $"Imported {result.ImportedCount} homeowner record(s). Some rows could not be processed.";

        await JS.InvokeVoidAsync("hrms.showToast", _importMessage, _importTone);
        await LoadHomeownersAsync();
    }

    private void AskDelete(Homeowner homeowner)
    {
        _pendingDeleteId = homeowner.HomeownerId;
        _confirmMessage = $"Are you sure you want to delete {GetFullName(homeowner)}?";
        _showConfirm = true;
    }

    private Task CancelDelete()
    {
        _showConfirm = false;
        _pendingDeleteId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteConfirmedAsync()
    {
        _showConfirm = false;

        if (!_pendingDeleteId.HasValue || AuthService.CurrentUser is null)
        {
            return;
        }

        var deleted = await HomeownerService.SoftDeleteAsync(_pendingDeleteId.Value, AuthService.CurrentUser.UserId);
        _pendingDeleteId = null;

        if (deleted)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Homeowner deleted successfully.", "success");
            await LoadHomeownersAsync();
        }
    }

    private string GetPhaseValue() => _phaseFilter?.ToString() ?? string.Empty;

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static List<string> GetCategories(Homeowner homeowner) =>
        string.IsNullOrWhiteSpace(homeowner.Categories)
            ? []
            : homeowner.Categories
                .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .ToList();

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;
}
