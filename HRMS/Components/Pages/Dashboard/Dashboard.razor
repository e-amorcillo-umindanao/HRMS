@page "/dashboard"
@inject ReportService ReportService
@inject AuthService AuthService
@inject IJSRuntime JS

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (AuthService.IsHomeowner())
{
    <PageHeader Title="Dashboard"
                Subtitle="A quick view of your account activity and standing." />

    @if (_homeownerDashboard is null)
    {
        <div class="card border border-base-300 bg-base-100 shadow-none">
            <EmptyState Title="No dashboard data available"
                        Subtitle="This account is not linked to a homeowner profile yet."
                        Icon="○" />
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="card border border-base-300 bg-base-100 shadow-none">
                <div class="card-body p-5">
                    <p class="text-xs font-semibold uppercase tracking-wide text-base-content/50">
                        Engagement Score
                    </p>
                    <p class="mt-1 text-4xl font-bold text-base-content">
                        @_homeownerDashboard.EngagementScore.ToString("0.##")
                    </p>
                    <div class="mt-3">
                        <EngagementBadge Score="@_homeownerDashboard.EngagementScore" />
                    </div>
                    <p class="mt-3 text-xs text-base-content/40">
                        @_homeownerDashboard.EngagementLabel
                    </p>
                </div>
            </div>
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 md:grid-cols-1 xl:grid-cols-3">
                <KpiCard Label="Unpaid Dues"
                         Value="@_homeownerDashboard.UnpaidDuesCount.ToString()"
                         Accent="warning" />
                <KpiCard Label="Open Violations"
                         Value="@_homeownerDashboard.OpenViolationCount.ToString()"
                         Accent="error" />
                <KpiCard Label="Pending Clearances"
                         Value="@_homeownerDashboard.PendingClearanceCount.ToString()"
                         Accent="warning" />
            </div>
        </div>
    }
}
else
{
    <PageHeader Title="Dashboard"
                Subtitle="ERP/CRM overview and key performance metrics." />

    <div class="mb-6 grid grid-cols-2 gap-4 xl:grid-cols-3">
        <KpiCard Label="Total Homeowners" Value="@_dashboardKpis.TotalHomeowners.ToString()" Accent="primary" />
        <KpiCard Label="Active Homeowners" Value="@_dashboardKpis.ActiveHomeowners.ToString()" Accent="success" />
        <KpiCard Label="Total Units" Value="@_dashboardKpis.TotalUnits.ToString()" Accent="ghost" />
        <KpiCard Label="Open Violations" Value="@_dashboardKpis.OpenViolations.ToString()" Accent="error" />
        <KpiCard Label="Unpaid / Overdue Dues" Value="@_dashboardKpis.UnpaidOrOverdueDues.ToString()" Accent="warning" />
        <KpiCard Label="Pending Clearances" Value="@_dashboardKpis.PendingClearances.ToString()" Accent="warning" />
    </div>

    @if (AuthService.IsAtLeast("Staff"))
    {
        <div class="mb-6 grid grid-cols-1 gap-4 xl:grid-cols-2">
            <div class="card border border-base-300 bg-base-100 shadow-none">
                <div class="card-body p-0">
                    <div class="border-b border-base-300 p-5">
                        <p class="text-sm font-semibold text-base-content">Engagement Trend</p>
                        <p class="mt-0.5 text-xs text-base-content/40">
                            Average homeowner engagement score across the last 6 months.
                        </p>
                    </div>
                    <div class="p-5">
                        @if (_engagementTrend.Count == 0 || _engagementTrend.All(point => point.Value == 0))
                        {
                            <EmptyState Title="No engagement trend data"
                                        Subtitle="Engagement data will appear here once homeowners, events, and interactions are recorded."
                                        Icon="○" />
                        }
                        else
                        {
                            <canvas id="engagementCanvas" height="220"></canvas>
                        }
                    </div>
                </div>
            </div>

            <div class="card border border-base-300 bg-base-100 shadow-none">
                <div class="card-body p-0">
                    <div class="border-b border-base-300 p-5">
                        <p class="text-sm font-semibold text-base-content">Attendance Trend</p>
                        <p class="mt-0.5 text-xs text-base-content/40">
                            Present attendees across the most recent 10 events.
                        </p>
                    </div>
                    <div class="p-5">
                        @if (_attendanceTrend.Count == 0)
                        {
                            <EmptyState Title="No attendance data"
                                        Subtitle="Create events and record attendance to populate this chart."
                                        Icon="○" />
                        }
                        else
                        {
                            <canvas id="attendanceCanvas" height="220"></canvas>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (AuthService.IsAtLeast("Board Member"))
    {
        <div class="card border border-base-300 bg-base-100 shadow-none">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <p class="text-sm font-semibold text-base-content">MSME Analytics</p>
                    <p class="mt-0.5 text-xs text-base-content/40">
                        Current registry status breakdown for subdivision businesses.
                    </p>
                </div>
                <div class="p-5">
                    @if (_msmeStatusBreakdown.All(item => item.Value == 0))
                    {
                        <EmptyState Title="No MSME data yet"
                                    Subtitle="Registered businesses will appear here once the MSME registry has entries."
                                    Icon="○" />
                    }
                    else
                    {
                        <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
                            @foreach (var item in _msmeStatusBreakdown)
                            {
                                <div class="rounded-box border border-base-300 bg-base-100 p-4">
                                    <p class="text-xs font-semibold uppercase tracking-wide text-base-content/40">
                                        @item.Label
                                    </p>
                                    <p class="mt-1 text-3xl font-bold text-base-content">
                                        @item.Value
                                    </p>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

@code {
    private DashboardKpiSummary _dashboardKpis = new();
    private HomeownerDashboardSummary? _homeownerDashboard;
    private List<TrendPoint> _engagementTrend = [];
    private List<TrendPoint> _attendanceTrend = [];
    private List<StatusBreakdownItem> _msmeStatusBreakdown = [];
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_isLoading && !AuthService.IsHomeowner())
        {
            if (_engagementTrend.Count > 0 && _engagementTrend.Any(point => point.Value > 0))
            {
                await JS.InvokeVoidAsync(
                    "hrms.renderEngagementChart",
                    "engagementCanvas",
                    _engagementTrend.Select(point => point.Label).ToArray(),
                    _engagementTrend.Select(point => point.Value).ToArray());
            }

            if (_attendanceTrend.Count > 0)
            {
                await JS.InvokeVoidAsync(
                    "hrms.renderAttendanceChart",
                    "attendanceCanvas",
                    _attendanceTrend.Select(point => point.Label).ToArray(),
                    _attendanceTrend.Select(point => point.Value).ToArray());
            }
        }
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        if (AuthService.IsHomeowner())
        {
            var homeownerId = AuthService.CurrentUser?.HomeownerId;
            _homeownerDashboard = homeownerId.HasValue
                ? await ReportService.GetHomeownerDashboardAsync(homeownerId.Value)
                : null;
        }
        else
        {
            _dashboardKpis = await ReportService.GetDashboardKPIsAsync();
            _engagementTrend = await ReportService.GetEngagementTrendAsync();
            _attendanceTrend = await ReportService.GetAttendanceTrendAsync();

            if (AuthService.IsAtLeast("Board Member"))
            {
                _msmeStatusBreakdown = await ReportService.GetMSMEStatusBreakdownAsync();
            }
        }

        _isLoading = false;
    }
}
