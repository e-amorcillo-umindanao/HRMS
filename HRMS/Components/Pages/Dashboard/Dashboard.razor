@page "/dashboard"
@inject ReportService ReportService
@inject AuthService AuthService

<PageHeader Title="Dashboard" />

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (AuthService.IsHomeowner())
{
    @if (_homeownerDashboard is null)
    {
        <MudPaper Class="hrms-page-card" Elevation="0">
            <EmptyState Title="No dashboard data available"
                        Subtitle="This account is not linked to a homeowner profile yet."
                        Icon="@Icons.Material.Filled.Dashboard" />
        </MudPaper>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudPaper Class="hrms-page-card" Style="padding: 24px;" Elevation="0">
                    <MudText Style="color: #64748B; font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">
                        Engagement Score
                    </MudText>
                    <MudText Style="color: #1E293B; font-size: 2rem; font-weight: 700; margin-top: 6px;">
                        @_homeownerDashboard.EngagementScore.ToString("0.##")
                    </MudText>
                    <div style="margin-top: 12px;">
                        <EngagementBadge Label="@_homeownerDashboard.EngagementLabel" />
                    </div>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <KpiCard Title="Unpaid Dues"
                         Value="@_homeownerDashboard.UnpaidDuesCount.ToString()" />
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <KpiCard Title="Open Violations"
                         Value="@_homeownerDashboard.OpenViolationCount.ToString()" />
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <KpiCard Title="Pending Clearances"
                         Value="@_homeownerDashboard.PendingClearanceCount.ToString()" />
            </MudItem>
        </MudGrid>
    }
}
else
{
    <MudGrid Style="margin-bottom: 24px;">
        <MudItem xs="12" sm="6" lg="2">
            <KpiCard Title="Total Homeowners" Value="@_dashboardKpis.TotalHomeowners.ToString()" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2">
            <KpiCard Title="Active Homeowners" Value="@_dashboardKpis.ActiveHomeowners.ToString()" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2">
            <KpiCard Title="Total Units" Value="@_dashboardKpis.TotalUnits.ToString()" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2">
            <KpiCard Title="Open Violations" Value="@_dashboardKpis.OpenViolations.ToString()" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2">
            <KpiCard Title="Unpaid / Overdue Dues" Value="@_dashboardKpis.UnpaidOrOverdueDues.ToString()" />
        </MudItem>
        <MudItem xs="12" sm="6" lg="2">
            <KpiCard Title="Pending Clearances" Value="@_dashboardKpis.PendingClearances.ToString()" />
        </MudItem>
    </MudGrid>

    @if (AuthService.IsAtLeast("Staff"))
    {
        <MudGrid Style="margin-bottom: 24px;">
            <MudItem xs="12" lg="6">
                <MudPaper Class="hrms-page-card" Style="padding: 24px; min-height: 380px;" Elevation="0">
                    <MudText Style="color: #1E293B; font-size: 1rem; font-weight: 700; margin-bottom: 6px;">
                        Engagement Trend
                    </MudText>
                    <MudText Style="color: #64748B; margin-bottom: 16px;">
                        Average homeowner engagement score across the last 6 months.
                    </MudText>

                    @if (_engagementTrend.Count == 0 || _engagementTrend.All(point => point.Value == 0))
                    {
                        <EmptyState Title="No engagement trend data"
                                    Subtitle="Engagement data will appear here once homeowners, events, and interactions are recorded."
                                    Icon="@Icons.Material.Filled.ShowChart" />
                    }
                    else
                    {
                        <MudChart T="double"
                                  ChartType="ChartType.Line"
                                  ChartSeries="@EngagementTrendSeries"
                                  ChartLabels="@EngagementTrendLabels"
                                  Width="100%"
                                  Height="280px" />
                    }
                </MudPaper>
            </MudItem>

            <MudItem xs="12" lg="6">
                <MudPaper Class="hrms-page-card" Style="padding: 24px; min-height: 380px;" Elevation="0">
                    <MudText Style="color: #1E293B; font-size: 1rem; font-weight: 700; margin-bottom: 6px;">
                        Attendance Trend
                    </MudText>
                    <MudText Style="color: #64748B; margin-bottom: 16px;">
                        Present attendees across the most recent 10 events.
                    </MudText>

                    @if (_attendanceTrend.Count == 0)
                    {
                        <EmptyState Title="No attendance data"
                                    Subtitle="Create events and record attendance to populate this chart."
                                    Icon="@Icons.Material.Filled.BarChart" />
                    }
                    else
                    {
                        <MudChart T="double"
                                  ChartType="ChartType.Bar"
                                  ChartSeries="@AttendanceTrendSeries"
                                  ChartLabels="@AttendanceTrendLabels"
                                  Width="100%"
                                  Height="280px" />
                    }
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    @if (AuthService.IsAtLeast("Board Member"))
    {
        <MudPaper Class="hrms-page-card" Style="padding: 24px;" Elevation="0">
            <MudText Style="color: #1E293B; font-size: 1rem; font-weight: 700; margin-bottom: 6px;">
                MSME Analytics
            </MudText>
            <MudText Style="color: #64748B; margin-bottom: 16px;">
                Current registry status breakdown for subdivision businesses.
            </MudText>

            @if (_msmeStatusBreakdown.All(item => item.Value == 0))
            {
                <EmptyState Title="No MSME data yet"
                            Subtitle="Registered businesses will appear here once the MSME registry has entries."
                            Icon="@Icons.Material.Filled.Storefront" />
            }
            else
            {
                <div style="max-width: 480px;">
                    <MudChart T="double"
                              ChartType="ChartType.Donut"
                              ChartSeries="@MsmStatusSeries"
                              ChartLabels="@MsmStatusLabels"
                              Width="100%"
                              Height="320px" />
                </div>
            }
        </MudPaper>
    }
}

@code {
    private DashboardKpiSummary _dashboardKpis = new();
    private HomeownerDashboardSummary? _homeownerDashboard;
    private List<TrendPoint> _engagementTrend = [];
    private List<TrendPoint> _attendanceTrend = [];
    private List<StatusBreakdownItem> _msmeStatusBreakdown = [];
    private bool _isLoading = true;

    private List<ChartSeries<double>> EngagementTrendSeries =>
    [
        new ChartSeries<double>
        {
            Name = "Average Score",
            Data = _engagementTrend.Select(point => point.Value).ToArray()
        }
    ];

    private string[] EngagementTrendLabels =>
        _engagementTrend.Select(point => point.Label).ToArray();

    private List<ChartSeries<double>> AttendanceTrendSeries =>
    [
        new ChartSeries<double>
        {
            Name = "Present Attendees",
            Data = _attendanceTrend.Select(point => point.Value).ToArray()
        }
    ];

    private string[] AttendanceTrendLabels =>
        _attendanceTrend.Select(point => point.Label).ToArray();

    private List<ChartSeries<double>> MsmStatusSeries =>
    [
        new ChartSeries<double>
        {
            Name = "MSME Status",
            Data = _msmeStatusBreakdown.Select(item => (double)item.Value).ToArray()
        }
    ];

    private string[] MsmStatusLabels =>
        _msmeStatusBreakdown.Select(item => item.Label).ToArray();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        if (AuthService.IsHomeowner())
        {
            var homeownerId = AuthService.CurrentUser?.HomeownerId;
            _homeownerDashboard = homeownerId.HasValue
                ? await ReportService.GetHomeownerDashboardAsync(homeownerId.Value)
                : null;
        }
        else
        {
            _dashboardKpis = await ReportService.GetDashboardKPIsAsync();
            _engagementTrend = await ReportService.GetEngagementTrendAsync();
            _attendanceTrend = await ReportService.GetAttendanceTrendAsync();

            if (AuthService.IsAtLeast("Board Member"))
            {
                _msmeStatusBreakdown = await ReportService.GetMSMEStatusBreakdownAsync();
            }
        }

        _isLoading = false;
    }
}
