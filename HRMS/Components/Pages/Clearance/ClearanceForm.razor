@page "/clearance/new"
@inject ClearanceService ClearanceService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="New Clearance Request"
            Subtitle="Create a new request on behalf of a homeowner." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4 text-sm">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Request Details</p>
            <div class="divider my-0 mb-4"></div>

            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Homeowner">
                    <select class="select select-bordered w-full" @bind="_selectedHomeownerId">
                        <option value="">Select homeowner</option>
                        @foreach (var homeowner in _homeowners.OrderBy(GetHomeownerDisplay))
                        {
                            <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Clearance / Document Type">
                    <select class="select select-bordered w-full" @bind="_model.ClearanceType">
                        <option value="">Select type</option>
                        @foreach (var type in ClearanceTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Purpose">
                    <select class="select select-bordered w-full" @bind="_model.Purpose">
                        <option value="">Select purpose</option>
                        @foreach (var purpose in Purposes)
                        {
                            <option value="@purpose">@purpose</option>
                        }
                    </select>
                </FieldGroup>
            </div>
        </div>

        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync">Save</button>
        </div>
    </div>
}

@code {
    private static readonly string[] ClearanceTypes = ["HOA Clearance", "Certificate of Residency", "Certificate of Good Standing", "Official Letter"];
    private static readonly string[] Purposes = ["Employment", "Travel", "School", "Business", "Renovation", "Selling", "Other"];

    private readonly ClearanceFormModel _model = new();
    private List<Homeowner> _homeowners = [];
    private int? _selectedHomeownerId;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsHomeowner())
        {
            NavigationManager.NavigateTo("/clearance");
            return;
        }

        _homeowners = await HomeownerService.GetAllAsync();
        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null || !_selectedHomeownerId.HasValue)
        {
            return;
        }

        await ClearanceService.AddAsync(new ClearanceRequest
        {
            HomeownerId = _selectedHomeownerId.Value,
            ClearanceType = _model.ClearanceType,
            Purpose = _model.Purpose
        }, AuthService.CurrentUser.UserId);

        await JS.InvokeVoidAsync("hrms.showToast", "Clearance request created successfully.", "success");
        NavigationManager.NavigateTo("/clearance");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/clearance");
    }

    private string? Validate()
    {
        if (!_selectedHomeownerId.HasValue)
        {
            return "Homeowner is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.ClearanceType))
        {
            return "Clearance Type is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.Purpose))
        {
            return "Purpose is required.";
        }

        return null;
    }

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private sealed class ClearanceFormModel
    {
        public string ClearanceType { get; set; } = string.Empty;
        public string Purpose { get; set; } = string.Empty;
    }
}
