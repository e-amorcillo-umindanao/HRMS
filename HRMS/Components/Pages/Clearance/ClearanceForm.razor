@page "/clearance/new"
@inject ClearanceService ClearanceService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageHeader Title="New Clearance Request" Subtitle="Create a new request on behalf of a homeowner." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <MudPaper Class="hrms-page-card" Style="padding: 24px;" Elevation="0">
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Style="margin-bottom: 16px;">
                @_errorMessage
            </MudAlert>
        }

        <div style="font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Request Details</div>
        <MudDivider Style="margin: 8px 0 20px;" />
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudAutocomplete T="Homeowner"
                                 Label="Homeowner"
                                 Value="_selectedHomeowner"
                                 ValueChanged="OnHomeownerChanged"
                                 SearchFunc="SearchHomeownersAsync"
                                 ToStringFunc="GetHomeownerDisplay"
                                 Variant="Variant.Outlined"
                                 Clearable="true"
                                 ResetValueOnEmptyText="true"
                                 MaxItems="8"
                                 Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" Label="Clearance / Document Type" @bind-Value="_model.ClearanceType" Variant="Variant.Outlined">
                    @foreach (var type in ClearanceTypes)
                    {
                        <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" Label="Purpose" @bind-Value="_model.Purpose" Variant="Variant.Outlined">
                    @foreach (var purpose in Purposes)
                    {
                        <MudSelectItem T="string" Value="@purpose">@purpose</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid #E2E8F0; display: flex; justify-content: flex-end; gap: 12px;">
            <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
        </div>
    </MudPaper>
}

@code {
    private static readonly string[] ClearanceTypes = ["HOA Clearance", "Certificate of Residency", "Certificate of Good Standing", "Official Letter"];
    private static readonly string[] Purposes = ["Employment", "Travel", "School", "Business", "Renovation", "Selling", "Other"];

    private readonly ClearanceFormModel _model = new();
    private List<Homeowner> _homeowners = [];
    private Homeowner? _selectedHomeowner;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsHomeowner())
        {
            NavigationManager.NavigateTo("/clearance");
            return;
        }

        _homeowners = await HomeownerService.GetAllAsync();
        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null || _selectedHomeowner is null)
        {
            return;
        }

        await ClearanceService.AddAsync(new ClearanceRequest
        {
            HomeownerId = _selectedHomeowner.HomeownerId,
            ClearanceType = _model.ClearanceType,
            Purpose = _model.Purpose
        }, AuthService.CurrentUser.UserId);

        Snackbar.Add("Clearance request created successfully.", Severity.Success);
        NavigationManager.NavigateTo("/clearance");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/clearance");
    }

    private string? Validate()
    {
        if (_selectedHomeowner is null)
        {
            return "Homeowner is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.ClearanceType))
        {
            return "Clearance Type is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.Purpose))
        {
            return "Purpose is required.";
        }

        return null;
    }

    private Task OnHomeownerChanged(Homeowner? homeowner)
    {
        _selectedHomeowner = homeowner;
        return Task.CompletedTask;
    }

    private Task<IEnumerable<Homeowner>> SearchHomeownersAsync(string value, CancellationToken cancellationToken)
    {
        IEnumerable<Homeowner> matches = _homeowners
            .OrderBy(homeowner => homeowner.LastName)
            .ThenBy(homeowner => homeowner.FirstName);

        if (!string.IsNullOrWhiteSpace(value))
        {
            matches = matches.Where(homeowner =>
                GetHomeownerDisplay(homeowner).Contains(value, StringComparison.OrdinalIgnoreCase));
        }

        return Task.FromResult(matches.Take(8));
    }

    private static string GetHomeownerDisplay(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return string.Empty;
        }

        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private sealed class ClearanceFormModel
    {
        public string ClearanceType { get; set; } = string.Empty;
        public string Purpose { get; set; } = string.Empty;
    }
}
