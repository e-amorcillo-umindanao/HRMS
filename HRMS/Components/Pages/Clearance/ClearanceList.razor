@page "/clearance"
@inject ClearanceService ClearanceService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Clearance & Documents"
            Subtitle="Track request status, approvals, and generated HOA clearances.">
    <Actions>
        @if (!AuthService.IsHomeowner())
        {
            <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/clearance/new")'>
                New Request
            </button>
        }
    </Actions>
</PageHeader>

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="form-control min-w-[200px] flex-1">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Homeowner Name</span>
                </label>
                <input type="text"
                       class="input input-bordered input-sm w-full"
                       placeholder="Search name..."
                       value="@_homeownerNameFilter"
                       @oninput="OnHomeownerNameInput" />
            </div>
            <div class="form-control min-w-[148px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Status</span>
                </label>
                <select class="select select-bordered select-sm" value="@_statusFilter" @onchange="OnStatusChanged">
                    <option value="">All Statuses</option>
                    @foreach (var status in StatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="form-control min-w-[200px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Clearance Type</span>
                </label>
                <select class="select select-bordered select-sm" value="@_clearanceTypeFilter" @onchange="OnClearanceTypeChanged">
                    <option value="">All Types</option>
                    @foreach (var type in ClearanceTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_requests.Count == 0)
        {
            <EmptyState Title="No clearance requests found"
                        Subtitle="Create a request or adjust your filters to see results."
                        Icon="O" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Homeowner</th>
                            <th>Type</th>
                            <th>Purpose</th>
                            <th>Requested</th>
                            <th>Status</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in _requests)
                        {
                            <tr class="h-[52px] hover">
                                <td class="text-sm text-base-content">@GetFullName(request.Homeowner)</td>
                                <td>
                                    <span class="badge badge-sm @GetClearanceTypeBadge(request.ClearanceType)">
                                        @DisplayValue(request.ClearanceType)
                                    </span>
                                </td>
                                <td class="text-sm text-base-content/60">@DisplayValue(request.Purpose)</td>
                                <td class="text-sm text-base-content/60">@FormatDate(request.RequestedAt)</td>
                                <td><StatusChip Status="@request.Status" /></td>
                                <td class="text-right">
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/clearance/{request.ClearanceId}")'>
                                        View
                                    </button>
                                    @if (CanManageOfficialClearances && request.Status == "Pending")
                                    {
                                        <button class="btn btn-ghost btn-xs text-success"
                                                @onclick='() => NavigationManager.NavigateTo($"/clearance/{request.ClearanceId}")'>
                                            Approve
                                        </button>
                                        <button class="btn btn-ghost btn-xs text-error"
                                                @onclick='() => NavigationManager.NavigateTo($"/clearance/{request.ClearanceId}")'>
                                            Reject
                                        </button>
                                    }
                                    @if (CanManageOfficialClearances && request.Status == "Approved")
                                    {
                                        <button class="btn btn-ghost btn-xs text-primary"
                                                @onclick="() => GeneratePdfAsync(request.ClearanceId)">
                                            PDF
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_requests.Count == 0 ? 0 : 1)"
                                  To="@_requests.Count"
                                  Total="@_requests.Count"
                                  Entity="clearance requests" />
            </div>
        }
    </div>
</div>

@code {
    private static readonly string[] StatusOptions = ["Pending", "Approved", "Rejected"];
    private static readonly string[] ClearanceTypes = ["HOA Clearance", "Certificate of Residency", "Certificate of Good Standing", "Official Letter"];

    private List<ClearanceRequest> _requests = [];
    private string _homeownerNameFilter = string.Empty;
    private string _statusFilter = string.Empty;
    private string _clearanceTypeFilter = string.Empty;
    private bool _isLoading = true;
    private bool CanManageOfficialClearances => AuthService.IsAtLeast("HOA President");

    protected override async Task OnInitializedAsync()
    {
        await LoadRequestsAsync();
    }

    private async Task LoadRequestsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        _requests = await ClearanceService.SearchAsync(
            NullIfEmpty(_homeownerNameFilter),
            NullIfEmpty(_statusFilter),
            NullIfEmpty(_clearanceTypeFilter),
            AuthService.IsHomeowner() ? AuthService.CurrentUser?.HomeownerId : null);

        _isLoading = false;
    }

    private async Task OnHomeownerNameInput(ChangeEventArgs args)
    {
        _homeownerNameFilter = args.Value?.ToString() ?? string.Empty;
        await LoadRequestsAsync();
    }

    private async Task OnStatusChanged(ChangeEventArgs args)
    {
        _statusFilter = args.Value?.ToString() ?? string.Empty;
        await LoadRequestsAsync();
    }

    private async Task OnClearanceTypeChanged(ChangeEventArgs args)
    {
        _clearanceTypeFilter = args.Value?.ToString() ?? string.Empty;
        await LoadRequestsAsync();
    }

    private async Task GeneratePdfAsync(int clearanceId)
    {
        if (AuthService.CurrentRole is null)
        {
            return;
        }

        try
        {
            var document = await DocumentService.GenerateHoaClearanceAsync(clearanceId, AuthService.CurrentRole);
            if (document is null)
            {
                await JS.InvokeVoidAsync("hrms.showToast", "Unable to generate clearance PDF.", "error");
                return;
            }

            var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
            await File.WriteAllBytesAsync(filePath, document.Bytes);

            await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
                new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                    document.FileName,
                    new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
        }
        catch (UnauthorizedAccessException exception)
        {
            await JS.InvokeVoidAsync("hrms.showToast", exception.Message, "error");
        }
    }

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static string GetClearanceTypeBadge(string? clearanceType) => clearanceType switch
    {
        "HOA Clearance" => "badge-info",
        "Certificate of Residency" => "badge-success",
        "Certificate of Good Standing" => "badge-success",
        "Official Letter" => "badge-warning",
        _ => "badge-ghost"
    };
}
