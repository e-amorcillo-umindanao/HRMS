@page "/clearance"
@inject ClearanceService ClearanceService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageHeader Title="Clearance & Documents" Subtitle="Track request status, approvals, and generated HOA clearances." />

<MudPaper Class="hrms-page-card" Style="padding: 16px; margin-bottom: 24px;" Elevation="0">
    <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end;">
        <FieldGroup Label="Homeowner Name" Style="min-width: 220px;">
            <MudTextField T="string"
                          Value="_homeownerNameFilter"
                          ValueChanged="OnHomeownerNameFilterChanged"
                          Variant="Variant.Outlined"
                          Immediate="true" />
        </FieldGroup>

        <FieldGroup Label="Status" Style="min-width: 180px;">
            <MudSelect T="string"
                       Value="_statusFilter"
                       ValueChanged="OnStatusFilterChanged"
                       Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">All Statuses</MudSelectItem>
                @foreach (var status in StatusOptions)
                {
                    <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
        </FieldGroup>

        <FieldGroup Label="Clearance Type" Style="min-width: 240px;">
            <MudSelect T="string"
                       Value="_clearanceTypeFilter"
                       ValueChanged="OnClearanceTypeFilterChanged"
                       Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">All Types</MudSelectItem>
                @foreach (var type in ClearanceTypes)
                {
                    <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                }
            </MudSelect>
        </FieldGroup>

        @if (!AuthService.IsHomeowner())
        {
            <div style="margin-left: auto;">
                <MudButton Color="Color.Primary" Variant="Variant.Filled" Href="/clearance/new">
                    New Request
                </MudButton>
            </div>
        }
    </div>
</MudPaper>

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_requests.Count == 0)
{
    <MudPaper Class="hrms-page-card" Elevation="0">
        <EmptyState Title="No clearance requests found"
                    Subtitle="Create a request or adjust your filters to see results."
                    Icon="@Icons.Material.Filled.Description" />
    </MudPaper>
}
else
{
    <MudPaper Class="hrms-page-card" Elevation="0">
        <MudTable T="ClearanceRequest" Items="_requests" Hover="false" Striped="false">
            <HeaderContent>
                <MudTh>Homeowner</MudTh>
                <MudTh>Clearance Type</MudTh>
                <MudTh>Purpose</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Requested At</MudTh>
                <MudTh>Processed At</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Homeowner">@GetFullName(context.Homeowner)</MudTd>
                <MudTd DataLabel="Clearance Type">@DisplayValue(context.ClearanceType)</MudTd>
                <MudTd DataLabel="Purpose">@DisplayValue(context.Purpose)</MudTd>
                <MudTd DataLabel="Status"><StatusChip Label="@context.Status" /></MudTd>
                <MudTd DataLabel="Requested At">@FormatDate(context.RequestedAt)</MudTd>
                <MudTd DataLabel="Processed At">@FormatDate(context.ProcessedAt)</MudTd>
                <MudTd DataLabel="Actions">
                    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/clearance/{context.ClearanceId}"))">
                            View
                        </MudButton>
                        @if (!AuthService.IsHomeowner() && context.Status == "Pending")
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/clearance/{context.ClearanceId}"))">
                                Approve / Reject
                            </MudButton>
                        }
                        @if (context.Status == "Approved")
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => GeneratePdfAsync(context.ClearanceId))">
                                Generate PDF
                            </MudButton>
                        }
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
    <TableRecordCount Count="_requests.Count" EntityLabel="clearance requests" />
}

@code {
    private static readonly string[] StatusOptions = ["Pending", "Approved", "Rejected"];
    private static readonly string[] ClearanceTypes = ["HOA Clearance", "Certificate of Residency", "Certificate of Good Standing", "Official Letter"];

    private List<ClearanceRequest> _requests = [];
    private string _homeownerNameFilter = string.Empty;
    private string _statusFilter = string.Empty;
    private string _clearanceTypeFilter = string.Empty;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequestsAsync();
    }

    private async Task LoadRequestsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        _requests = await ClearanceService.SearchAsync(
            NullIfEmpty(_homeownerNameFilter),
            NullIfEmpty(_statusFilter),
            NullIfEmpty(_clearanceTypeFilter),
            AuthService.IsHomeowner() ? AuthService.CurrentUser?.HomeownerId : null);

        _isLoading = false;
    }

    private async Task OnHomeownerNameFilterChanged(string value)
    {
        _homeownerNameFilter = value;
        await LoadRequestsAsync();
    }

    private async Task OnStatusFilterChanged(string value)
    {
        _statusFilter = value;
        await LoadRequestsAsync();
    }

    private async Task OnClearanceTypeFilterChanged(string value)
    {
        _clearanceTypeFilter = value;
        await LoadRequestsAsync();
    }

    private async Task GeneratePdfAsync(int clearanceId)
    {
        var document = await DocumentService.GenerateHoaClearanceAsync(clearanceId);
        if (document is null)
        {
            Snackbar.Add("Unable to generate clearance PDF.", Severity.Error);
            return;
        }

        var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
        await File.WriteAllBytesAsync(filePath, document.Bytes);

        await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
            new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                document.FileName,
                new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
    }

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }
}
