@page "/clearance/{Id:int}"
@inject ClearanceService ClearanceService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_request is null)
{
    <PageHeader Title="Clearance Request" Subtitle="The requested clearance record could not be loaded." />
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No clearance request available"
                    Subtitle="The requested clearance request could not be found."
                    Icon="O" />
    </div>
}
else
{
    <PageHeader Title="@_request.ClearanceType" Subtitle="Clearance request details.">
        <Actions>
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">Back</button>
            @if (CanManageOfficialClearances && _request.Status == "Approved")
            {
                <button class="btn btn-outline btn-sm" @onclick="GeneratePdfAsync">Generate PDF</button>
            }
        </Actions>
    </PageHeader>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
        <div class="card border border-base-300 bg-base-100 shadow-none xl:col-span-2">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <p class="text-sm font-semibold text-base-content">Request Information</p>
                    <p class="mt-0.5 text-xs text-base-content/40">Full details and processing history.</p>
                </div>
                <div class="p-5">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
                        @DetailField("Homeowner", GetFullName(_request.Homeowner))
                        @DetailField("Type", DisplayValue(_request.ClearanceType))
                        @DetailField("Status", DisplayValue(_request.Status))
                        @DetailField("Purpose", DisplayValue(_request.Purpose))
                        @DetailField("Requested At", FormatDate(_request.RequestedAt))
                        @DetailField("Processed At", FormatDate(_request.ProcessedAt))
                        @DetailField("Processed By", DisplayValue(_request.ProcessedByUser?.Username))
                        @DetailField("Valid Until", FormatDate(_request.ValidUntil))
                        @DetailField("Remarks", DisplayValue(_request.Remarks))
                    </div>
                </div>
            </div>
        </div>

        <div class="card border border-base-300 bg-base-100 shadow-none xl:col-span-1">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <p class="text-sm font-semibold text-base-content">Status</p>
                    <div class="mt-2">
                        <StatusChip Status="@_request.Status" />
                    </div>
                </div>
                <div class="p-5">
                    @if (CanManageOfficialClearances && _request.Status == "Pending")
                    {
                        @if (!string.IsNullOrWhiteSpace(_errorMessage))
                        {
                            <div role="alert" class="alert alert-error mb-4 text-sm">
                                <span>@_errorMessage</span>
                            </div>
                        }

                        <div class="grid gap-4">
                            <FieldGroup Label="Valid Until">
                                <input type="date"
                                       class="input input-bordered w-full"
                                       value="@FormatHtmlDate(_validUntil)"
                                       @onchange="OnValidUntilChanged" />
                            </FieldGroup>
                            <FieldGroup Label="Remarks">
                                <textarea class="textarea textarea-bordered h-28 w-full resize-none"
                                          @bind="_remarks"></textarea>
                            </FieldGroup>
                        </div>

                        <div class="mt-5 flex justify-end gap-3">
                            <button class="btn btn-ghost btn-sm text-error" @onclick="RejectAsync">Reject</button>
                            <button class="btn btn-primary btn-sm" @onclick="ApproveAsync">Approve</button>
                        </div>
                    }
                    else
                    {
                        <p class="text-sm text-base-content/60">
                            This request is read-only. Pending requests can be approved or rejected by the HOA President and above.
                        </p>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ClearanceRequest? _request;
    private DateTime? _validUntil;
    private string _remarks = string.Empty;
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool CanManageOfficialClearances => AuthService.IsAtLeast("HOA President");

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _request = await ClearanceService.GetByIdAsync(Id);

        if (_request is not null && AuthService.IsHomeowner() && _request.HomeownerId != AuthService.CurrentUser?.HomeownerId)
        {
            NavigationManager.NavigateTo("/clearance");
            return;
        }

        _isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/clearance");
    }

    private async Task ApproveAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        try
        {
            var approved = await ClearanceService.ApproveAsync(Id, AuthService.CurrentUser.UserId, _remarks, _validUntil);
            if (approved is null)
            {
                _errorMessage = "Unable to approve the request.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "Clearance request approved.", "success");
            _request = await ClearanceService.GetByIdAsync(Id);
        }
        catch (UnauthorizedAccessException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private async Task RejectAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_remarks))
        {
            _errorMessage = "Remarks are required when rejecting a request.";
            return;
        }

        try
        {
            var rejected = await ClearanceService.RejectAsync(Id, AuthService.CurrentUser.UserId, _remarks);
            if (rejected is null)
            {
                _errorMessage = "Unable to reject the request.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "Clearance request rejected.", "success");
            _request = await ClearanceService.GetByIdAsync(Id);
        }
        catch (UnauthorizedAccessException exception)
        {
            _errorMessage = exception.Message;
        }
    }

    private async Task GeneratePdfAsync()
    {
        if (AuthService.CurrentRole is null)
        {
            return;
        }

        try
        {
            var document = await DocumentService.GenerateHoaClearanceAsync(Id, AuthService.CurrentRole);
            if (document is null)
            {
                await JS.InvokeVoidAsync("hrms.showToast", "Unable to generate clearance PDF.", "error");
                return;
            }

            var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
            await File.WriteAllBytesAsync(filePath, document.Bytes);

            await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
                new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                    document.FileName,
                    new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
        }
        catch (UnauthorizedAccessException exception)
        {
            await JS.InvokeVoidAsync("hrms.showToast", exception.Message, "error");
        }
    }

    private void OnValidUntilChanged(ChangeEventArgs args) =>
        _validUntil = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static RenderFragment DetailField(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.OpenElement(1, "p");
        builder.AddAttribute(2, "class", "text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40");
        builder.AddContent(3, label);
        builder.CloseElement();
        builder.OpenElement(4, "p");
        builder.AddAttribute(5, "class", "mt-0.5 text-sm text-base-content");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };
}
