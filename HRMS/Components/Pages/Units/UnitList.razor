@page "/units"
@inject AppDbContext DbContext
@inject UnitService UnitService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Units"
            Subtitle="Track subdivision units, head homeowners, and occupant assignments.">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/units/add")'>
            Add Unit
        </button>
    </Actions>
</PageHeader>

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="form-control min-w-[200px] flex-1">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Address</span>
                </label>
                <input type="text"
                       class="input input-bordered input-sm w-full"
                       placeholder="Search address..."
                       value="@_addressFilter"
                       @oninput="OnAddressInput" />
            </div>

            <div class="form-control min-w-[160px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Phase</span>
                </label>
                <select class="select select-bordered select-sm" value="@GetPhaseValue()" @onchange="OnPhaseChanged">
                    <option value="">All Phases</option>
                    @foreach (var phase in _phases)
                    {
                        <option value="@phase.PhaseId">@phase.Name</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_units.Count == 0)
        {
            <EmptyState Title="No units found"
                        Subtitle="Try adjusting your filters or add a unit record."
                        Icon="○" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Unit Number</th>
                            <th>Address</th>
                            <th>Phase</th>
                            <th>Head Homeowner</th>
                            <th>Occupants</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var unit in _units)
                        {
                            <tr class="h-[52px] hover">
                                <td class="text-sm text-base-content">@DisplayValue(unit.UnitNumber)</td>
                                <td class="text-sm text-base-content/60">@DisplayValue(unit.Address)</td>
                                <td class="text-sm text-base-content/60">@DisplayValue(unit.Phase?.Name)</td>
                                <td class="text-sm text-base-content/60">@DisplayValue(GetFullName(unit.HeadHomeowner))</td>
                                <td class="text-sm text-base-content/60">@GetOccupantCount(unit)</td>
                                <td class="text-right">
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/units/{unit.UnitId}")'>
                                        View
                                    </button>
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/units/edit/{unit.UnitId}")'>
                                        Edit
                                    </button>
                                    <button class="btn btn-ghost btn-xs text-error"
                                            @onclick='() => AskDelete(unit)'>
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_units.Count == 0 ? 0 : 1)"
                                  To="@_units.Count"
                                  Total="@_units.Count"
                                  Entity="units" />
            </div>
        }
    </div>
</div>

<ConfirmDialog IsVisible="@_showConfirm"
               Title="Delete Unit"
               Message="@_confirmMessage"
               ConfirmLabel="Delete"
               OnConfirm="DeleteConfirmedAsync"
               OnCancel="CancelDelete" />

@code {
    private List<Unit> _units = [];
    private List<Phase> _phases = [];
    private string _addressFilter = string.Empty;
    private int? _phaseFilter;
    private bool _isLoading = true;
    private bool _showConfirm;
    private int? _pendingDeleteId;
    private string _confirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _phases = await DbContext.Phases
            .AsNoTracking()
            .OrderBy(p => p.Name)
            .ToListAsync();

        await LoadUnitsAsync();
    }

    private async Task LoadUnitsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        _units = await UnitService.SearchAsync(NullIfEmpty(_addressFilter), _phaseFilter);

        _isLoading = false;
    }

    private async Task OnAddressInput(ChangeEventArgs args)
    {
        _addressFilter = args.Value?.ToString() ?? string.Empty;
        await LoadUnitsAsync();
    }

    private async Task OnPhaseChanged(ChangeEventArgs args)
    {
        _phaseFilter = int.TryParse(args.Value?.ToString(), out var phaseId) ? phaseId : null;
        await LoadUnitsAsync();
    }

    private void AskDelete(Unit unit)
    {
        _pendingDeleteId = unit.UnitId;
        _confirmMessage = $"Are you sure you want to delete unit {unit.UnitNumber}?";
        _showConfirm = true;
    }

    private Task CancelDelete()
    {
        _showConfirm = false;
        _pendingDeleteId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteConfirmedAsync()
    {
        _showConfirm = false;

        if (!_pendingDeleteId.HasValue || AuthService.CurrentUser is null)
        {
            return;
        }

        var result = await UnitService.DeleteAsync(_pendingDeleteId.Value, AuthService.CurrentUser.UserId);
        _pendingDeleteId = null;

        if (!result.Success)
        {
            await JS.InvokeVoidAsync("hrms.showToast", result.ErrorMessage ?? "Unable to delete unit.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "Unit deleted successfully.", "success");
        await LoadUnitsAsync();
    }

    private string GetPhaseValue() => _phaseFilter?.ToString() ?? string.Empty;

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private static string? GetFullName(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return null;
        }

        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static int GetOccupantCount(Unit unit) =>
        unit.Homeowners.Count(homeowner => !homeowner.IsDeleted);
}
