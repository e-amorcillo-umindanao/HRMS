@page "/units/{Id:int}"
@inject UnitService UnitService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_unit is null)
{
    <PageHeader Title="Unit" Subtitle="The requested unit could not be loaded." />
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No unit available"
                    Subtitle="The requested unit record could not be found."
                    Icon="○" />
    </div>
}
else
{
    <PageHeader Title="@_unit.UnitNumber" Subtitle="Unit details and occupant assignments.">
        <Actions>
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">Back</button>
            @if (CanWriteUnits)
            {
                <button class="btn btn-primary btn-sm"
                        @onclick='() => NavigationManager.NavigateTo($"/units/{_unit.UnitId}/edit")'>
                    Edit
                </button>
            }
        </Actions>
    </PageHeader>

    <div class="grid grid-cols-1 gap-4 xl:grid-cols-3">
        <div class="card border border-base-300 bg-base-100 shadow-none xl:col-span-1">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <p class="text-sm font-semibold text-base-content">Unit Information</p>
                </div>
                <div class="space-y-3 p-5">
                    @DetailField("Unit Number", DisplayValue(_unit.UnitNumber))
                    @DetailField("Address", DisplayValue(_unit.Address))
                    @DetailField("Phase", DisplayValue(_unit.Phase?.Name))
                    @DetailField("Head Homeowner", DisplayValue(GetFullName(_unit.HeadHomeowner)))
                </div>
            </div>
        </div>

        <div class="card border border-base-300 bg-base-100 shadow-none xl:col-span-2">
            <div class="card-body p-0">
                <div class="border-b border-base-300 p-5">
                    <p class="text-sm font-semibold text-base-content">Occupants</p>
                    <p class="mt-0.5 text-xs text-base-content/40">Assign existing homeowners to this unit.</p>
                </div>

                @if (CanWriteUnits)
                {
                    <div class="border-b border-base-300 p-5">
                        <div class="flex flex-wrap items-end gap-3">
                            <div class="form-control min-w-[260px] flex-1">
                                <label class="label py-0 pb-1">
                                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Add Occupant</span>
                                </label>
                                <select class="select select-bordered w-full" @bind="_selectedOccupantId">
                                    <option value="">Select homeowner...</option>
                                    @foreach (var homeowner in AssignableHomeowners)
                                    {
                                        <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                                    }
                                </select>
                            </div>
                            <button class="btn btn-primary btn-sm" @onclick="AssignOccupantAsync">Assign Homeowner</button>
                        </div>
                    </div>
                }

                <div class="p-5">
                    @if (_occupants.Count == 0)
                    {
                        <EmptyState Title="No occupants assigned"
                                    Subtitle="Assign an existing homeowner to start tracking unit occupancy."
                                    Icon="○" />
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="table table-sm">
                                <thead>
                                    <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                        <th>Homeowner</th>
                                        <th>Status</th>
                                        <th>Contact Number</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var occupant in _occupants)
                                    {
                                        <tr class="h-[52px] hover">
                                            <td class="text-sm text-base-content">@GetFullName(occupant)</td>
                                            <td><StatusChip Status="@occupant.Status" /></td>
                                            <td class="text-sm text-base-content/60">@DisplayValue(occupant.ContactNumber)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <TableRecordCount From="1" To="@_occupants.Count" Total="@_occupants.Count" Entity="occupants" />
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Unit? _unit;
    private List<Homeowner> _occupants = [];
    private List<Homeowner> _activeHomeowners = [];
    private int? _selectedOccupantId;
    private bool _isLoading = true;
    private bool CanWriteUnits => AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "units");

    private IEnumerable<Homeowner> AssignableHomeowners
    {
        get
        {
            var occupantIds = _occupants.Select(homeowner => homeowner.HomeownerId).ToHashSet();
            return _activeHomeowners
                .Where(homeowner => !occupantIds.Contains(homeowner.HomeownerId))
                .OrderBy(homeowner => homeowner.LastName)
                .ThenBy(homeowner => homeowner.FirstName);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _unit = await UnitService.GetByIdAsync(Id);
        _occupants = await UnitService.GetOccupantsAsync(Id);
        _activeHomeowners = await HomeownerService.GetAllActiveAsync();
        _selectedOccupantId = null;
        _isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/units");
    }

    private async Task AssignOccupantAsync()
    {
        if (!_selectedOccupantId.HasValue)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Select a homeowner to assign.", "warning");
            return;
        }

        if (AuthService.CurrentUser is null)
        {
            return;
        }

        var result = await UnitService.AssignHomeownerAsync(Id, _selectedOccupantId.Value, AuthService.CurrentUser.UserId);
        if (!result.Success)
        {
            await JS.InvokeVoidAsync("hrms.showToast", result.ErrorMessage ?? "Unable to assign homeowner.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "Homeowner assigned successfully.", "success");
        await LoadAsync();
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetFullName(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return "-";
        }

        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var fullName = GetFullName(homeowner);
        var unitNumber = string.IsNullOrWhiteSpace(homeowner.Unit?.UnitNumber) ? null : homeowner.Unit.UnitNumber;

        return string.IsNullOrWhiteSpace(unitNumber)
            ? fullName
            : $"{fullName} ({unitNumber})";
    }

    private static RenderFragment DetailField(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.OpenElement(1, "p");
        builder.AddAttribute(2, "class", "text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40");
        builder.AddContent(3, label);
        builder.CloseElement();
        builder.OpenElement(4, "p");
        builder.AddAttribute(5, "class", "mt-0.5 text-sm text-base-content");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };
}
