@page "/units/add"
@page "/units/new"
@page "/units/edit/{UnitId:int}"
@page "/units/{UnitId:int}/edit"
@inject AppDbContext DbContext
@inject UnitService UnitService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="@(IsEdit ? "Edit Unit" : "Add Unit")"
            Subtitle="Capture unit details and optionally assign a head homeowner." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Unit Information</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Unit Number">
                    <input type="text" class="input input-bordered w-full" @bind="_model.UnitNumber" />
                </FieldGroup>
                <FieldGroup Label="Address">
                    <input type="text" class="input input-bordered w-full" @bind="_model.Address" />
                </FieldGroup>
                <FieldGroup Label="Phase">
                    <select class="select select-bordered w-full" @bind="_model.PhaseId">
                        <option value="">-</option>
                        @foreach (var phase in _phases)
                        {
                            <option value="@phase.PhaseId">@phase.Name</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Head Homeowner">
                    <select class="select select-bordered w-full" @bind="_selectedHeadHomeownerId">
                        <option value="">-</option>
                        @foreach (var homeowner in _activeHomeowners.OrderBy(GetHomeownerDisplay))
                        {
                            <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                        }
                    </select>
                </FieldGroup>
            </div>
        </div>

        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                Save
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    public int? UnitId { get; set; }

    private readonly UnitFormModel _model = new();
    private List<Phase> _phases = [];
    private List<Homeowner> _activeHomeowners = [];
    private int? _selectedHeadHomeownerId;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin ? null : AuthService.CurrentSubdivisionId;

    private bool IsEdit => UnitId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _phases = await DbContext.Phases
            .AsNoTracking()
            .Where(phase => !ActiveSubdivisionId.HasValue || phase.SubdivisionId == ActiveSubdivisionId.Value)
            .OrderBy(p => p.Name)
            .ToListAsync();

        _activeHomeowners = await HomeownerService.GetAllActiveAsync(ActiveSubdivisionId);

        if (IsEdit)
        {
            var unit = await UnitService.GetByIdAsync(UnitId.GetValueOrDefault(), ActiveSubdivisionId);
            if (unit is null)
            {
                _errorMessage = "Unit record not found.";
                _isLoading = false;
                return;
            }

            _model.UnitId = unit.UnitId;
            _model.UnitNumber = unit.UnitNumber;
            _model.Address = unit.Address;
            _model.PhaseId = unit.PhaseId;

            if (unit.HeadHomeowner is not null && _activeHomeowners.All(homeowner => homeowner.HomeownerId != unit.HeadHomeowner.HomeownerId))
            {
                _activeHomeowners.Add(unit.HeadHomeowner);
            }

            _selectedHeadHomeownerId = unit.HeadHomeowner?.HomeownerId;
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null)
        {
            return;
        }

        _isSaving = true;

        var unit = new Unit
        {
            UnitId = _model.UnitId ?? 0,
            UnitNumber = _model.UnitNumber.Trim(),
            Address = _model.Address.Trim(),
            PhaseId = _model.PhaseId,
            HeadHomeownerId = _selectedHeadHomeownerId
        };

        if (IsEdit)
        {
            var updated = await UnitService.UpdateAsync(unit, AuthService.CurrentUser.UserId);
            _isSaving = false;

            if (updated is null)
            {
                _errorMessage = "Unable to update unit.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "Unit updated successfully.", "success");
            NavigationManager.NavigateTo($"/units/{updated.UnitId}");
            return;
        }

        var created = await UnitService.AddAsync(unit, AuthService.CurrentUser.UserId);
        _isSaving = false;
        await JS.InvokeVoidAsync("hrms.showToast", "Unit added successfully.", "success");
        NavigationManager.NavigateTo($"/units/{created.UnitId}");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(IsEdit ? $"/units/{UnitId}" : "/units");
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.UnitNumber))
        {
            return "Unit Number is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.Address))
        {
            return "Address is required.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.UnitId = null;
        _model.UnitNumber = string.Empty;
        _model.Address = string.Empty;
        _model.PhaseId = null;
        _selectedHeadHomeownerId = null;
    }

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var fullName = GetFullName(homeowner);
        var unitNumber = string.IsNullOrWhiteSpace(homeowner.Unit?.UnitNumber) ? null : homeowner.Unit.UnitNumber;

        return string.IsNullOrWhiteSpace(unitNumber)
            ? fullName
            : $"{fullName} ({unitNumber})";
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private sealed class UnitFormModel
    {
        public int? UnitId { get; set; }
        public string UnitNumber { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public int? PhaseId { get; set; }
    }
}
