@page "/documents"
@inject HomeownerService HomeownerService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject IJSRuntime JS

<PageHeader Title="Documents"
            Subtitle="Generate official HOA certificates and letters." />

<div class="card max-w-2xl border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        <div class="border-b border-base-300 p-5">
            <p class="text-sm font-semibold text-base-content">Generate Document</p>
            <p class="mt-0.5 text-xs text-base-content/40">Select a homeowner and document type to generate.</p>
        </div>

        <div class="flex flex-col gap-5 p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error text-sm">
                    <span>@_errorMessage</span>
                </div>
            }

            <FieldGroup Label="Homeowner">
                <select class="select select-bordered w-full" @bind="_selectedHomeownerId">
                    <option value="">Select homeowner...</option>
                    @foreach (var homeowner in _homeowners.OrderBy(GetHomeownerDisplay))
                    {
                        <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                    }
                </select>
            </FieldGroup>

            <div>
                <p class="mb-3 text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">Document Type</p>
                <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
                    @foreach (var option in DocumentOptions)
                    {
                        <button type="button"
                                class="@GetDocCardClass(option.Key)"
                                @onclick="() => SelectDocument(option.Key)">
                            @option.Label
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="flex justify-end border-t border-base-300 px-6 py-4">
            <button class="btn btn-primary btn-sm"
                    disabled="@IsGenerateDisabled"
                    @onclick="GenerateAsync">
                Generate PDF
            </button>
        </div>
    </div>
</div>

@code {
    private static readonly (string Key, string Label)[] DocumentOptions =
    [
        ("Residency", "Certificate of Residency"),
        ("GoodStanding", "Certificate of Good Standing"),
        ("OfficialLetter", "Official Letter")
    ];

    private List<Homeowner> _homeowners = [];
    private int? _selectedHomeownerId;
    private string _selectedDocumentType = string.Empty;
    private string? _errorMessage;

    private bool IsGenerateDisabled => !_selectedHomeownerId.HasValue || string.IsNullOrWhiteSpace(_selectedDocumentType);

    protected override async Task OnInitializedAsync()
    {
        _homeowners = await HomeownerService.GetAllActiveAsync();
    }

    private void SelectDocument(string key)
    {
        _selectedDocumentType = key;
    }

    private async Task GenerateAsync()
    {
        _errorMessage = null;

        if (!_selectedHomeownerId.HasValue || string.IsNullOrWhiteSpace(_selectedDocumentType))
        {
            _errorMessage = "Select a homeowner and document type first.";
            return;
        }

        try
        {
            GeneratedDocumentResult? document = _selectedDocumentType switch
            {
                "Residency" when AuthService.CurrentRole is not null => await DocumentService.GenerateCertificateOfResidencyAsync(_selectedHomeownerId.Value, AuthService.CurrentRole),
                "GoodStanding" when AuthService.CurrentRole is not null => await DocumentService.GenerateCertificateOfGoodStandingAsync(_selectedHomeownerId.Value, AuthService.CurrentRole),
                "OfficialLetter" when AuthService.CurrentRole is not null => await DocumentService.GenerateOfficialLetterAsync(_selectedHomeownerId.Value, AuthService.CurrentRole),
                _ => null
            };

            if (document is null)
            {
                _errorMessage = "Unable to generate the selected document.";
                return;
            }

            var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
            await File.WriteAllBytesAsync(filePath, document.Bytes);

            await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
                new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                    document.FileName,
                    new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
        }
        catch (InvalidOperationException exception)
        {
            _errorMessage = exception.Message;
            await JS.InvokeVoidAsync("hrms.showToast", exception.Message, "error");
        }
        catch (UnauthorizedAccessException exception)
        {
            _errorMessage = exception.Message;
            await JS.InvokeVoidAsync("hrms.showToast", exception.Message, "error");
        }
    }

    private string GetDocCardClass(string type) =>
        $"{(type == _selectedDocumentType ? "border-2 border-primary bg-primary/10 text-primary font-semibold" : "border border-base-300 bg-base-100 text-base-content hover:border-base-content/30")} min-h-[72px] rounded text-sm flex items-center justify-center p-3 text-center transition-all";

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }
}
