@page "/dues/add"
@page "/dues/new"
@page "/dues/edit/{DuesId:int}"
@page "/dues/{DuesId:int}/edit"
@inject DuesService DuesService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="@(IsEdit ? "Edit Dues Record" : "Record Dues")"
            Subtitle="Capture monthly dues, due dates, and payment status." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Dues Information</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-4">
                <div class="md:col-span-2">
                    <FieldGroup Label="Homeowner">
                        <select class="select select-bordered w-full" @bind="_selectedHomeownerId">
                            <option value="">Select homeowner...</option>
                            @foreach (var homeowner in _activeHomeowners.OrderBy(GetHomeownerDisplay))
                            {
                                <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                            }
                        </select>
                    </FieldGroup>
                </div>
                <FieldGroup Label="Month">
                    <select class="select select-bordered w-full" @bind="_model.Month">
                        @foreach (var month in Enumerable.Range(1, 12))
                        {
                            <option value="@month">@GetMonthName(month)</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Year">
                    <select class="select select-bordered w-full" @bind="_model.Year">
                        @foreach (var year in _yearOptions)
                        {
                            <option value="@year">@year</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Amount">
                    <input type="text"
                           inputmode="decimal"
                           class="input input-bordered w-full"
                           placeholder="0.00"
                           value="@_amountInput"
                           @oninput="OnAmountInput"
                           @onblur="FormatAmountOnBlur" />
                </FieldGroup>
                <FieldGroup Label="Due Date">
                    <input type="date"
                           class="input input-bordered w-full"
                           max="@MaxDueDateString"
                           value="@FormatHtmlDate(_dueDate)"
                           @onchange="OnDueDateChanged" />
                </FieldGroup>
            </div>

            <p class="mb-2 mt-8 text-xs font-semibold uppercase tracking-wide text-base-content/40">Payment</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <FieldGroup Label="Status">
                    <select class="select select-bordered w-full" @bind="_model.Status" @bind:after="OnStatusChanged">
                        @foreach (var status in StatusOptions)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </FieldGroup>
                @if (_model.Status == "Paid")
                {
                    <FieldGroup Label="Paid Date">
                        <input type="date"
                               class="input input-bordered w-full"
                               max="@TodayDateString"
                               value="@FormatHtmlDate(_paidDate)"
                               @onchange="OnPaidDateChanged" />
                    </FieldGroup>
                }
            </div>
        </div>
        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                Save
            </button>
        </div>
    </div>
}

@code {
    private static readonly string[] StatusOptions = ["Paid", "Unpaid", "Overdue"];

    [Parameter]
    public int? DuesId { get; set; }

    private readonly DuesFormModel _model = new();
    private List<Homeowner> _activeHomeowners = [];
    private List<int> _yearOptions = [];
    private int? _selectedHomeownerId;
    private DateTime? _dueDate;
    private DateTime? _paidDate;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;
    private string _amountInput = "0.00";
    private bool _hasAmountParseError;
    private int MinDuesYear => 2020;
    private int MaxDuesYear => DateTime.Today.Year + 1;
    private string MaxDueDateString => new DateTime(MaxDuesYear, 12, 31).ToString("yyyy-MM-dd");
    private static string TodayDateString => DateTime.Today.ToString("yyyy-MM-dd");
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin ? null : AuthService.CurrentSubdivisionId;

    private bool IsEdit => DuesId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _activeHomeowners = await HomeownerService.GetAllActiveAsync(ActiveSubdivisionId);
        _yearOptions = BuildYearOptions();

        if (IsEdit)
        {
            var dues = await DuesService.GetByIdAsync(DuesId.GetValueOrDefault(), ActiveSubdivisionId);
            if (dues is null)
            {
                _errorMessage = "Dues record not found.";
                _isLoading = false;
                return;
            }

            _model.DuesId = dues.DuesId;
            _model.Month = dues.Month;
            _model.Year = dues.Year;
            _model.Amount = dues.Amount;
            _amountInput = FormatHelper.Number(dues.Amount);
            _hasAmountParseError = false;
            _model.Status = dues.Status;
            _dueDate = ParseDate(dues.DueDate);
            _paidDate = ParseDate(dues.PaidDate);
            _selectedHomeownerId = dues.HomeownerId;
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        FormatAmountOnBlur();
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null || !_selectedHomeownerId.HasValue)
        {
            return;
        }

        _isSaving = true;

        var dues = new DuesRecord
        {
            DuesId = _model.DuesId ?? 0,
            HomeownerId = _selectedHomeownerId.Value,
            Month = _model.Month,
            Year = _model.Year,
            Amount = _model.Amount,
            DueDate = ToIsoDateString(_dueDate!.Value),
            Status = _model.Status,
            PaidDate = _model.Status == "Paid" && _paidDate.HasValue
                ? ToIsoDateString(_paidDate.Value)
                : null
        };

        try
        {
            if (IsEdit)
            {
                var updated = await DuesService.UpdateAsync(dues, AuthService.CurrentUser.UserId);
                _isSaving = false;

                if (updated is null)
                {
                    _errorMessage = "Unable to update dues record.";
                    return;
                }

                await JS.InvokeVoidAsync("hrms.showToast", "Dues record updated successfully.", "success");
            }
            else
            {
                await DuesService.AddAsync(dues, AuthService.CurrentUser.UserId);
                _isSaving = false;
                await JS.InvokeVoidAsync("hrms.showToast", "Dues record added successfully.", "success");
            }

            NavigationManager.NavigateTo("/dues");
        }
        catch (InvalidOperationException exception)
        {
            _isSaving = false;
            _errorMessage = exception.Message;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/dues");
    }

    private string? Validate()
    {
        if (!_selectedHomeownerId.HasValue)
        {
            return "Homeowner is required.";
        }

        if (_model.Month is < 1 or > 12)
        {
            return "Month is required.";
        }

        if (_model.Year < 2000)
        {
            return "Year is required.";
        }

        if (_model.Year < MinDuesYear || _model.Year > MaxDuesYear)
        {
            return $"Year must be between {MinDuesYear} and {MaxDuesYear}.";
        }

        if (_hasAmountParseError)
        {
            return "Amount must be a valid number.";
        }

        if (_model.Amount <= 0)
        {
            return "Amount must be greater than zero.";
        }

        if (_dueDate is null)
        {
            return "Due Date is required.";
        }

        if (_dueDate.Value.Date > new DateTime(MaxDuesYear, 12, 31))
        {
            return $"Due Date cannot be later than {MaxDueDateString}.";
        }

        if (_model.Status == "Paid" && !_paidDate.HasValue)
        {
            return "Paid Date is required when status is Paid.";
        }

        if (_model.Status == "Paid" && _paidDate!.Value.Date > DateTime.Today)
        {
            return "Paid Date cannot be in the future.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.DuesId = null;
        _model.Month = DateTime.UtcNow.Month;
        _model.Year = DateTime.UtcNow.Year;
        _model.Amount = 0;
        _amountInput = FormatHelper.Number(_model.Amount);
        _hasAmountParseError = false;
        _model.Status = "Unpaid";
        _selectedHomeownerId = null;
        _dueDate = DateTime.UtcNow.Date;
        _paidDate = null;
    }

    private Task OnStatusChanged()
    {
        if (_model.Status != "Paid")
        {
            _paidDate = null;
        }

        return Task.CompletedTask;
    }

    private static List<int> BuildYearOptions()
    {
        const int minDuesYear = 2020;
        var maxDuesYear = DateTime.Today.Year + 1;

        return Enumerable.Range(minDuesYear, maxDuesYear - minDuesYear + 1)
            .OrderByDescending(year => year)
            .ToList();
    }

    private void OnAmountInput(ChangeEventArgs args)
    {
        _amountInput = args.Value?.ToString() ?? string.Empty;

        if (TryParseAmount(_amountInput, out var amount))
        {
            _model.Amount = amount;
            _hasAmountParseError = false;
            return;
        }

        _hasAmountParseError = !string.IsNullOrWhiteSpace(_amountInput);
    }

    private void FormatAmountOnBlur()
    {
        if (!TryParseAmount(_amountInput, out var amount))
        {
            return;
        }

        _model.Amount = amount;
        _amountInput = FormatHelper.Number(amount);
        _hasAmountParseError = false;
    }

    private void OnDueDateChanged(ChangeEventArgs args) =>
        _dueDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private void OnPaidDateChanged(ChangeEventArgs args) =>
        _paidDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var fullName = GetFullName(homeowner);
        var unitNumber = string.IsNullOrWhiteSpace(homeowner.Unit?.UnitNumber) ? null : homeowner.Unit.UnitNumber;

        return string.IsNullOrWhiteSpace(unitNumber)
            ? fullName
            : $"{fullName} ({unitNumber})";
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string GetMonthName(int month)
    {
        if (month < 1 || month > 12)
        {
            return "-";
        }

        return System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month);
    }

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string ToIsoDateString(DateTime value) =>
        DateTime.SpecifyKind(value.Date, DateTimeKind.Utc).ToString("o");

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static bool TryParseAmount(string? value, out decimal amount)
    {
        amount = 0;

        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var sanitized = value
            .Replace("\u20B1", string.Empty, StringComparison.Ordinal)
            .Replace("PHP", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace(",", string.Empty, StringComparison.Ordinal)
            .Trim();

        return decimal.TryParse(
            sanitized,
            System.Globalization.NumberStyles.Number,
            System.Globalization.CultureInfo.InvariantCulture,
            out amount);
    }

    private sealed class DuesFormModel
    {
        public int? DuesId { get; set; }
        public int Month { get; set; }
        public int Year { get; set; }
        public decimal Amount { get; set; }
        public string Status { get; set; } = "Unpaid";
    }
}
