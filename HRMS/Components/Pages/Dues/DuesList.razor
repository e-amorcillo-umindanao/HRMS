@page "/dues"
@inject DuesService DuesService
@inject HomeownerService HomeownerService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject SubdivisionContextService SubdivisionContextService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Dues & Fees"
            Subtitle="Track monthly dues, payment status, and homeowner statements.">
    <Actions>
        @if (CanWriteDues)
        {
            <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/dues/add")'>
                Record Dues
            </button>
        }
    </Actions>
</PageHeader>

<SubdivisionSelector OnSubdivisionSelected="HandleSubdivisionChange" />

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="grid grid-cols-1 gap-4 md:grid-cols-4">
            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-base-content/40">Homeowner</label>
                <select class="select select-bordered select-sm w-full" @bind="_selectedHomeownerId" @bind:after="LoadDuesAsync">
                    <option value="">All Homeowners</option>
                    @foreach (var homeowner in _activeHomeowners.OrderBy(GetHomeownerDisplay))
                    {
                        <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                    }
                </select>
            </div>

            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-base-content/40">Status</label>
                <select class="select select-bordered select-sm" @bind="_statusFilter" @bind:after="LoadDuesAsync">
                    <option value="">All Statuses</option>
                    @foreach (var status in StatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>

            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-base-content/40">Month</label>
                <select class="select select-bordered select-sm" @bind="_monthFilter" @bind:after="LoadDuesAsync">
                    <option value="">All Months</option>
                    @foreach (var month in Enumerable.Range(1, 12))
                    {
                        <option value="@month">@GetMonthName(month)</option>
                    }
                </select>
            </div>

            <div>
                <label class="mb-1 block text-xs font-semibold uppercase tracking-wide text-base-content/40">Year</label>
                <select class="select select-bordered select-sm" @bind="_yearFilter" @bind:after="LoadDuesAsync">
                    <option value="">All Years</option>
                    @foreach (var year in _yearOptions)
                    {
                        <option value="@year">@year</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_duesRecords.Count == 0)
        {
            <EmptyState Title="No dues records found"
                        Subtitle="Record dues or adjust your filters to see results."
                        Icon="O" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Homeowner</th>
                            <th>Month / Year</th>
                            <th>Amount</th>
                            <th>Due Date</th>
                            <th>Paid Date</th>
                            <th>Status</th>
                            @if (CanShowActions)
                            {
                                <th class="text-right">Actions</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dues in _duesRecords)
                        {
                            <tr class="h-[52px]">
                                <td class="text-sm font-medium text-base-content">@DisplayValue(GetFullName(dues.Homeowner))</td>
                                <td class="text-sm text-base-content/60">@FormatMonthYear(dues.Month, dues.Year)</td>
                                <td class="text-sm font-medium text-base-content">@FormatCurrency(dues.Amount)</td>
                                <td class="text-sm text-base-content/60">@FormatDate(dues.DueDate)</td>
                                <td class="text-sm text-base-content/60">@FormatDate(dues.PaidDate)</td>
                                <td><StatusChip Status="@dues.Status" /></td>
                                @if (CanShowActions)
                                {
                                    <td class="text-right">
                                        <div class="flex items-center justify-end gap-1">
                                            @if (CanGenerateDocuments)
                                            {
                                                <button class="btn btn-ghost btn-xs" @onclick='() => GenerateStatementAsync(dues.HomeownerId)'>Statement</button>
                                            }
                                            @if (CanWriteDues)
                                            {
                                                @if (dues.Status != "Paid")
                                                {
                                                    <button class="btn btn-ghost btn-xs text-success" @onclick='() => MarkAsPaidAsync(dues.DuesId)'>Mark as Paid</button>
                                                }
                                                <button class="btn btn-ghost btn-xs" @onclick='() => NavigationManager.NavigateTo($"/dues/edit/{dues.DuesId}")'>Edit</button>
                                                <button class="btn btn-ghost btn-xs text-error" @onclick='() => AskDelete(dues)'>Delete</button>
                                            }
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_duesRecords.Count == 0 ? 0 : 1)"
                                  To="@_duesRecords.Count"
                                  Total="@_duesRecords.Count"
                                  Entity="dues records" />
            </div>
        }
    </div>
</div>

<ConfirmDialog IsVisible="@_showConfirm"
               Title="Delete Dues Record"
               Message="@_confirmMessage"
               ConfirmLabel="Delete"
               OnConfirm="DeleteConfirmedAsync"
               OnCancel="CancelDelete" />

@code {
    private static readonly string[] StatusOptions = ["Paid", "Unpaid", "Overdue"];
    private bool CanWriteDues => AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "dues");
    private bool CanGenerateDocuments => AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "documents");
    private bool CanShowActions => CanWriteDues || CanGenerateDocuments;
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin
        ? SubdivisionContextService.SelectedSubdivisionId
        : AuthService.CurrentSubdivisionId;

    private List<DuesRecord> _duesRecords = [];
    private List<Homeowner> _activeHomeowners = [];
    private List<int> _yearOptions = [];
    private int? _selectedHomeownerId;
    private string _statusFilter = string.Empty;
    private int? _monthFilter;
    private int? _yearFilter;
    private bool _isLoading = true;
    private bool _showConfirm;
    private int? _pendingDeleteId;
    private string _confirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadHomeownersAsync();
        _yearOptions = BuildYearOptions([]);
        await LoadDuesAsync();
    }

    private async Task LoadHomeownersAsync()
    {
        _activeHomeowners = ActiveSubdivisionId.HasValue
            ? await HomeownerService.GetAllActiveAsync(ActiveSubdivisionId.Value)
            : [];
    }

    private async Task LoadDuesAsync()
    {
        if (!ActiveSubdivisionId.HasValue)
        {
            _duesRecords = [];
            _isLoading = false;
            return;
        }

        _isLoading = true;
        StateHasChanged();

        var records = await DuesService.GetAllAsync(ActiveSubdivisionId.Value);
        _yearOptions = BuildYearOptions(records);

        _duesRecords = records
            .Where(record => !_selectedHomeownerId.HasValue || record.HomeownerId == _selectedHomeownerId.Value)
            .Where(record => string.IsNullOrWhiteSpace(_statusFilter) || record.Status == _statusFilter)
            .Where(record => !_monthFilter.HasValue || record.Month == _monthFilter.Value)
            .Where(record => !_yearFilter.HasValue || record.Year == _yearFilter.Value)
            .ToList();

        _isLoading = false;
    }

    private async Task HandleSubdivisionChange(int? subdivisionId)
    {
        _selectedHomeownerId = null;
        await LoadHomeownersAsync();
        await LoadDuesAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task GenerateStatementAsync(int homeownerId)
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        var document = await DocumentService.GenerateDuesStatementAsync(homeownerId, AuthService.CurrentUser.UserId);
        if (document is null)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to generate dues statement.", "error");
            return;
        }

        var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
        await File.WriteAllBytesAsync(filePath, document.Bytes);

        await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
            new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                document.FileName,
                new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
    }

    private async Task MarkAsPaidAsync(int duesId)
    {
        if (!CanWriteDues || AuthService.CurrentUser is null)
        {
            return;
        }

        var updated = await DuesService.MarkAsPaidAsync(duesId, DateTime.UtcNow.Date, AuthService.CurrentUser.UserId);
        if (updated is null)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to update dues record.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "Dues record marked as paid.", "success");
        await LoadDuesAsync();
    }

    private void AskDelete(DuesRecord dues)
    {
        _pendingDeleteId = dues.DuesId;
        _confirmMessage = $"Are you sure you want to delete the dues record for {GetFullName(dues.Homeowner)} ({FormatMonthYear(dues.Month, dues.Year)})?";
        _showConfirm = true;
    }

    private Task CancelDelete()
    {
        _showConfirm = false;
        _pendingDeleteId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteConfirmedAsync()
    {
        _showConfirm = false;

        if (!_pendingDeleteId.HasValue || AuthService.CurrentUser is null)
        {
            return;
        }

        var deleted = await DuesService.DeleteAsync(_pendingDeleteId.Value, AuthService.CurrentUser.UserId);
        _pendingDeleteId = null;

        if (!deleted)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to delete dues record.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "Dues record deleted successfully.", "success");
        await LoadDuesAsync();
    }

    private static List<int> BuildYearOptions(IEnumerable<DuesRecord> records)
    {
        var currentYear = DateTime.UtcNow.Year;

        return records
            .Select(record => record.Year)
            .Append(currentYear)
            .Append(currentYear - 1)
            .Append(currentYear + 1)
            .Distinct()
            .OrderByDescending(year => year)
            .ToList();
    }

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var fullName = GetFullName(homeowner);
        var unitNumber = string.IsNullOrWhiteSpace(homeowner.Unit?.UnitNumber) ? null : homeowner.Unit.UnitNumber;

        return string.IsNullOrWhiteSpace(unitNumber)
            ? fullName
            : $"{fullName} ({unitNumber})";
    }

    private static string GetFullName(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return string.Empty;
        }

        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static string FormatMonthYear(int month, int year) =>
        $"{GetMonthName(month)} {year}";

    private static string GetMonthName(int month)
    {
        if (month < 1 || month > 12)
        {
            return "-";
        }

        return System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month);
    }

    private static string FormatCurrency(decimal amount) => $"{'\u20B1'}{amount:N2}";
}
