@page "/dues"
@inject DuesService DuesService
@inject HomeownerService HomeownerService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageHeader Title="Dues & Fees" Subtitle="Track monthly dues, payment status, and homeowner statements." />

<MudPaper Class="hrms-page-card" Style="padding: 16px; margin-bottom: 24px;" Elevation="0">
    <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end;">
        <FieldGroup Label="Homeowner" Style="min-width: 240px;">
            <MudAutocomplete T="Homeowner"
                             Value="_selectedHomeownerFilter"
                             ValueChanged="OnHomeownerFilterChanged"
                             SearchFunc="SearchHomeownersAsync"
                             ToStringFunc="GetHomeownerDisplay"
                             Variant="Variant.Outlined"
                             Clearable="true"
                             ResetValueOnEmptyText="true"
                             MaxItems="8"
                             Dense="true" />
        </FieldGroup>

        <FieldGroup Label="Status" Style="min-width: 180px;">
            <MudSelect T="string"
                       Value="_statusFilter"
                       ValueChanged="OnStatusFilterChanged"
                       Variant="Variant.Outlined">
                <MudSelectItem T="string" Value="@string.Empty">All Statuses</MudSelectItem>
                @foreach (var status in StatusOptions)
                {
                    <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                }
            </MudSelect>
        </FieldGroup>

        <FieldGroup Label="Month" Style="min-width: 180px;">
            <MudSelect T="int?"
                       Value="_monthFilter"
                       ValueChanged="OnMonthFilterChanged"
                       Variant="Variant.Outlined">
                <MudSelectItem T="int?" Value="@((int?)null)">All Months</MudSelectItem>
                @foreach (var month in Enumerable.Range(1, 12))
                {
                    <MudSelectItem T="int?" Value="@month">@GetMonthName(month)</MudSelectItem>
                }
            </MudSelect>
        </FieldGroup>

        <FieldGroup Label="Year" Style="min-width: 140px;">
            <MudSelect T="int?"
                       Value="_yearFilter"
                       ValueChanged="OnYearFilterChanged"
                       Variant="Variant.Outlined">
                <MudSelectItem T="int?" Value="@((int?)null)">All Years</MudSelectItem>
                @foreach (var year in _yearOptions)
                {
                    <MudSelectItem T="int?" Value="@year">@year</MudSelectItem>
                }
            </MudSelect>
        </FieldGroup>

        <div style="margin-left: auto;">
            <MudButton Color="Color.Primary" Variant="Variant.Filled" Href="/dues/add">
                Record Dues
            </MudButton>
        </div>
    </div>
</MudPaper>

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_duesRecords.Count == 0)
{
    <MudPaper Class="hrms-page-card" Elevation="0">
        <EmptyState Title="No dues records found"
                    Subtitle="Record dues or adjust your filters to see results."
                    Icon="@Icons.Material.Filled.Payments" />
    </MudPaper>
}
else
{
    <MudPaper Class="hrms-page-card" Elevation="0">
        <MudTable T="DuesRecord" Items="_duesRecords" Hover="false" Striped="false">
            <HeaderContent>
                <MudTh>Homeowner</MudTh>
                <MudTh>Month/Year</MudTh>
                <MudTh>Amount</MudTh>
                <MudTh>Due Date</MudTh>
                <MudTh>Paid Date</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Homeowner">@DisplayValue(GetFullName(context.Homeowner))</MudTd>
                <MudTd DataLabel="Month/Year">@FormatMonthYear(context.Month, context.Year)</MudTd>
                <MudTd DataLabel="Amount">@FormatCurrency(context.Amount)</MudTd>
                <MudTd DataLabel="Due Date">@FormatDate(context.DueDate)</MudTd>
                <MudTd DataLabel="Paid Date">@FormatDate(context.PaidDate)</MudTd>
                <MudTd DataLabel="Status"><StatusChip Label="@context.Status" /></MudTd>
                <MudTd DataLabel="Actions">
                    <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => GenerateStatementAsync(context.HomeownerId))">
                            Statement
                        </MudButton>
                        @if (context.Status != "Paid")
                        {
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => MarkAsPaidAsync(context.DuesId))">
                                Mark as Paid
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => NavigationManager.NavigateTo($"/dues/edit/{context.DuesId}"))">
                            Edit
                        </MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="@(() => PromptDeleteAsync(context))">
                            Delete
                        </MudButton>
                    </div>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
    <TableRecordCount Count="_duesRecords.Count" EntityLabel="dues records" />
}

@code {
    private static readonly string[] StatusOptions = ["Paid", "Unpaid", "Overdue"];

    private List<DuesRecord> _duesRecords = [];
    private List<Homeowner> _activeHomeowners = [];
    private List<int> _yearOptions = [];
    private Homeowner? _selectedHomeownerFilter;
    private string _statusFilter = string.Empty;
    private int? _monthFilter;
    private int? _yearFilter;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _activeHomeowners = await HomeownerService.GetAllActiveAsync();
        _yearOptions = BuildYearOptions([]);
        await LoadDuesAsync();
    }

    private async Task LoadDuesAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var records = await DuesService.GetAllAsync();
        _yearOptions = BuildYearOptions(records);

        _duesRecords = records
            .Where(record => _selectedHomeownerFilter is null || record.HomeownerId == _selectedHomeownerFilter.HomeownerId)
            .Where(record => string.IsNullOrWhiteSpace(_statusFilter) || record.Status == _statusFilter)
            .Where(record => !_monthFilter.HasValue || record.Month == _monthFilter.Value)
            .Where(record => !_yearFilter.HasValue || record.Year == _yearFilter.Value)
            .ToList();

        _isLoading = false;
    }

    private async Task OnHomeownerFilterChanged(Homeowner? homeowner)
    {
        _selectedHomeownerFilter = homeowner;
        await LoadDuesAsync();
    }

    private async Task OnStatusFilterChanged(string value)
    {
        _statusFilter = value;
        await LoadDuesAsync();
    }

    private async Task OnMonthFilterChanged(int? value)
    {
        _monthFilter = value;
        await LoadDuesAsync();
    }

    private async Task OnYearFilterChanged(int? value)
    {
        _yearFilter = value;
        await LoadDuesAsync();
    }

    private Task<IEnumerable<Homeowner>> SearchHomeownersAsync(string value, CancellationToken cancellationToken)
    {
        IEnumerable<Homeowner> matches = _activeHomeowners
            .OrderBy(homeowner => homeowner.LastName)
            .ThenBy(homeowner => homeowner.FirstName);

        if (!string.IsNullOrWhiteSpace(value))
        {
            matches = matches.Where(homeowner =>
                GetHomeownerDisplay(homeowner).Contains(value, StringComparison.OrdinalIgnoreCase));
        }

        return Task.FromResult(matches.Take(8));
    }

    private async Task GenerateStatementAsync(int homeownerId)
    {
        var document = await DocumentService.GenerateDuesStatementAsync(homeownerId);
        if (document is null)
        {
            Snackbar.Add("Unable to generate dues statement.", Severity.Error);
            return;
        }

        var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
        await File.WriteAllBytesAsync(filePath, document.Bytes);

        await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
            new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                document.FileName,
                new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
    }

    private async Task MarkAsPaidAsync(int duesId)
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        var updated = await DuesService.MarkAsPaidAsync(duesId, DateTime.UtcNow.Date, AuthService.CurrentUser.UserId);
        if (updated is null)
        {
            Snackbar.Add("Unable to update dues record.", Severity.Error);
            return;
        }

        Snackbar.Add("Dues record marked as paid.", Severity.Success);
        await LoadDuesAsync();
    }

    private async Task PromptDeleteAsync(DuesRecord dues)
    {
        var parameters = new DialogParameters
        {
            [nameof(ConfirmDialog.Title)] = "Delete Dues Record",
            [nameof(ConfirmDialog.Message)] = $"Are you sure you want to delete the dues record for {GetFullName(dues.Homeowner)} ({FormatMonthYear(dues.Month, dues.Year)})?",
            [nameof(ConfirmDialog.OnConfirm)] = EventCallback.Factory.Create(this, async () => await DeleteAsync(dues.DuesId))
        };

        await DialogService.ShowAsync<ConfirmDialog>(string.Empty, parameters);
    }

    private async Task DeleteAsync(int duesId)
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        var deleted = await DuesService.DeleteAsync(duesId, AuthService.CurrentUser.UserId);
        if (!deleted)
        {
            Snackbar.Add("Unable to delete dues record.", Severity.Error);
            return;
        }

        Snackbar.Add("Dues record deleted successfully.", Severity.Success);
        await LoadDuesAsync();
    }

    private static List<int> BuildYearOptions(IEnumerable<DuesRecord> records)
    {
        var currentYear = DateTime.UtcNow.Year;

        return records
            .Select(record => record.Year)
            .Append(currentYear)
            .Append(currentYear - 1)
            .Append(currentYear + 1)
            .Distinct()
            .OrderByDescending(year => year)
            .ToList();
    }

    private static string GetHomeownerDisplay(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return string.Empty;
        }

        var fullName = GetFullName(homeowner);
        var unitNumber = string.IsNullOrWhiteSpace(homeowner.Unit?.UnitNumber) ? null : homeowner.Unit.UnitNumber;

        return string.IsNullOrWhiteSpace(unitNumber)
            ? fullName
            : $"{fullName} ({unitNumber})";
    }

    private static string GetFullName(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return string.Empty;
        }

        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static string FormatMonthYear(int month, int year) =>
        $"{GetMonthName(month)} {year}";

    private static string GetMonthName(int month)
    {
        if (month < 1 || month > 12)
        {
            return "-";
        }

        return System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month);
    }

    private static string FormatCurrency(decimal amount) => $"₱{amount:N2}";
}
