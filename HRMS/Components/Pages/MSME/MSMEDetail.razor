@page "/msme/{Id:int}"
@inject MSMEService MSMEService
@inject InteractionService InteractionService
@inject AuthService AuthService
@inject NavigationManager NavigationManager

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_msme is null)
{
    <PageHeader Title="MSME" Subtitle="The requested business could not be loaded." />
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No MSME available"
                    Subtitle="The requested business record could not be found."
                    Icon="O" />
    </div>
}
else
{
    <PageHeader Title="@_msme.BusinessName" Subtitle="MSME profile and interaction history.">
        <Actions>
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">Back</button>
            @if (AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "msme"))
            {
                <button class="btn btn-primary btn-sm"
                        @onclick='() => NavigationManager.NavigateTo($"/msme/edit/{_msme.MSMEId}")'>
                    Edit
                </button>
            }
        </Actions>
    </PageHeader>

    <div class="mb-4 card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-5">
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
                @DetailField("Business Name", DisplayValue(_msme.BusinessName))
                @DetailField("Business Type", DisplayValue(_msme.BusinessType))
                @DetailField("Status", DisplayValue(_msme.Status))
                @DetailField("Unit", DisplayValue(_msme.Unit?.UnitNumber))
                @DetailField("Contact Number", DisplayValue(_msme.ContactNumber))
                @DetailField("Registration Date", FormatDate(_msme.RegistrationDate))
                @DetailField("Expiry Date", FormatDate(_msme.ExpiryDate))
                @DetailField("Description", DisplayValue(_msme.Description))
                <div>
                    <p class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40">Owner</p>
                    @if (_msme.Homeowner is null)
                    {
                        <p class="mt-0.5 text-sm text-base-content">-</p>
                    }
                    else
                    {
                        <button class="btn btn-ghost btn-xs h-auto min-h-0 px-0 text-primary"
                                @onclick='() => NavigationManager.NavigateTo($"/homeowners/{_msme.HomeownerId}")'>
                            @GetFullName(_msme.Homeowner)
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-0">
            <div class="border-b border-base-300 p-5">
                <div class="flex flex-wrap items-center justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold text-base-content">Interaction History</p>
                        <p class="mt-0.5 text-xs text-base-content/40">Review all CRM touchpoints logged against this business.</p>
                    </div>
                    @if (AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "engagement"))
                    {
                        <button class="btn btn-primary btn-sm" @onclick="LogInteraction">Log Interaction</button>
                    }
                </div>
            </div>
            <div class="p-5">
                <InteractionTimeline Logs="_logs" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private MSME? _msme;
    private List<InteractionLog> _logs = [];
    private bool _isLoading = true;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _msme = await MSMEService.GetByIdAsync(Id);
        _logs = await InteractionService.GetByMSMEAsync(Id);
        _isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/msme");
    }

    private void LogInteraction()
    {
        NavigationManager.NavigateTo($"/engagement/log?msmeId={Id}&returnUrl=%2Fmsme%2F{Id}");
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static RenderFragment DetailField(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.OpenElement(1, "p");
        builder.AddAttribute(2, "class", "text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40");
        builder.AddContent(3, label);
        builder.CloseElement();
        builder.OpenElement(4, "p");
        builder.AddAttribute(5, "class", "mt-0.5 text-sm text-base-content");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };
}
