@page "/msme"
@inject MSMEService MSMEService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="MSME Registry"
            Subtitle="Track registered businesses, owners, and permit status.">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/msme/add")'>
            Register Business
        </button>
    </Actions>
</PageHeader>

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="form-control min-w-[200px] flex-1">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Business Name</span>
                </label>
                <input type="text"
                       class="input input-bordered input-sm w-full"
                       placeholder="Search business name..."
                       value="@_nameFilter"
                       @oninput="OnNameInput" />
            </div>

            <div class="form-control min-w-[148px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Status</span>
                </label>
                <select class="select select-bordered select-sm" value="@_statusFilter" @onchange="OnStatusChanged">
                    <option value="">All Statuses</option>
                    @foreach (var status in StatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>

            <div class="form-control min-w-[180px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Business Type</span>
                </label>
                <select class="select select-bordered select-sm" value="@_businessTypeFilter" @onchange="OnBusinessTypeChanged">
                    <option value="">All Business Types</option>
                    @foreach (var businessType in BusinessTypeOptions)
                    {
                        <option value="@businessType">@businessType</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_msmes.Count == 0)
        {
            <EmptyState Title="No MSMEs found"
                        Subtitle="Register a business to begin tracking owners and interactions."
                        Icon="O" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Business Name</th>
                            <th>Business Type</th>
                            <th>Owner</th>
                            <th>Status</th>
                            <th>Registration Date</th>
                            <th>Expiry Date</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var msme in _msmes)
                        {
                            <tr class="h-[52px] hover">
                                <td class="text-sm text-base-content">@DisplayValue(msme.BusinessName)</td>
                                <td>
                                    <span class="badge badge-sm @GetBusinessTypeBadge(msme.BusinessType)">@DisplayValue(msme.BusinessType)</span>
                                </td>
                                <td class="text-sm text-base-content/60">@DisplayValue(GetFullName(msme.Homeowner))</td>
                                <td><StatusChip Status="@msme.Status" /></td>
                                <td class="text-sm text-base-content/60">@FormatDate(msme.RegistrationDate)</td>
                                <td class="@(IsExpiredWarning(msme) ? "text-error font-semibold" : "text-base-content/60") text-sm">@FormatDate(msme.ExpiryDate)</td>
                                <td class="text-right">
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/msme/{msme.MSMEId}")'>
                                        View
                                    </button>
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/msme/edit/{msme.MSMEId}")'>
                                        Edit
                                    </button>
                                    <button class="btn btn-ghost btn-xs text-error"
                                            @onclick='() => AskDelete(msme)'>
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_msmes.Count == 0 ? 0 : 1)"
                                  To="@_msmes.Count"
                                  Total="@_msmes.Count"
                                  Entity="msmes" />
            </div>
        }
    </div>
</div>

<ConfirmDialog IsVisible="@_showConfirm"
               Title="Delete MSME"
               Message="@_confirmMessage"
               ConfirmLabel="Delete"
               OnConfirm="DeleteConfirmedAsync"
               OnCancel="CancelDelete" />

@code {
    private static readonly string[] StatusOptions = ["Active", "Suspended", "Expired", "Closed"];
    private static readonly string[] BusinessTypeOptions =
    [
        "Sari-sari Store",
        "Home Salon/Barbershop",
        "Food Business",
        "Online Selling",
        "Repair Shop",
        "Other"
    ];

    private List<MSME> _msmes = [];
    private string _nameFilter = string.Empty;
    private string _statusFilter = string.Empty;
    private string _businessTypeFilter = string.Empty;
    private bool _isLoading = true;
    private bool _showConfirm;
    private int? _pendingDeleteId;
    private string _confirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadMsmesAsync();
    }

    private async Task LoadMsmesAsync()
    {
        _isLoading = true;
        StateHasChanged();

        _msmes = await MSMEService.SearchAsync(
            NullIfEmpty(_nameFilter),
            NullIfEmpty(_statusFilter),
            NullIfEmpty(_businessTypeFilter));

        _isLoading = false;
    }

    private async Task OnNameInput(ChangeEventArgs args)
    {
        _nameFilter = args.Value?.ToString() ?? string.Empty;
        await LoadMsmesAsync();
    }

    private async Task OnStatusChanged(ChangeEventArgs args)
    {
        _statusFilter = args.Value?.ToString() ?? string.Empty;
        await LoadMsmesAsync();
    }

    private async Task OnBusinessTypeChanged(ChangeEventArgs args)
    {
        _businessTypeFilter = args.Value?.ToString() ?? string.Empty;
        await LoadMsmesAsync();
    }

    private void AskDelete(MSME msme)
    {
        _pendingDeleteId = msme.MSMEId;
        _confirmMessage = $"Are you sure you want to delete {msme.BusinessName}?";
        _showConfirm = true;
    }

    private Task CancelDelete()
    {
        _showConfirm = false;
        _pendingDeleteId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteConfirmedAsync()
    {
        _showConfirm = false;

        if (!_pendingDeleteId.HasValue || AuthService.CurrentUser is null)
        {
            return;
        }

        var deleted = await MSMEService.DeleteAsync(_pendingDeleteId.Value, AuthService.CurrentUser.UserId);
        _pendingDeleteId = null;

        if (!deleted)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to delete MSME.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "MSME deleted successfully.", "success");
        await LoadMsmesAsync();
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private static string? GetFullName(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return null;
        }

        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static bool IsExpiredWarning(MSME msme) =>
        !string.IsNullOrWhiteSpace(msme.ExpiryDate)
        && DateTime.TryParse(msme.ExpiryDate, out var expiryDate)
        && expiryDate.Date < DateTime.Today
        && msme.Status != "Expired"
        && msme.Status != "Closed";

    private static string GetBusinessTypeBadge(string? businessType) => businessType switch
    {
        "Sari-sari Store" => "badge-info",
        "Home Salon/Barbershop" => "badge-success",
        "Food Business" => "badge-warning",
        "Online Selling" => "badge-info",
        "Repair Shop" => "badge-warning",
        _ => "badge-ghost"
    };
}
