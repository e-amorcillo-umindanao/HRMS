@page "/msme/add"
@page "/msme/new"
@page "/msme/edit/{MSMEId:int}"
@page "/msme/{MSMEId:int}/edit"
@inject MSMEService MSMEService
@inject HomeownerService HomeownerService
@inject UnitService UnitService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="@(IsEdit ? "Edit MSME" : "Register Business")"
            Subtitle="Capture business, owner, and registration details." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Business Information</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Business Name">
                    <input type="text" class="input input-bordered w-full" @bind="_model.BusinessName" />
                </FieldGroup>
                <FieldGroup Label="Business Type">
                    <select class="select select-bordered w-full" @bind="_model.BusinessType">
                        <option value="">Select business type</option>
                        @foreach (var businessType in BusinessTypeOptions)
                        {
                            <option value="@businessType">@businessType</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Owner">
                    <select class="select select-bordered w-full" @bind="_selectedOwnerId">
                        <option value="">Select owner...</option>
                        @foreach (var homeowner in _activeHomeowners.OrderBy(GetHomeownerDisplay))
                        {
                            <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Unit">
                    <select class="select select-bordered w-full" @bind="_model.UnitId">
                        <option value="">-</option>
                        @foreach (var unit in _units)
                        {
                            <option value="@unit.UnitId">@($"{unit.UnitNumber} - {unit.Address}")</option>
                        }
                    </select>
                </FieldGroup>
            </div>

            <p class="mb-2 mt-8 text-xs font-semibold uppercase tracking-wide text-base-content/40">Registration Details</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
                <FieldGroup Label="Registration Date">
                    <input type="date"
                           class="input input-bordered w-full"
                           value="@FormatHtmlDate(_registrationDate)"
                           @onchange="OnRegistrationDateChanged" />
                </FieldGroup>
                <FieldGroup Label="Expiry Date">
                    <input type="date"
                           class="input input-bordered w-full"
                           value="@FormatHtmlDate(_expiryDate)"
                           @onchange="OnExpiryDateChanged" />
                </FieldGroup>
                <FieldGroup Label="Status">
                    <select class="select select-bordered w-full" @bind="_model.Status">
                        @foreach (var status in StatusOptions)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </FieldGroup>
            </div>

            <p class="mb-2 mt-8 text-xs font-semibold uppercase tracking-wide text-base-content/40">Additional Information</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Contact Number">
                    <input type="text" class="input input-bordered w-full" @bind="_model.ContactNumber" />
                </FieldGroup>
                <div class="md:col-span-2">
                    <FieldGroup Label="Description">
                        <textarea class="textarea textarea-bordered h-28 w-full resize-none" @bind="_model.Description"></textarea>
                    </FieldGroup>
                </div>
            </div>
        </div>
        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                Save
            </button>
        </div>
    </div>
}

@code {
    private static readonly string[] BusinessTypeOptions =
    [
        "Sari-sari Store",
        "Home Salon/Barbershop",
        "Food Business",
        "Online Selling",
        "Repair Shop",
        "Other"
    ];

    private static readonly string[] StatusOptions = ["Active", "Suspended", "Expired", "Closed"];

    [Parameter]
    public int? MSMEId { get; set; }

    private readonly MSMEFormModel _model = new();
    private List<Homeowner> _activeHomeowners = [];
    private List<Unit> _units = [];
    private int? _selectedOwnerId;
    private DateTime? _registrationDate;
    private DateTime? _expiryDate;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;

    private bool IsEdit => MSMEId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _activeHomeowners = await HomeownerService.GetAllActiveAsync();
        _units = await UnitService.GetAllAsync();

        if (IsEdit)
        {
            var msme = await MSMEService.GetByIdAsync(MSMEId.GetValueOrDefault());
            if (msme is null)
            {
                _errorMessage = "MSME record not found.";
                _isLoading = false;
                return;
            }

            _model.MSMEId = msme.MSMEId;
            _model.BusinessName = msme.BusinessName;
            _model.BusinessType = msme.BusinessType;
            _model.UnitId = msme.UnitId;
            _model.Status = msme.Status;
            _model.ContactNumber = msme.ContactNumber ?? string.Empty;
            _model.Description = msme.Description ?? string.Empty;
            _registrationDate = ParseDate(msme.RegistrationDate);
            _expiryDate = ParseDate(msme.ExpiryDate);
            _selectedOwnerId = msme.HomeownerId;
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null || !_selectedOwnerId.HasValue)
        {
            return;
        }

        _isSaving = true;

        var msme = new MSME
        {
            MSMEId = _model.MSMEId ?? 0,
            BusinessName = _model.BusinessName.Trim(),
            BusinessType = _model.BusinessType,
            HomeownerId = _selectedOwnerId.Value,
            UnitId = _model.UnitId,
            ContactNumber = NullIfEmpty(_model.ContactNumber),
            Description = NullIfEmpty(_model.Description),
            RegistrationDate = ToIsoDateString(_registrationDate!.Value),
            ExpiryDate = _expiryDate.HasValue ? ToIsoDateString(_expiryDate.Value) : null,
            Status = _model.Status
        };

        if (IsEdit)
        {
            var updated = await MSMEService.UpdateAsync(msme, AuthService.CurrentUser.UserId);
            _isSaving = false;

            if (updated is null)
            {
                _errorMessage = "Unable to update MSME.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "MSME updated successfully.", "success");
            NavigationManager.NavigateTo($"/msme/{updated.MSMEId}");
            return;
        }

        var created = await MSMEService.AddAsync(msme, AuthService.CurrentUser.UserId);
        _isSaving = false;
        await JS.InvokeVoidAsync("hrms.showToast", "MSME registered successfully.", "success");
        NavigationManager.NavigateTo($"/msme/{created.MSMEId}");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(IsEdit ? $"/msme/{MSMEId}" : "/msme");
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.BusinessName))
        {
            return "Business Name is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.BusinessType))
        {
            return "Business Type is required.";
        }

        if (!_selectedOwnerId.HasValue)
        {
            return "Owner is required.";
        }

        if (_registrationDate is null)
        {
            return "Registration Date is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.Status))
        {
            return "Status is required.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.MSMEId = null;
        _model.BusinessName = string.Empty;
        _model.BusinessType = string.Empty;
        _model.UnitId = null;
        _model.Status = "Active";
        _model.ContactNumber = string.Empty;
        _model.Description = string.Empty;
        _selectedOwnerId = null;
        _registrationDate = null;
        _expiryDate = null;
    }

    private void OnRegistrationDateChanged(ChangeEventArgs args) =>
        _registrationDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private void OnExpiryDateChanged(ChangeEventArgs args) =>
        _expiryDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var fullName = GetFullName(homeowner);
        var unitNumber = string.IsNullOrWhiteSpace(homeowner.Unit?.UnitNumber) ? null : homeowner.Unit.UnitNumber;

        return string.IsNullOrWhiteSpace(unitNumber)
            ? fullName
            : $"{fullName} ({unitNumber})";
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string ToIsoDateString(DateTime value) =>
        DateTime.SpecifyKind(value.Date, DateTimeKind.Utc).ToString("o");

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class MSMEFormModel
    {
        public int? MSMEId { get; set; }
        public string BusinessName { get; set; } = string.Empty;
        public string BusinessType { get; set; } = string.Empty;
        public int? UnitId { get; set; }
        public string Status { get; set; } = "Active";
        public string ContactNumber { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}
