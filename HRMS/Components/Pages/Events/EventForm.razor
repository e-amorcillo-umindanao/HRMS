@page "/events/add"
@page "/events/new"
@page "/events/edit/{EventId:int}"
@page "/events/{EventId:int}/edit"
@inject EventService EventService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="@(IsEdit ? "Edit Event" : "Add Event")"
            Subtitle="Capture event details and prepare attendance tracking." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Event Details</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Title">
                    <input type="text" class="input input-bordered w-full" @bind="_model.Title" />
                </FieldGroup>
                <FieldGroup Label="Event Date">
                    <input type="date"
                           class="input input-bordered w-full"
                           value="@FormatHtmlDate(_eventDate)"
                           @onchange="OnEventDateChanged" />
                </FieldGroup>
                <FieldGroup Label="Event Time">
                    <input type="time"
                           class="input input-bordered w-full"
                           value="@FormatHtmlTime(_eventTime)"
                           @onchange="OnEventTimeChanged" />
                </FieldGroup>
                <FieldGroup Label="Event Type">
                    <select class="select select-bordered w-full" @bind="_model.EventType">
                        <option value="">Select event type</option>
                        @foreach (var eventType in EventTypes)
                        {
                            <option value="@eventType">@eventType</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Venue">
                    <input type="text" class="input input-bordered w-full" @bind="_model.Venue" />
                </FieldGroup>
                <div class="md:col-span-2">
                    <FieldGroup Label="Description">
                        <textarea class="textarea textarea-bordered h-28 w-full resize-none" @bind="_model.Description"></textarea>
                    </FieldGroup>
                </div>
            </div>
        </div>
        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                Save
            </button>
        </div>
    </div>
}

@code {
    private static readonly string[] EventTypes = ["Assembly", "Livelihood", "Health", "Relief", "Other"];

    [Parameter]
    public int? EventId { get; set; }

    private readonly EventFormModel _model = new();
    private DateTime? _eventDate;
    private TimeSpan? _eventTime;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;

    private bool IsEdit => EventId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        if (IsEdit)
        {
            var evt = await EventService.GetByIdAsync(EventId.GetValueOrDefault());
            if (evt is null)
            {
                _errorMessage = "Event record not found.";
                _isLoading = false;
                return;
            }

            _model.EventId = evt.EventId;
            _model.Title = evt.Title;
            _model.EventType = evt.EventType;
            _model.Venue = evt.Venue ?? string.Empty;
            _model.Description = evt.Description ?? string.Empty;
            var parsed = ParseDate(evt.EventDate);
            _eventDate = parsed?.Date;
            _eventTime = parsed?.TimeOfDay;
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null)
        {
            return;
        }

        _isSaving = true;

        var evt = new Event
        {
            EventId = _model.EventId ?? 0,
            Title = _model.Title.Trim(),
            EventDate = ToIsoDateTimeString(_eventDate!.Value, _eventTime),
            EventType = _model.EventType,
            Venue = NullIfEmpty(_model.Venue),
            Description = NullIfEmpty(_model.Description)
        };

        if (IsEdit)
        {
            var updated = await EventService.UpdateAsync(evt, AuthService.CurrentUser.UserId);
            _isSaving = false;

            if (updated is null)
            {
                _errorMessage = "Unable to update event.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "Event updated successfully.", "success");
            NavigationManager.NavigateTo($"/events/{updated.EventId}");
            return;
        }

        var created = await EventService.AddAsync(evt, AuthService.CurrentUser.UserId);
        _isSaving = false;
        await JS.InvokeVoidAsync("hrms.showToast", "Event added successfully.", "success");
        NavigationManager.NavigateTo($"/events/{created.EventId}");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(IsEdit ? $"/events/{EventId}" : "/events");
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.Title))
        {
            return "Title is required.";
        }

        if (_eventDate is null)
        {
            return "Event Date is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.EventType))
        {
            return "Event Type is required.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.EventId = null;
        _model.Title = string.Empty;
        _model.EventType = string.Empty;
        _model.Venue = string.Empty;
        _model.Description = string.Empty;
        _eventDate = null;
        _eventTime = null;
    }

    private void OnEventDateChanged(ChangeEventArgs args) =>
        _eventDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private void OnEventTimeChanged(ChangeEventArgs args) =>
        _eventTime = TimeSpan.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string ToIsoDateTimeString(DateTime date, TimeSpan? time)
    {
        var combined = date.Date.Add(time ?? TimeSpan.Zero);
        return DateTime.SpecifyKind(combined, DateTimeKind.Utc).ToString("o");
    }

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static string FormatHtmlTime(TimeSpan? value) =>
        value?.ToString(@"hh\:mm") ?? string.Empty;

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class EventFormModel
    {
        public int? EventId { get; set; }
        public string Title { get; set; } = string.Empty;
        public string EventType { get; set; } = string.Empty;
        public string Venue { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}
