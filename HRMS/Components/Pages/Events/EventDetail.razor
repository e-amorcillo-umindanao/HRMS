@page "/events/{Id:int}"
@inject EventService EventService
@inject AttendanceService AttendanceService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject SubdivisionContextService SubdivisionContextService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_event is null)
{
    <PageHeader Title="Event" Subtitle="The requested event could not be loaded." />
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No event available"
                    Subtitle="The requested event record could not be found."
                    Icon="O" />
    </div>
}
else
{
    <PageHeader Title="@_event.Title" Subtitle="Event details and attendance recording.">
        <Actions>
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">Back</button>
            @if (CanWriteEvents)
            {
                <button class="btn btn-primary btn-sm"
                        @onclick='() => NavigationManager.NavigateTo($"/events/edit/{_event.EventId}")'>
                    Edit
                </button>
            }
        </Actions>
    </PageHeader>

    <div class="mb-4 card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-5">
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-5">
                @DetailField("Title", DisplayValue(_event.Title))
                @DetailField("Event Type", DisplayValue(_event.EventType))
                @DetailField("Event Date", FormatDateTime(_event.EventDate))
                @DetailField("Venue", DisplayValue(_event.Venue))
                @DetailField("Description", DisplayValue(_event.Description))
            </div>
        </div>
    </div>

    <div class="card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-0">
            <div class="border-b border-base-300 p-5">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <p class="text-sm font-semibold text-base-content">Attendance</p>
                        <p class="mt-0.5 text-xs text-base-content/40">Record Present, Absent, or Excused for each active homeowner.</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <span class="badge badge-success badge-sm">Present: @PresentCount</span>
                        <span class="badge badge-error badge-sm">Absent: @AbsentCount</span>
                        <span class="badge badge-warning badge-sm">Excused: @ExcusedCount</span>
                    </div>
                </div>
            </div>

            <div class="p-5">
                @if (_rows.Count == 0)
                {
                    <EmptyState Title="No active homeowners"
                                Subtitle="Add active homeowners before recording event attendance."
                                Icon="O" />
                }
                else
                {
                    <div class="overflow-x-auto">
                        <table class="table table-sm">
                            <thead>
                                <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                    <th>Homeowner</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in _rows)
                                {
                                    <tr class="h-[52px] hover">
                                        <td class="text-sm text-base-content">@GetFullName(row.Homeowner)</td>
                                        <td>
                                            @if (CanWriteEvents)
                                            {
                                                <select class="select select-bordered select-sm max-w-[180px]"
                                                        value="@row.Status"
                                                        @onchange='args => OnStatusChanged(row.Homeowner.HomeownerId, args.Value?.ToString() ?? "Absent")'>
                                                    @foreach (var status in AttendanceStatuses)
                                                    {
                                                        <option value="@status">@status</option>
                                                    }
                                                </select>
                                            }
                                            else
                                            {
                                                <span class="badge badge-sm @GetAttendanceBadgeClass(row.Status)">
                                                    @row.Status
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <TableRecordCount From="1" To="@_rows.Count" Total="@_rows.Count" Entity="attendance records" />
                    @if (CanWriteEvents)
                    {
                        <div class="mt-6 flex justify-end">
                            <button class="btn btn-primary btn-sm" @onclick="SaveAttendanceAsync">Save Attendance</button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] AttendanceStatuses = ["Present", "Absent", "Excused"];

    [Parameter]
    public int Id { get; set; }

    private Event? _event;
    private List<AttendanceRow> _rows = [];
    private bool _isLoading = true;
    private bool CanWriteEvents => AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "events");
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin
        ? SubdivisionContextService.SelectedSubdivisionId
        : AuthService.CurrentSubdivisionId;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        _event = await EventService.GetByIdAsync(Id, ActiveSubdivisionId);
        if (_event is null && AuthService.IsSuperAdmin && !ActiveSubdivisionId.HasValue)
        {
            _event = await EventService.GetByIdAsync(Id);
        }

        if (_event is null)
        {
            _rows = [];
            _isLoading = false;
            return;
        }

        var subdivisionId = _event.SubdivisionId;
        var activeHomeowners = await HomeownerService.GetAllActiveAsync(subdivisionId);
        var attendanceRecords = await AttendanceService.GetByEventAsync(Id, subdivisionId);
        var attendanceByHomeowner = attendanceRecords.ToDictionary(record => record.HomeownerId, record => record);

        _rows = activeHomeowners
            .Select(homeowner => new AttendanceRow
            {
                Homeowner = homeowner,
                Status = attendanceByHomeowner.TryGetValue(homeowner.HomeownerId, out var attendance)
                    ? attendance.Status
                    : "Absent"
            })
            .OrderBy(row => row.Homeowner.LastName)
            .ThenBy(row => row.Homeowner.FirstName)
            .ToList();

        _isLoading = false;
    }

    private int PresentCount => _rows.Count(row => row.Status == "Present");
    private int AbsentCount => _rows.Count(row => row.Status == "Absent");
    private int ExcusedCount => _rows.Count(row => row.Status == "Excused");

    private void OnStatusChanged(int homeownerId, string value)
    {
        var row = _rows.FirstOrDefault(record => record.Homeowner.HomeownerId == homeownerId);
        if (row is not null)
        {
            row.Status = value;
        }
    }

    private async Task SaveAttendanceAsync()
    {
        if (AuthService.CurrentUser is null || _event is null)
        {
            return;
        }

        var attendances = _rows
            .Select(row => new Attendance
            {
                EventId = _event.EventId,
                HomeownerId = row.Homeowner.HomeownerId,
                Status = row.Status
            })
            .ToList();

        await AttendanceService.BulkRecordAsync(attendances, AuthService.CurrentUser.UserId);
        await JS.InvokeVoidAsync("hrms.showToast", "Attendance saved successfully.", "success");
        await LoadAsync();
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/events");
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string GetAttendanceBadgeClass(string? status) => status switch
    {
        "Present" => "badge-success",
        "Absent" => "badge-error",
        "Excused" => "badge-warning",
        _ => "badge-ghost"
    };

    private static string FormatDateTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy h:mm tt");
    }

    private static RenderFragment DetailField(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.OpenElement(1, "p");
        builder.AddAttribute(2, "class", "text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40");
        builder.AddContent(3, label);
        builder.CloseElement();
        builder.OpenElement(4, "p");
        builder.AddAttribute(5, "class", "mt-0.5 text-sm text-base-content");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };

    private sealed class AttendanceRow
    {
        public Homeowner Homeowner { get; init; } = null!;
        public string Status { get; set; } = "Absent";
    }
}
