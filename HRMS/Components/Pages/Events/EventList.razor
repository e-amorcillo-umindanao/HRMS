@page "/events"
@inject EventService EventService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Events & Programs"
            Subtitle="Manage activities, programs, and attendance tracking.">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/events/add")'>
            Add Event
        </button>
    </Actions>
</PageHeader>

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="form-control min-w-[200px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Event Type</span>
                </label>
                <select class="select select-bordered select-sm" value="@_eventTypeFilter" @onchange="OnEventTypeChanged">
                    <option value="">All Event Types</option>
                    @foreach (var eventType in EventTypes)
                    {
                        <option value="@eventType">@eventType</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_events.Count == 0)
        {
            <EmptyState Title="No events found"
                        Subtitle="Add an event to begin attendance tracking."
                        Icon="○" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Title</th>
                            <th>Event Type</th>
                            <th>Event Date</th>
                            <th>Venue</th>
                            <th>Attendance</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evt in _events)
                        {
                            <tr class="h-[52px] hover">
                                <td class="text-sm text-base-content">@DisplayValue(evt.Title)</td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(evt.EventType))
                                    {
                                        <span class="text-sm text-base-content/30">-</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-sm @GetEventTypeBadge(evt.EventType)">@evt.EventType</span>
                                    }
                                </td>
                                <td class="text-sm text-base-content/60">@FormatDateTime(evt.EventDate)</td>
                                <td class="text-sm text-base-content/60">@DisplayValue(evt.Venue)</td>
                                <td class="text-sm text-base-content/60">@GetAttendeeCount(evt)</td>
                                <td class="text-right">
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/events/{evt.EventId}")'>
                                        View
                                    </button>
                                    <button class="btn btn-ghost btn-xs"
                                            @onclick='() => NavigationManager.NavigateTo($"/events/edit/{evt.EventId}")'>
                                        Edit
                                    </button>
                                    <button class="btn btn-ghost btn-xs text-error"
                                            @onclick='() => AskDelete(evt)'>
                                        Delete
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_events.Count == 0 ? 0 : 1)"
                                  To="@_events.Count"
                                  Total="@_events.Count"
                                  Entity="events" />
            </div>
        }
    </div>
</div>

<ConfirmDialog IsVisible="@_showConfirm"
               Title="Delete Event"
               Message="@_confirmMessage"
               ConfirmLabel="Delete"
               OnConfirm="DeleteConfirmedAsync"
               OnCancel="CancelDelete" />

@code {
    private static readonly string[] EventTypes = ["Assembly", "Livelihood", "Health", "Relief", "Other"];

    private List<Event> _events = [];
    private string _eventTypeFilter = string.Empty;
    private bool _isLoading = true;
    private bool _showConfirm;
    private int? _pendingDeleteId;
    private string _confirmMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadEventsAsync();
    }

    private async Task LoadEventsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var events = await EventService.GetAllAsync();
        _events = string.IsNullOrWhiteSpace(_eventTypeFilter)
            ? events
            : events.Where(evt => evt.EventType == _eventTypeFilter).ToList();

        _isLoading = false;
    }

    private async Task OnEventTypeChanged(ChangeEventArgs args)
    {
        _eventTypeFilter = args.Value?.ToString() ?? string.Empty;
        await LoadEventsAsync();
    }

    private void AskDelete(Event evt)
    {
        _pendingDeleteId = evt.EventId;
        _confirmMessage = $"Are you sure you want to delete '{evt.Title}'?";
        _showConfirm = true;
    }

    private Task CancelDelete()
    {
        _showConfirm = false;
        _pendingDeleteId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteConfirmedAsync()
    {
        _showConfirm = false;

        if (!_pendingDeleteId.HasValue || AuthService.CurrentUser is null)
        {
            return;
        }

        var deleted = await EventService.DeleteAsync(_pendingDeleteId.Value, AuthService.CurrentUser.UserId);
        _pendingDeleteId = null;

        if (!deleted)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to delete event.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "Event deleted successfully.", "success");
        await LoadEventsAsync();
    }

    private static int GetAttendeeCount(Event evt) =>
        evt.Attendances.Count(attendance => attendance.Status == "Present");

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDateTime(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy h:mm tt");
    }

    private static string GetEventTypeBadge(string? eventType) => eventType switch
    {
        "Assembly" => "badge-info",
        "Livelihood" => "badge-success",
        "Health" => "badge-success",
        "Relief" => "badge-warning",
        _ => "badge-ghost"
    };
}
