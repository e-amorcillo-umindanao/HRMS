@page "/violations/add"
@page "/violations/edit/{ViolationId:int}"
@inject ViolationService ViolationService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageHeader Title="@(IsEdit ? "Edit Violation" : "File Violation")"
            Subtitle="Capture incident details, parties involved, and status updates." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <MudPaper Class="hrms-page-card" Style="padding: 24px;" Elevation="0">
        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Style="margin-bottom: 16px;">
                @_errorMessage
            </MudAlert>
        }

        <div style="font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Parties Involved</div>
        <MudDivider Style="margin: 8px 0 20px;" />
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudAutocomplete T="Homeowner"
                                 Label="Homeowner"
                                 Value="_selectedHomeowner"
                                 ValueChanged="OnHomeownerChanged"
                                 SearchFunc="SearchHomeownersAsync"
                                 ToStringFunc="GetHomeownerDisplay"
                                 Variant="Variant.Outlined"
                                 Clearable="true"
                                 ResetValueOnEmptyText="true"
                                 MaxItems="8"
                                 Dense="true" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField T="string" Label="Homeowner Name" @bind-Value="_model.HomeownerName" Variant="Variant.Outlined" Required="true" />
            </MudItem>
        </MudGrid>

        <div style="margin-top: 28px; font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Incident Information</div>
        <MudDivider Style="margin: 8px 0 20px;" />
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudSelect T="string" Label="Violation Type" @bind-Value="_model.ViolationType" Variant="Variant.Outlined">
                    @foreach (var type in ViolationTypes)
                    {
                        <MudSelectItem T="string" Value="@type">@type</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker Label="Violation Date" DateFormat="MMMM dd, yyyy" @bind-Date="_violationDate" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField T="string" Label="Details" @bind-Value="_model.Details" Variant="Variant.Outlined" Lines="4" />
            </MudItem>
        </MudGrid>

        @if (IsEdit)
        {
            <div style="margin-top: 28px; font-size: 0.75rem; font-weight: 700; color: #64748B; text-transform: uppercase;">Status Update</div>
            <MudDivider Style="margin: 8px 0 20px;" />
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudSelect T="string" @bind-Value="_model.Status" Label="Status" Variant="Variant.Outlined">
                        @foreach (var status in StatusOptions)
                        {
                            <MudSelectItem T="string" Value="@status">@status</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                @if (_model.Status != "Open")
                {
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Resolution" @bind-Value="_model.Resolution" Variant="Variant.Outlined" Lines="4" />
                    </MudItem>
                }
            </MudGrid>
        }

        <div style="margin-top: 24px; padding-top: 20px; border-top: 1px solid #E2E8F0; display: flex; justify-content: flex-end; gap: 12px;">
            <MudButton Variant="Variant.Text" OnClick="Cancel">Cancel</MudButton>
            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveAsync">Save</MudButton>
        </div>
    </MudPaper>
}

@code {
    private static readonly string[] ViolationTypes = ["Noise Complaint", "Unauthorized Construction", "Unpaid Dues", "Pet Violation", "Parking Violation", "Other"];
    private static readonly string[] StatusOptions = ["Open", "Under Review", "Resolved", "Closed"];

    [Parameter]
    public int? ViolationId { get; set; }

    private readonly ViolationFormModel _model = new();
    private List<Homeowner> _homeowners = [];
    private Homeowner? _selectedHomeowner;
    private DateTime? _violationDate;
    private bool _isLoading = true;
    private string? _errorMessage;

    private bool IsEdit => ViolationId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _homeowners = await HomeownerService.GetAllAsync();

        if (IsEdit)
        {
            var violation = await ViolationService.GetByIdAsync(ViolationId.GetValueOrDefault());
            if (violation is null)
            {
                _errorMessage = "Violation record not found.";
                _isLoading = false;
                return;
            }

            _model.ViolationId = violation.ViolationId;
            _model.HomeownerName = violation.HomeownerName;
            _model.ViolationType = violation.ViolationType;
            _model.Details = violation.Details;
            _model.Status = violation.Status;
            _model.Resolution = violation.Resolution ?? string.Empty;
            _violationDate = ParseDate(violation.ViolationDate);
            _selectedHomeowner = _homeowners.FirstOrDefault(homeowner => homeowner.HomeownerId == violation.HomeownerId);
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null)
        {
            return;
        }

        var record = new ViolationRecord
        {
            ViolationId = _model.ViolationId ?? 0,
            HomeownerId = _selectedHomeowner?.HomeownerId,
            HomeownerName = _model.HomeownerName.Trim(),
            ViolationType = _model.ViolationType,
            ViolationDate = ToIsoDateString(_violationDate!.Value),
            Details = _model.Details.Trim(),
            Status = IsEdit ? _model.Status : "Open",
            Resolution = IsEdit && _model.Status != "Open" ? NullIfEmpty(_model.Resolution) : null
        };

        if (IsEdit)
        {
            var updated = await ViolationService.UpdateAsync(record, AuthService.CurrentUser.UserId);
            if (updated is null)
            {
                _errorMessage = "Unable to update violation.";
                return;
            }

            Snackbar.Add("Violation updated successfully.", Severity.Success);
            NavigationManager.NavigateTo($"/violations/{updated.ViolationId}");
        }
        else
        {
            var created = await ViolationService.AddAsync(record, AuthService.CurrentUser.UserId);
            Snackbar.Add("Violation filed successfully.", Severity.Success);
            NavigationManager.NavigateTo($"/violations/{created.ViolationId}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(IsEdit ? $"/violations/{ViolationId}" : "/violations");
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.HomeownerName))
        {
            return "Homeowner Name is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.ViolationType))
        {
            return "Violation Type is required.";
        }

        if (_violationDate is null)
        {
            return "Violation Date is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.Details))
        {
            return "Details are required.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.ViolationId = null;
        _model.HomeownerName = string.Empty;
        _model.ViolationType = string.Empty;
        _model.Details = string.Empty;
        _model.Status = "Open";
        _model.Resolution = string.Empty;
        _selectedHomeowner = null;
        _violationDate = DateTime.UtcNow.Date;
    }

    private Task OnHomeownerChanged(Homeowner? homeowner)
    {
        _selectedHomeowner = homeowner;
        if (homeowner is not null)
        {
            _model.HomeownerName = GetFullName(homeowner);
        }

        return Task.CompletedTask;
    }

    private Task<IEnumerable<Homeowner>> SearchHomeownersAsync(string value, CancellationToken cancellationToken)
    {
        IEnumerable<Homeowner> matches = _homeowners
            .OrderBy(homeowner => homeowner.LastName)
            .ThenBy(homeowner => homeowner.FirstName);

        if (!string.IsNullOrWhiteSpace(value))
        {
            matches = matches.Where(homeowner =>
                GetHomeownerDisplay(homeowner).Contains(value, StringComparison.OrdinalIgnoreCase));
        }

        return Task.FromResult(matches.Take(8));
    }

    private static string GetHomeownerDisplay(Homeowner? homeowner)
    {
        if (homeowner is null)
        {
            return string.Empty;
        }

        return GetFullName(homeowner);
    }

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string ToIsoDateString(DateTime value) =>
        DateTime.SpecifyKind(value.Date, DateTimeKind.Utc).ToString("o");

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class ViolationFormModel
    {
        public int? ViolationId { get; set; }
        public string HomeownerName { get; set; } = string.Empty;
        public string ViolationType { get; set; } = string.Empty;
        public string Details { get; set; } = string.Empty;
        public string Status { get; set; } = "Open";
        public string Resolution { get; set; } = string.Empty;
    }
}
