@page "/violations/add"
@page "/violations/new"
@page "/violations/edit/{ViolationId:int}"
@page "/violations/{ViolationId:int}/edit"
@inject ViolationService ViolationService
@inject HomeownerService HomeownerService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="@(IsEdit ? "Edit Violation" : "File Violation")"
            Subtitle="Capture incident details, parties involved, and status updates." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="card max-w-3xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-base-content/40">Parties Involved</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Homeowner">
                    <select class="select select-bordered w-full" @bind="_selectedHomeownerId" @bind:after="OnHomeownerChanged">
                        <option value="">-</option>
                        @foreach (var homeowner in _homeowners.OrderBy(GetHomeownerDisplay))
                        {
                            <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Homeowner Name">
                    <input type="text" class="input input-bordered w-full" @bind="_model.HomeownerName" />
                </FieldGroup>
            </div>

            <p class="mb-2 mt-8 text-xs font-semibold uppercase tracking-wide text-base-content/40">Incident Information</p>
            <div class="divider my-0 mb-4"></div>
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <FieldGroup Label="Violation Type">
                    <select class="select select-bordered w-full" @bind="_model.ViolationType">
                        <option value="">Select violation type</option>
                        @foreach (var type in ViolationTypes)
                        {
                            <option value="@type">@type</option>
                        }
                    </select>
                </FieldGroup>
                <FieldGroup Label="Violation Date">
                    <input type="date" class="input input-bordered w-full" value="@FormatHtmlDate(_violationDate)" @onchange="OnViolationDateChanged" />
                </FieldGroup>
                <div class="md:col-span-2">
                    <FieldGroup Label="Details">
                        <textarea class="textarea textarea-bordered h-28 w-full resize-none" @bind="_model.Details"></textarea>
                    </FieldGroup>
                </div>
            </div>

            @if (IsEdit)
            {
                <p class="mb-2 mt-8 text-xs font-semibold uppercase tracking-wide text-base-content/40">Status Update</p>
                <div class="divider my-0 mb-4"></div>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    <FieldGroup Label="Status">
                        <select class="select select-bordered w-full" @bind="_model.Status">
                            @foreach (var status in StatusOptions)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </FieldGroup>
                    @if (_model.Status != "Open")
                    {
                        <div class="md:col-span-2">
                            <FieldGroup Label="Resolution">
                                <textarea class="textarea textarea-bordered h-28 w-full resize-none" @bind="_model.Resolution"></textarea>
                            </FieldGroup>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                Save
            </button>
        </div>
    </div>
}

@code {
    private static readonly string[] ViolationTypes = ["Noise Complaint", "Unauthorized Construction", "Unpaid Dues", "Pet Violation", "Parking Violation", "Other"];
    private static readonly string[] StatusOptions = ["Open", "Under Review", "Resolved", "Closed"];

    [Parameter]
    public int? ViolationId { get; set; }

    private readonly ViolationFormModel _model = new();
    private List<Homeowner> _homeowners = [];
    private int? _selectedHomeownerId;
    private DateTime? _violationDate;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _errorMessage;

    private bool IsEdit => ViolationId.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        _homeowners = await HomeownerService.GetAllAsync();

        if (IsEdit)
        {
            var violation = await ViolationService.GetByIdAsync(ViolationId.GetValueOrDefault());
            if (violation is null)
            {
                _errorMessage = "Violation record not found.";
                _isLoading = false;
                return;
            }

            _model.ViolationId = violation.ViolationId;
            _model.HomeownerName = violation.HomeownerName;
            _model.ViolationType = violation.ViolationType;
            _model.Details = violation.Details;
            _model.Status = violation.Status;
            _model.Resolution = violation.Resolution ?? string.Empty;
            _violationDate = ParseDate(violation.ViolationDate);
            _selectedHomeownerId = violation.HomeownerId;
        }
        else
        {
            ResetModel();
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null)
        {
            return;
        }

        _isSaving = true;

        var record = new ViolationRecord
        {
            ViolationId = _model.ViolationId ?? 0,
            HomeownerId = _selectedHomeownerId,
            HomeownerName = _model.HomeownerName.Trim(),
            ViolationType = _model.ViolationType,
            ViolationDate = ToIsoDateString(_violationDate!.Value),
            Details = _model.Details.Trim(),
            Status = IsEdit ? _model.Status : "Open",
            Resolution = IsEdit && _model.Status != "Open" ? NullIfEmpty(_model.Resolution) : null
        };

        if (IsEdit)
        {
            var updated = await ViolationService.UpdateAsync(record, AuthService.CurrentUser.UserId);
            _isSaving = false;

            if (updated is null)
            {
                _errorMessage = "Unable to update violation.";
                return;
            }

            await JS.InvokeVoidAsync("hrms.showToast", "Violation updated successfully.", "success");
            NavigationManager.NavigateTo($"/violations/{updated.ViolationId}");
        }
        else
        {
            var created = await ViolationService.AddAsync(record, AuthService.CurrentUser.UserId);
            _isSaving = false;
            await JS.InvokeVoidAsync("hrms.showToast", "Violation filed successfully.", "success");
            NavigationManager.NavigateTo($"/violations/{created.ViolationId}");
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(IsEdit ? $"/violations/{ViolationId}" : "/violations");
    }

    private string? Validate()
    {
        if (string.IsNullOrWhiteSpace(_model.HomeownerName))
        {
            return "Homeowner Name is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.ViolationType))
        {
            return "Violation Type is required.";
        }

        if (_violationDate is null)
        {
            return "Violation Date is required.";
        }

        if (string.IsNullOrWhiteSpace(_model.Details))
        {
            return "Details are required.";
        }

        return null;
    }

    private void ResetModel()
    {
        _model.ViolationId = null;
        _model.HomeownerName = string.Empty;
        _model.ViolationType = string.Empty;
        _model.Details = string.Empty;
        _model.Status = "Open";
        _model.Resolution = string.Empty;
        _selectedHomeownerId = null;
        _violationDate = DateTime.UtcNow.Date;
    }

    private Task OnHomeownerChanged()
    {
        if (_selectedHomeownerId.HasValue)
        {
            var homeowner = _homeowners.FirstOrDefault(item => item.HomeownerId == _selectedHomeownerId.Value);
            if (homeowner is not null)
            {
                _model.HomeownerName = GetFullName(homeowner);
            }
        }

        return Task.CompletedTask;
    }

    private void OnViolationDateChanged(ChangeEventArgs args) =>
        _violationDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private static string GetHomeownerDisplay(Homeowner homeowner) => GetFullName(homeowner);

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

    private static string ToIsoDateString(DateTime value) =>
        DateTime.SpecifyKind(value.Date, DateTimeKind.Utc).ToString("o");

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class ViolationFormModel
    {
        public int? ViolationId { get; set; }
        public string HomeownerName { get; set; } = string.Empty;
        public string ViolationType { get; set; } = string.Empty;
        public string Details { get; set; } = string.Empty;
        public string Status { get; set; } = "Open";
        public string Resolution { get; set; } = string.Empty;
    }
}
