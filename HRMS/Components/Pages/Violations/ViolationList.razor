@page "/violations"
@inject ViolationService ViolationService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Violations & Incidents"
            Subtitle="Track filed cases, status updates, and violation reports.">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo("/violations/add")'>
            File Violation
        </button>
    </Actions>
</PageHeader>

<div class="card mb-4 border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-4">
        <div class="flex flex-wrap items-end gap-3">
            <div class="form-control min-w-[200px] flex-1">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Homeowner Name</span>
                </label>
                <input type="text"
                       class="input input-bordered input-sm w-full"
                       placeholder="Search name..."
                       value="@_homeownerNameFilter"
                       @oninput="OnNameInput" />
            </div>
            <div class="form-control min-w-[148px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Status</span>
                </label>
                <select class="select select-bordered select-sm" value="@_statusFilter" @onchange="OnStatusChanged">
                    <option value="">All Statuses</option>
                    @foreach (var status in StatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="form-control min-w-[180px]">
                <label class="label py-0 pb-1">
                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Violation Type</span>
                </label>
                <select class="select select-bordered select-sm" value="@_typeFilter" @onchange="OnTypeChanged">
                    <option value="">All Types</option>
                    @foreach (var type in ViolationTypes)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
            </div>
        </div>
    </div>
</div>

<div class="card border border-base-300 bg-base-100 shadow-none">
    <div class="card-body p-0">
        @if (_isLoading)
        {
            <LoadingSpinner />
        }
        else if (_violations.Count == 0)
        {
            <EmptyState Title="No violations found"
                        Subtitle="File a violation or adjust your filters to see results."
                        Icon="O" />
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="table table-sm">
                    <thead>
                        <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                            <th>Violation No.</th>
                            <th>Homeowner</th>
                            <th>Violation Type</th>
                            <th>Date Filed</th>
                            <th>Status</th>
                            <th class="text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var violation in _violations)
                        {
                            <tr class="h-[52px] hover">
                                <td><span class="violation-pill">@DisplayValue(violation.ViolationNumber)</span></td>
                                <td class="text-sm text-base-content">@DisplayValue(violation.HomeownerName)</td>
                                <td><span class="badge badge-sm @GetViolationTypeBadge(violation.ViolationType)">@DisplayValue(violation.ViolationType)</span></td>
                                <td class="text-sm text-base-content/60">@FormatDate(violation.FiledAt)</td>
                                <td><StatusChip Status="@violation.Status" /></td>
                                <td class="text-right">
                                    <button class="btn btn-ghost btn-xs" @onclick='() => NavigationManager.NavigateTo($"/violations/{violation.ViolationId}")'>View</button>
                                    <button class="btn btn-ghost btn-xs" @onclick='() => NavigationManager.NavigateTo($"/violations/edit/{violation.ViolationId}")'>Edit</button>
                                    @if (CanGeneratePdf)
                                    {
                                        <button class="btn btn-ghost btn-xs text-primary" @onclick='() => NavigationManager.NavigateTo($"/violations/{violation.ViolationId}")'>PDF</button>
                                    }
                                    <button class="btn btn-ghost btn-xs text-error" @onclick='() => AskDelete(violation)'>Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="px-4 pb-4">
                <TableRecordCount From="@(_violations.Count == 0 ? 0 : 1)"
                                  To="@_violations.Count"
                                  Total="@_violations.Count"
                                  Entity="violations" />
            </div>
        }
    </div>
</div>

<ConfirmDialog IsVisible="@_showConfirm"
               Title="Delete Violation"
               Message="@_confirmMessage"
               ConfirmLabel="Delete"
               OnConfirm="DeleteConfirmedAsync"
               OnCancel="CancelDelete" />

@code {
    private static readonly string[] StatusOptions = ["Open", "Under Review", "Resolved", "Closed"];
    private static readonly string[] ViolationTypes = ["Noise Complaint", "Unauthorized Construction", "Unpaid Dues", "Pet Violation", "Parking Violation", "Other"];

    private List<ViolationRecord> _violations = [];
    private string _homeownerNameFilter = string.Empty;
    private string _statusFilter = string.Empty;
    private string _typeFilter = string.Empty;
    private bool _isLoading = true;
    private bool _showConfirm;
    private int? _pendingDeleteId;
    private string _confirmMessage = string.Empty;

    private bool CanGeneratePdf => AuthService.IsAtLeast("HOA President");

    protected override async Task OnInitializedAsync()
    {
        await LoadViolationsAsync();
    }

    private async Task LoadViolationsAsync()
    {
        _isLoading = true;
        StateHasChanged();

        _violations = await ViolationService.SearchAsync(
            NullIfEmpty(_homeownerNameFilter),
            NullIfEmpty(_statusFilter),
            NullIfEmpty(_typeFilter));

        _isLoading = false;
    }

    private async Task OnNameInput(ChangeEventArgs args)
    {
        _homeownerNameFilter = args.Value?.ToString() ?? string.Empty;
        await LoadViolationsAsync();
    }

    private async Task OnStatusChanged(ChangeEventArgs args)
    {
        _statusFilter = args.Value?.ToString() ?? string.Empty;
        await LoadViolationsAsync();
    }

    private async Task OnTypeChanged(ChangeEventArgs args)
    {
        _typeFilter = args.Value?.ToString() ?? string.Empty;
        await LoadViolationsAsync();
    }

    private void AskDelete(ViolationRecord violation)
    {
        _pendingDeleteId = violation.ViolationId;
        _confirmMessage = $"Are you sure you want to delete {violation.ViolationNumber}?";
        _showConfirm = true;
    }

    private Task CancelDelete()
    {
        _showConfirm = false;
        _pendingDeleteId = null;
        return Task.CompletedTask;
    }

    private async Task DeleteConfirmedAsync()
    {
        _showConfirm = false;

        if (!_pendingDeleteId.HasValue || AuthService.CurrentUser is null)
        {
            return;
        }

        var deleted = await ViolationService.DeleteAsync(_pendingDeleteId.Value, AuthService.CurrentUser.UserId);
        _pendingDeleteId = null;

        if (!deleted)
        {
            await JS.InvokeVoidAsync("hrms.showToast", "Unable to delete violation.", "error");
            return;
        }

        await JS.InvokeVoidAsync("hrms.showToast", "Violation deleted successfully.", "success");
        await LoadViolationsAsync();
    }

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value;

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static string GetViolationTypeBadge(string? violationType) => violationType switch
    {
        "Noise Complaint" => "badge-warning",
        "Unauthorized Construction" => "badge-error",
        "Unpaid Dues" => "badge-error",
        "Pet Violation" => "badge-success",
        "Parking Violation" => "badge-info",
        _ => "badge-ghost"
    };
}
