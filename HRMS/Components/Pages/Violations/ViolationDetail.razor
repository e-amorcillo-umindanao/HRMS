@page "/violations/{Id:int}"
@inject ViolationService ViolationService
@inject DocumentService DocumentService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (_violation is null)
{
    <PageHeader Title="Violation" Subtitle="The requested violation record could not be loaded." />
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No violation available"
                    Subtitle="The requested violation record could not be found."
                    Icon="O" />
    </div>
}
else
{
    <PageHeader Title="@_violation.ViolationNumber" Subtitle="Violation record.">
        <Actions>
            <button class="btn btn-ghost btn-sm" @onclick="GoBack">Back</button>
            @if (CanGenerateViolationPdf)
            {
                <button class="btn btn-outline btn-sm" @onclick="GeneratePdfAsync">Generate PDF Report</button>
            }
            <button class="btn btn-primary btn-sm" @onclick='() => NavigationManager.NavigateTo($"/violations/edit/{_violation.ViolationId}")'>Edit</button>
        </Actions>
    </PageHeader>

    <div class="card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-5">
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
                @DetailField("Violation Number", DisplayValue(_violation.ViolationNumber))
                @DetailField("Homeowner", DisplayValue(_violation.HomeownerName))
                @DetailField("Status", DisplayValue(_violation.Status))
                @DetailField("Type", DisplayValue(_violation.ViolationType))
                @DetailField("Violation Date", FormatDate(_violation.ViolationDate))
                @DetailField("Filed By", DisplayValue(_violation.FiledByUser?.Username))
                @DetailField("Details", DisplayValue(_violation.Details))
                @DetailField("Resolution", DisplayValue(_violation.Resolution))
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private ViolationRecord? _violation;
    private bool _isLoading = true;
    private bool CanGenerateViolationPdf => AuthService.IsAtLeast("HOA President");

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _violation = await ViolationService.GetByIdAsync(Id);
        _isLoading = false;
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/violations");
    }

    private async Task GeneratePdfAsync()
    {
        if (AuthService.CurrentRole is null)
        {
            return;
        }

        try
        {
            var document = await DocumentService.GenerateViolationReportAsync(Id, AuthService.CurrentRole);
            if (document is null)
            {
                await JS.InvokeVoidAsync("hrms.showToast", "Unable to generate violation report.", "error");
                return;
            }

            var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, document.FileName);
            await File.WriteAllBytesAsync(filePath, document.Bytes);

            await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
                new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                    document.FileName,
                    new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
        }
        catch (UnauthorizedAccessException exception)
        {
            await JS.InvokeVoidAsync("hrms.showToast", exception.Message, "error");
        }
    }

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static RenderFragment DetailField(string label, string value) => builder =>
    {
        builder.OpenElement(0, "div");
        builder.OpenElement(1, "p");
        builder.AddAttribute(2, "class", "text-[10.5px] font-semibold uppercase tracking-wide text-base-content/40");
        builder.AddContent(3, label);
        builder.CloseElement();
        builder.OpenElement(4, "p");
        builder.AddAttribute(5, "class", "mt-0.5 text-sm text-base-content");
        builder.AddContent(6, value);
        builder.CloseElement();
        builder.CloseElement();
    };
}
