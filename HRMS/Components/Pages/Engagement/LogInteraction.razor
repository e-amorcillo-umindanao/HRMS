@page "/engagement/log"
@page "/engagement/log/{HomeownerId:int}"
@page "/engagement/log/msme/{MsmeId:int}"
@inject AppDbContext DbContext
@inject InteractionService InteractionService
@inject EngagementService EngagementService
@inject AuthService AuthService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageHeader Title="Log Interaction"
            Subtitle="Record homeowner or MSME touchpoints for engagement tracking." />

@if (_isLoading)
{
    <LoadingSpinner />
}
else if (!HasValidContext)
{
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <EmptyState Title="No interaction subject selected"
                    Subtitle="@(_contextMessage ?? "Choose a homeowner or MSME before logging an interaction.")"
                    Icon="○" />
    </div>
}
else
{
    <div class="card mb-4 max-w-xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body flex-row items-center gap-4 p-4">
            <div class="avatar placeholder">
                <div class="w-10 rounded-full bg-primary text-primary-content">
                    <span class="text-sm font-semibold">@GetInitials()</span>
                </div>
            </div>
            <div>
                <p class="text-sm font-semibold text-base-content">@_subjectName</p>
                <p class="text-xs text-base-content/40">@GetSubjectType()</p>
                @if (_engagementSummary is not null)
                {
                    <div class="mt-2">
                        <EngagementBadge Score="@_engagementSummary.Score" />
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(_msmeStatus))
                {
                    <div class="mt-2">
                        <span class="badge badge-sm @GetMsmeStatusBadge(_msmeStatus)">@_msmeStatus</span>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card max-w-xl border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div role="alert" class="alert alert-error mb-4">
                    <span>@_errorMessage</span>
                </div>
            }

            <div class="grid gap-4">
                <FieldGroup Label="Interaction Type">
                    <select class="select select-bordered w-full" @bind="_model.InteractionType">
                        <option>Visit</option>
                        <option>Call</option>
                        <option>Follow-up</option>
                        <option>Message</option>
                        <option>Meeting</option>
                    </select>
                </FieldGroup>
                <FieldGroup Label="Interaction Date">
                    <input type="date"
                           class="input input-bordered w-full"
                           value="@FormatHtmlDate(_interactionDate)"
                           @onchange="OnInteractionDateChanged" />
                </FieldGroup>
                <FieldGroup Label="Notes">
                    <textarea class="textarea textarea-bordered h-28 w-full resize-none"
                              @bind="_model.Notes"
                              placeholder="Summary of the interaction..."></textarea>
                </FieldGroup>
            </div>
        </div>
        <div class="flex justify-end gap-3 border-t border-base-300 px-6 py-4">
            <button class="btn btn-ghost btn-sm" @onclick="Cancel">Cancel</button>
            <button class="btn btn-primary btn-sm" @onclick="SaveAsync" disabled="@_isSaving">
                @if (_isSaving)
                {
                    <span class="loading loading-spinner loading-xs"></span>
                }
                Log Interaction
            </button>
        </div>
    </div>
}

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "homeownerId")]
    public int? HomeownerId { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "msmeId")]
    public int? MsmeId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly LogInteractionModel _model = new();
    private EngagementSummary? _engagementSummary;
    private string? _subjectName;
    private string? _contextMessage;
    private string? _msmeStatus;
    private string? _errorMessage;
    private DateTime? _interactionDate = DateTime.UtcNow.Date;
    private bool _isLoading = true;
    private bool _isSaving;

    private bool HasValidContext => !string.IsNullOrWhiteSpace(_subjectName);

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _subjectName = null;
        _contextMessage = null;
        _msmeStatus = null;
        _engagementSummary = null;
        _errorMessage = null;
        _model.InteractionType = string.IsNullOrWhiteSpace(_model.InteractionType) ? "Visit" : _model.InteractionType;

        if (!AuthService.IsAtLeast("Board Member"))
        {
            NavigationManager.NavigateTo("/dashboard");
            return;
        }

        if (HomeownerId.HasValue == MsmeId.HasValue)
        {
            _contextMessage = "Exactly one homeowner or MSME must be selected.";
            _isLoading = false;
            return;
        }

        if (HomeownerId.HasValue)
        {
            var homeowner = await DbContext.Homeowners
                .AsNoTracking()
                .SingleOrDefaultAsync(record => record.HomeownerId == HomeownerId.Value && !record.IsDeleted);

            if (homeowner is null)
            {
                _contextMessage = "The selected homeowner could not be found.";
                _isLoading = false;
                return;
            }

            _subjectName = GetFullName(homeowner);
            _engagementSummary = await EngagementService.GetEngagementSummaryAsync(homeowner.HomeownerId);
        }
        else if (MsmeId.HasValue)
        {
            var msme = await DbContext.MSMEs
                .AsNoTracking()
                .SingleOrDefaultAsync(record => record.MSMEId == MsmeId.Value);

            if (msme is null)
            {
                _contextMessage = "The selected MSME could not be found.";
                _isLoading = false;
                return;
            }

            _subjectName = msme.BusinessName;
            _msmeStatus = msme.Status;
        }

        _isLoading = false;
    }

    private async Task SaveAsync()
    {
        _errorMessage = Validate();
        if (!string.IsNullOrWhiteSpace(_errorMessage) || AuthService.CurrentUser is null)
        {
            return;
        }

        _isSaving = true;

        try
        {
            await InteractionService.AddAsync(new InteractionLog
            {
                HomeownerId = HomeownerId,
                MSMEId = MsmeId,
                InteractionType = _model.InteractionType,
                Notes = _model.Notes,
                InteractionDate = ToIsoDateString(_interactionDate!.Value)
            }, AuthService.CurrentUser.UserId);

            _isSaving = false;
            await JS.InvokeVoidAsync("hrms.showToast", "Interaction logged successfully.", "success");
            NavigationManager.NavigateTo(GetReturnUrl());
        }
        catch (ArgumentException exception)
        {
            _isSaving = false;
            _errorMessage = exception.Message;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo(GetReturnUrl());
    }

    private void OnInteractionDateChanged(ChangeEventArgs args) =>
        _interactionDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private string? Validate()
    {
        if (!HasValidContext)
        {
            return "Select a valid homeowner or MSME first.";
        }

        if (string.IsNullOrWhiteSpace(_model.InteractionType))
        {
            return "Interaction Type is required.";
        }

        if (_interactionDate is null)
        {
            return "Interaction Date is required.";
        }

        return null;
    }

    private string GetReturnUrl() =>
        string.IsNullOrWhiteSpace(ReturnUrl) ? "/engagement" : ReturnUrl;

    private string GetInitials()
    {
        if (string.IsNullOrWhiteSpace(_subjectName))
        {
            return "--";
        }

        var parts = _subjectName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        if (parts.Length == 1)
        {
            return parts[0][..1].ToUpperInvariant();
        }

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private string GetSubjectType() => HomeownerId.HasValue ? "Homeowner" : "MSME";

    private static string GetMsmeStatusBadge(string? status) => status switch
    {
        "Active" => "badge-success",
        "Suspended" => "badge-warning",
        "Expired" => "badge-error",
        "Closed" => "badge-ghost",
        _ => "badge-ghost"
    };

    private static string GetFullName(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string ToIsoDateString(DateTime value) =>
        DateTime.SpecifyKind(value.Date, DateTimeKind.Utc).ToString("o");

    private static string FormatHtmlDate(DateTime? value) =>
        value?.ToString("yyyy-MM-dd") ?? string.Empty;

    private sealed class LogInteractionModel
    {
        public string InteractionType { get; set; } = "Visit";
        public string Notes { get; set; } = string.Empty;
    }
}
