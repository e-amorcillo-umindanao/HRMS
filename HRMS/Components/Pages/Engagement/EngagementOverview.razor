@page "/engagement"
@inject EngagementService EngagementService
@inject AuthService AuthService
@inject SubdivisionContextService SubdivisionContextService
@inject NavigationManager NavigationManager

<PageHeader Title="Engagement"
            Subtitle="Homeowner engagement scores, interaction history, and event attendance." />

<SubdivisionSelector OnSubdivisionSelected="HandleSubdivisionChange" />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-3">
        <KpiCard Label="Total High" Value="@HighCount.ToString()" Sub="Score 75-100" Accent="success" />
        <KpiCard Label="Total Medium" Value="@MediumCount.ToString()" Sub="Score 40-74" Accent="warning" />
        <KpiCard Label="Total Low" Value="@LowCount.ToString()" Sub="Score 0-39" Accent="error" />
    </div>

    <div class="card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-0">
            @if (_summaries.Count == 0)
            {
                <EmptyState Title="No engagement records yet"
                            Subtitle="Add homeowners and interactions to start tracking engagement."
                            Icon="○" />
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="table table-sm">
                        <thead>
                            <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                <th>Homeowner Name</th>
                                <th>Engagement Score</th>
                                <th>Badge</th>
                                <th>Last Interaction Date</th>
                                <th>Events Attended</th>
                                <th class="text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var summary in _summaries)
                            {
                                <tr class="h-[52px] hover">
                                    <td class="text-sm text-base-content">@summary.HomeownerName</td>
                                    <td><EngagementBadge Score="@summary.Score" /></td>
                                    <td>
                                        <StatusChip Status="@summary.Label" />
                                    </td>
                                    <td class="text-sm text-base-content/60">@FormatDate(summary.LastInteractionDate)</td>
                                    <td class="text-sm text-base-content/60">@($"{summary.EventsAttended} / {summary.TotalEvents}")</td>
                                    <td class="text-right">
                                        <button class="btn btn-ghost btn-xs"
                                                @onclick='() => NavigationManager.NavigateTo($"/homeowners/{summary.HomeownerId}")'>
                                            View Homeowner
                                        </button>
                                        @if (AccessHelper.CanWrite(AuthService.CurrentRole ?? string.Empty, "engagement"))
                                        {
                                            <button class="btn btn-outline btn-xs"
                                                    @onclick='() => NavigationManager.NavigateTo($"/engagement/log?homeownerId={summary.HomeownerId}&returnUrl=%2Fengagement")'>
                                                Log Interaction
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="px-4 pb-4">
                    <TableRecordCount From="@(_summaries.Count == 0 ? 0 : 1)"
                                      To="@_summaries.Count"
                                      Total="@_summaries.Count"
                                      Entity="engagement records" />
                </div>
            }
        </div>
    </div>
}

@code {
    private List<EngagementSummary> _summaries = [];
    private bool _isLoading = true;
    private int? ActiveSubdivisionId => AuthService.IsSuperAdmin
        ? SubdivisionContextService.SelectedSubdivisionId
        : AuthService.CurrentSubdivisionId;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _summaries = ActiveSubdivisionId.HasValue
            ? await EngagementService.GetAllEngagementSummariesAsync(ActiveSubdivisionId.Value)
            : [];
        _isLoading = false;
    }

    private async Task HandleSubdivisionChange(int? subdivisionId)
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private int HighCount => _summaries.Count(summary => summary.Label == "High Engagement");
    private int MediumCount => _summaries.Count(summary => summary.Label == "Medium Engagement");
    private int LowCount => _summaries.Count(summary => summary.Label == "Low Engagement");

    private static string FormatDate(DateTime? value) =>
        value.HasValue ? value.Value.ToString("MMMM dd, yyyy") : "-";
}
