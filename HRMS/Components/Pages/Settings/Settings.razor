@page "/settings"
@inject AppDbContext DbContext
@inject AuthService AuthService
@inject AuditService AuditService
@inject ISnackbar Snackbar

<PageHeader Title="Settings" />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <MudTabs Rounded="true">
        <MudTabPanel Text="HOA Configuration">
            <MudPaper Class="hrms-page-card" Style="padding: 24px;" Elevation="0">
                <MudText Class="hrms-section-heading">General Information</MudText>
                <MudDivider Style="margin: 8px 0 20px;" />
                <MudGrid Style="margin-bottom: 24px;">
                    <MudItem xs="12" sm="6">
                        <FieldGroup Label="HOA Name">
                            <MudTextField T="string" @bind-Value="_hoaSettings.HOAName" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <FieldGroup Label="Subdivision Name">
                            <MudTextField T="string" @bind-Value="_hoaSettings.Subdivision" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                </MudGrid>

                <MudText Class="hrms-section-heading">Location & Contact</MudText>
                <MudDivider Style="margin: 8px 0 20px;" />
                <MudGrid Style="margin-bottom: 24px;">
                    <MudItem xs="12" sm="4">
                        <FieldGroup Label="City">
                            <MudTextField T="string" @bind-Value="_hoaSettings.City" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FieldGroup Label="Province">
                            <MudTextField T="string" @bind-Value="_hoaSettings.Province" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FieldGroup Label="Contact Number">
                            <MudTextField T="string" @bind-Value="_hoaSettings.ContactNumber" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                </MudGrid>

                <MudText Class="hrms-section-heading">Board Leadership</MudText>
                <MudDivider Style="margin: 8px 0 20px;" />
                <MudGrid Style="margin-bottom: 24px;">
                    <MudItem xs="12" sm="4">
                        <FieldGroup Label="President Name">
                            <MudTextField T="string" @bind-Value="_hoaSettings.PresidentName" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FieldGroup Label="Secretary Name">
                            <MudTextField T="string" @bind-Value="_hoaSettings.SecretaryName" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <FieldGroup Label="Treasurer Name">
                            <MudTextField T="string" @bind-Value="_hoaSettings.TreasurerName" Variant="Variant.Outlined" />
                        </FieldGroup>
                    </MudItem>
                </MudGrid>

                <MudText Class="hrms-section-heading">Digital Assets</MudText>
                <MudDivider Style="margin: 8px 0 20px;" />
                <FieldGroup Label="Logo">
                    <div class="logo-upload-area">
                        @if (!string.IsNullOrWhiteSpace(_logoPreviewUrl))
                        {
                            <div class="logo-preview-row">
                                    <img src="@_logoPreviewUrl" class="logo-preview-thumb" alt="HOA logo preview" />
                                <div class="logo-file-info">
                                    <span class="logo-filename">@System.IO.Path.GetFileName(_hoaSettings.LogoPath)</span>
                                    <span class="logo-hint">PNG or SVG, Max 2MB</span>
                                </div>
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PickLogoFileAsync">
                                    Replace
                                </MudButton>
                            </div>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Outlined" OnClick="PickLogoFileAsync">
                                Upload Logo
                            </MudButton>
                        }
                    </div>
                </FieldGroup>

                <div class="settings-action-row">
                    <MudButton Variant="Variant.Text" OnClick="DiscardHoaSettingsChangesAsync">
                        Discard Changes
                    </MudButton>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveHoaSettingsAsync">
                        Save Settings
                    </MudButton>
                </div>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="User Management">
            <MudPaper Class="hrms-page-card" Style="padding: 24px; margin-bottom: 24px;" Elevation="0">
                <div style="display: flex; justify-content: space-between; gap: 12px; align-items: center; flex-wrap: wrap;">
                    <MudText Style="color: #1E293B; font-size: 1rem; font-weight: 700;">Users</MudText>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="ToggleAddUserForm">
                        @(_showAddUserForm ? "Close Form" : "Add User")
                    </MudButton>
                </div>

                @if (_showAddUserForm)
                {
                    <MudDivider Style="margin: 16px 0;" />
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <FieldGroup Label="Username">
                                <MudTextField T="string" @bind-Value="_userForm.Username" Variant="Variant.Outlined" />
                            </FieldGroup>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <FieldGroup Label="Password">
                                <MudTextField T="string" @bind-Value="_userForm.Password" Variant="Variant.Outlined" InputType="InputType.Password" />
                            </FieldGroup>
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <FieldGroup Label="Role">
                                <MudSelect T="int" @bind-Value="_userForm.RoleId" Variant="Variant.Outlined">
                                    <MudSelectItem T="int" Value="0">Select Role</MudSelectItem>
                                    @foreach (var role in _roles)
                                    {
                                        <MudSelectItem T="int" Value="@role.RoleId">@role.RoleName</MudSelectItem>
                                    }
                                </MudSelect>
                            </FieldGroup>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <FieldGroup Label="Homeowner Link">
                                <MudSelect T="int?" @bind-Value="_userForm.HomeownerId" Variant="Variant.Outlined">
                                    <MudSelectItem T="int?" Value="@((int?)null)">No linked homeowner</MudSelectItem>
                                    @foreach (var homeowner in _availableHomeowners)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)homeowner.HomeownerId)">@GetHomeownerDisplay(homeowner)</MudSelectItem>
                                    }
                                </MudSelect>
                            </FieldGroup>
                        </MudItem>
                    </MudGrid>

                    <div style="margin-top: 16px; display: flex; justify-content: flex-end; gap: 12px;">
                        <MudButton Variant="Variant.Text" OnClick="ToggleAddUserForm">Cancel</MudButton>
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="AddUserAsync">Create User</MudButton>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="hrms-page-card" Elevation="0">
                <MudTable T="User" Items="_users" Hover="false" Striped="false">
                    <HeaderContent>
                        <MudTh>Username</MudTh>
                        <MudTh>Role</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Last Login</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Username">@context.Username</MudTd>
                        <MudTd DataLabel="Role">@DisplayValue(context.Role?.RoleName)</MudTd>
                        <MudTd DataLabel="Status"><StatusChip Label="@(context.IsActive ? "Active" : "Inactive")" /></MudTd>
                        <MudTd DataLabel="Last Login">@FormatDate(context.LastLoginAt)</MudTd>
                        <MudTd DataLabel="Actions">
                            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                                @if (context.IsActive)
                                {
                                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeactivateUserAsync(context.UserId))">
                                        Deactivate
                                    </MudButton>
                                }
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => BeginPasswordReset(context))">
                                    Reset Password
                                </MudButton>
                            </div>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>

            @if (_resetPasswordUser is not null)
            {
                <MudPaper Class="hrms-page-card" Style="padding: 24px; margin-top: 24px;" Elevation="0">
                    <MudText Style="color: #1E293B; font-size: 1rem; font-weight: 700;">
                        Reset Password for @_resetPasswordUser.Username
                    </MudText>
                    <MudGrid Style="margin-top: 8px;">
                        <MudItem xs="12" sm="6">
                            <FieldGroup Label="New Password">
                                <MudTextField T="string" @bind-Value="_resetPasswordValue" Variant="Variant.Outlined" InputType="InputType.Password" />
                            </FieldGroup>
                        </MudItem>
                    </MudGrid>

                    <div style="margin-top: 16px; display: flex; justify-content: flex-end; gap: 12px;">
                        <MudButton Variant="Variant.Text" OnClick="CancelPasswordReset">Cancel</MudButton>
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SavePasswordResetAsync">
                            Save Password
                        </MudButton>
                    </div>
                </MudPaper>
            }
        </MudTabPanel>

        <MudTabPanel Text="Phase Management">
            <MudPaper Class="hrms-page-card" Style="padding: 24px; margin-bottom: 24px;" Elevation="0">
                <div style="display: flex; justify-content: space-between; gap: 12px; align-items: center; flex-wrap: wrap;">
                    <MudText Style="color: #1E293B; font-size: 1rem; font-weight: 700;">Phases</MudText>
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="BeginAddPhase">
                        @(_editingPhaseId.HasValue ? "Cancel Edit" : "Add Phase")
                    </MudButton>
                </div>

                @if (_showPhaseForm)
                {
                    <MudDivider Style="margin: 16px 0;" />
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <FieldGroup Label="Phase Name">
                                <MudTextField T="string" @bind-Value="_phaseForm.Name" Variant="Variant.Outlined" />
                            </FieldGroup>
                        </MudItem>
                        <MudItem xs="12" sm="8">
                            <FieldGroup Label="Description">
                                <MudTextField T="string" @bind-Value="_phaseForm.Description" Variant="Variant.Outlined" />
                            </FieldGroup>
                        </MudItem>
                    </MudGrid>

                    <div style="margin-top: 16px; display: flex; justify-content: flex-end; gap: 12px;">
                        <MudButton Variant="Variant.Text" OnClick="CancelPhaseForm">Cancel</MudButton>
                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SavePhaseAsync">
                            Save Phase
                        </MudButton>
                    </div>
                }
            </MudPaper>

            <MudPaper Class="hrms-page-card" Elevation="0">
                <MudTable T="PhaseSummaryRow" Items="_phases" Hover="false" Striped="false">
                    <HeaderContent>
                        <MudTh>Phase Name</MudTh>
                        <MudTh>Description</MudTh>
                        <MudTh>Homeowner Count</MudTh>
                        <MudTh>Unit Count</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Phase Name">@context.Name</MudTd>
                        <MudTd DataLabel="Description">@DisplayValue(context.Description)</MudTd>
                        <MudTd DataLabel="Homeowner Count">@context.HomeownerCount</MudTd>
                        <MudTd DataLabel="Unit Count">@context.UnitCount</MudTd>
                        <MudTd DataLabel="Actions">
                            <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => BeginEditPhase(context))">
                                    Edit
                                </MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error" OnClick="@(() => DeletePhaseAsync(context.PhaseId))">
                                    Delete
                                </MudButton>
                            </div>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudTabPanel>

        <MudTabPanel Text="Audit Log">
            <MudPaper Class="hrms-page-card" Style="padding: 24px; margin-bottom: 24px;" Elevation="0">
                <div style="display: flex; flex-wrap: wrap; gap: 16px; align-items: flex-end;">
                    <FieldGroup Label="Username" Style="min-width: 220px;">
                        <MudTextField T="string"
                                      @bind-Value="_auditUsernameFilter"
                                      Variant="Variant.Outlined"
                                      Immediate="true" />
                    </FieldGroup>

                    <FieldGroup Label="Action" Style="min-width: 180px;">
                        <MudSelect T="string"
                                   @bind-Value="_auditActionFilter"
                                   Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@string.Empty">All Actions</MudSelectItem>
                            @foreach (var action in AuditActionOptions)
                            {
                                <MudSelectItem T="string" Value="@action">@action</MudSelectItem>
                            }
                        </MudSelect>
                    </FieldGroup>

                    <FieldGroup Label="Table" Style="min-width: 220px;">
                        <MudSelect T="string"
                                   @bind-Value="_auditTableFilter"
                                   Variant="Variant.Outlined">
                            <MudSelectItem T="string" Value="@string.Empty">All Tables</MudSelectItem>
                            @foreach (var table in AuditTableOptions)
                            {
                                <MudSelectItem T="string" Value="@table">@table</MudSelectItem>
                            }
                        </MudSelect>
                    </FieldGroup>

                    <FieldGroup Label="From">
                        <MudDatePicker DateFormat="MMMM dd, yyyy"
                                       @bind-Date="_auditFromDate"
                                       Variant="Variant.Outlined" />
                    </FieldGroup>

                    <FieldGroup Label="To">
                        <MudDatePicker DateFormat="MMMM dd, yyyy"
                                       @bind-Date="_auditToDate"
                                       Variant="Variant.Outlined" />
                    </FieldGroup>
                </div>
            </MudPaper>

            <MudPaper Class="hrms-page-card" Elevation="0">
                <MudTable T="AuditLog" Items="FilteredAuditLogs" Hover="false" Striped="false">
                    <HeaderContent>
                        <MudTh>Timestamp</MudTh>
                        <MudTh>Username</MudTh>
                        <MudTh>Action</MudTh>
                        <MudTh>Table Affected</MudTh>
                        <MudTh>Record ID</MudTh>
                        <MudTh>Details</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Timestamp">@FormatDate(context.Timestamp)</MudTd>
                        <MudTd DataLabel="Username">@DisplayValue(context.User?.Username)</MudTd>
                        <MudTd DataLabel="Action">@DisplayValue(context.Action)</MudTd>
                        <MudTd DataLabel="Table Affected">@DisplayValue(context.TableAffected)</MudTd>
                        <MudTd DataLabel="Record ID">@DisplayValue(context.RecordId?.ToString())</MudTd>
                        <MudTd DataLabel="Details">@DisplayValue(context.Details)</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudTabPanel>
    </MudTabs>
}

@code {
    private static readonly string[] AuditActionOptions = ["Login", "Create", "Update", "Delete"];
    private static readonly string[] AuditTableOptions =
    [
        "Users",
        "Homeowners",
        "Units",
        "Events",
        "Attendances",
        "InteractionLogs",
        "MSMEs",
        "DuesRecords",
        "ViolationRecords",
        "ClearanceRequests",
        "AuditLogs",
        "HOASettings",
        "Phases"
    ];

    private HOASettings _hoaSettings = new() { SettingId = 1 };
    private List<User> _users = [];
    private List<Role> _roles = [];
    private List<Homeowner> _availableHomeowners = [];
    private List<PhaseSummaryRow> _phases = [];
    private List<AuditLog> _auditLogs = [];
    private UserFormModel _userForm = new();
    private PhaseFormModel _phaseForm = new();
    private User? _resetPasswordUser;
    private string _resetPasswordValue = string.Empty;
    private string? _logoPreviewUrl;
    private bool _isLoading = true;
    private bool _showAddUserForm;
    private bool _showPhaseForm;
    private int? _editingPhaseId;
    private string _auditUsernameFilter = string.Empty;
    private string _auditActionFilter = string.Empty;
    private string _auditTableFilter = string.Empty;
    private DateTime? _auditFromDate;
    private DateTime? _auditToDate;

    private IEnumerable<AuditLog> FilteredAuditLogs => _auditLogs
        .Where(log => string.IsNullOrWhiteSpace(_auditUsernameFilter) ||
                      (log.User?.Username?.Contains(_auditUsernameFilter, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(log => string.IsNullOrWhiteSpace(_auditActionFilter) || log.Action == _auditActionFilter)
        .Where(log => string.IsNullOrWhiteSpace(_auditTableFilter) || log.TableAffected == _auditTableFilter)
        .Where(log =>
        {
            var timestamp = ParseDate(log.Timestamp);
            return !_auditFromDate.HasValue || (timestamp.HasValue && timestamp.Value.Date >= _auditFromDate.Value.Date);
        })
        .Where(log =>
        {
            var timestamp = ParseDate(log.Timestamp);
            return !_auditToDate.HasValue || (timestamp.HasValue && timestamp.Value.Date <= _auditToDate.Value.Date);
        })
        .OrderByDescending(log => ParseDate(log.Timestamp));

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;

        _hoaSettings = await LoadHoaSettingsAsync();
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);

        _users = await DbContext.Users
            .AsNoTracking()
            .Include(user => user.Role)
            .Include(user => user.Homeowner)
            .OrderBy(user => user.Username)
            .ToListAsync();

        _roles = await DbContext.Roles
            .AsNoTracking()
            .OrderBy(role => role.RoleName)
            .ToListAsync();

        _availableHomeowners = await GetAvailableHomeownersAsync();

        _phases = await DbContext.Phases
            .AsNoTracking()
            .Include(phase => phase.Homeowners)
            .Include(phase => phase.Units)
            .OrderBy(phase => phase.Name)
            .Select(phase => new PhaseSummaryRow
            {
                PhaseId = phase.PhaseId,
                Name = phase.Name,
                Description = phase.Description,
                HomeownerCount = phase.Homeowners.Count(homeowner => !homeowner.IsDeleted),
                UnitCount = phase.Units.Count
            })
            .ToListAsync();

        _auditLogs = await DbContext.AuditLogs
            .AsNoTracking()
            .Include(log => log.User)
            .OrderByDescending(log => log.Timestamp)
            .ToListAsync();

        _isLoading = false;
    }

    private async Task SaveHoaSettingsAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_hoaSettings.HOAName) ||
            string.IsNullOrWhiteSpace(_hoaSettings.Subdivision) ||
            string.IsNullOrWhiteSpace(_hoaSettings.City) ||
            string.IsNullOrWhiteSpace(_hoaSettings.Province))
        {
            Snackbar.Add("HOA name and address fields are required.", Severity.Warning);
            return;
        }

        var settings = await DbContext.HOASettings.FirstOrDefaultAsync();
        if (settings is null)
        {
            settings = new HOASettings { SettingId = 1 };
            DbContext.HOASettings.Add(settings);
        }

        settings.HOAName = _hoaSettings.HOAName;
        settings.Subdivision = _hoaSettings.Subdivision;
        settings.City = _hoaSettings.City;
        settings.Province = _hoaSettings.Province;
        settings.PresidentName = NullIfEmpty(_hoaSettings.PresidentName);
        settings.SecretaryName = NullIfEmpty(_hoaSettings.SecretaryName);
        settings.TreasurerName = NullIfEmpty(_hoaSettings.TreasurerName);
        settings.ContactNumber = NullIfEmpty(_hoaSettings.ContactNumber);
        settings.LogoPath = NullIfEmpty(_hoaSettings.LogoPath);
        settings.UpdatedAt = DateTime.UtcNow.ToString("o");
        settings.UpdatedBy = AuthService.CurrentUser.UserId;

        await DbContext.SaveChangesAsync();
        _hoaSettings = await LoadHoaSettingsAsync();
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
        await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Update", "HOASettings", settings.SettingId, "Updated HOA settings.");
        Snackbar.Add("HOA settings saved.", Severity.Success);
    }

    private async Task DiscardHoaSettingsChangesAsync()
    {
        _hoaSettings = await LoadHoaSettingsAsync();
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
        Snackbar.Add("Unsaved HOA configuration changes were discarded.", Severity.Info);
    }

    private async Task PickLogoFileAsync()
    {
        var result = await Microsoft.Maui.Storage.FilePicker.PickAsync(new Microsoft.Maui.Storage.PickOptions
        {
            PickerTitle = "Select HOA Logo",
            FileTypes = new Microsoft.Maui.Storage.FilePickerFileType(new Dictionary<Microsoft.Maui.Devices.DevicePlatform, IEnumerable<string>>
            {
                [Microsoft.Maui.Devices.DevicePlatform.WinUI] = [".png", ".svg"]
            })
        });

        if (result is null)
        {
            return;
        }

        var extension = System.IO.Path.GetExtension(result.FileName);
        if (!string.Equals(extension, ".png", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(extension, ".svg", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Only PNG and SVG logo files are supported.", Severity.Warning);
            return;
        }

        _hoaSettings.LogoPath = result.FullPath;
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
    }

    private void ToggleAddUserForm()
    {
        _showAddUserForm = !_showAddUserForm;
        if (!_showAddUserForm)
        {
            _userForm = new UserFormModel();
        }
    }

    private async Task AddUserAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_userForm.Username) ||
            string.IsNullOrWhiteSpace(_userForm.Password) ||
            _userForm.RoleId == 0)
        {
            Snackbar.Add("Username, password, and role are required.", Severity.Warning);
            return;
        }

        var username = _userForm.Username.Trim();
        if (await DbContext.Users.AnyAsync(user => user.Username == username))
        {
            Snackbar.Add("That username is already in use.", Severity.Error);
            return;
        }

        if (_userForm.HomeownerId.HasValue &&
            await DbContext.Users.AnyAsync(user => user.HomeownerId == _userForm.HomeownerId.Value))
        {
            Snackbar.Add("That homeowner is already linked to another user.", Severity.Error);
            return;
        }

        var user = new User
        {
            Username = username,
            PasswordHash = HashHelper.Hash(_userForm.Password),
            RoleId = _userForm.RoleId,
            HomeownerId = _userForm.HomeownerId,
            IsActive = true,
            CreatedAt = DateTime.UtcNow.ToString("o")
        };

        DbContext.Users.Add(user);
        await DbContext.SaveChangesAsync();
        await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Create", "Users", user.UserId, $"Created user '{user.Username}'.");

        Snackbar.Add("User created successfully.", Severity.Success);
        _userForm = new UserFormModel();
        _showAddUserForm = false;
        await LoadAsync();
    }

    private void BeginPasswordReset(User user)
    {
        _resetPasswordUser = user;
        _resetPasswordValue = string.Empty;
    }

    private void CancelPasswordReset()
    {
        _resetPasswordUser = null;
        _resetPasswordValue = string.Empty;
    }

    private async Task SavePasswordResetAsync()
    {
        if (AuthService.CurrentUser is null || _resetPasswordUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_resetPasswordValue))
        {
            Snackbar.Add("Enter a new password first.", Severity.Warning);
            return;
        }

        var user = await DbContext.Users.FirstOrDefaultAsync(item => item.UserId == _resetPasswordUser.UserId);
        if (user is null)
        {
            Snackbar.Add("The selected user could not be found.", Severity.Error);
            return;
        }

        user.PasswordHash = HashHelper.Hash(_resetPasswordValue);
        await DbContext.SaveChangesAsync();
        await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Update", "Users", user.UserId, $"Reset password for '{user.Username}'.");

        Snackbar.Add("Password updated successfully.", Severity.Success);
        CancelPasswordReset();
        await LoadAsync();
    }

    private async Task DeactivateUserAsync(int userId)
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        if (AuthService.CurrentUser.UserId == userId)
        {
            Snackbar.Add("You cannot deactivate your own account.", Severity.Warning);
            return;
        }

        var user = await DbContext.Users.FirstOrDefaultAsync(item => item.UserId == userId);
        if (user is null)
        {
            Snackbar.Add("The selected user could not be found.", Severity.Error);
            return;
        }

        user.IsActive = false;
        await DbContext.SaveChangesAsync();
        await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Update", "Users", user.UserId, $"Deactivated user '{user.Username}'.");

        Snackbar.Add("User deactivated.", Severity.Success);
        await LoadAsync();
    }

    private void BeginAddPhase()
    {
        if (_editingPhaseId.HasValue || _showPhaseForm)
        {
            CancelPhaseForm();
            return;
        }

        _showPhaseForm = true;
        _phaseForm = new PhaseFormModel();
        _editingPhaseId = null;
    }

    private void BeginEditPhase(PhaseSummaryRow phase)
    {
        _showPhaseForm = true;
        _editingPhaseId = phase.PhaseId;
        _phaseForm = new PhaseFormModel
        {
            Name = phase.Name,
            Description = phase.Description
        };
    }

    private void CancelPhaseForm()
    {
        _showPhaseForm = false;
        _editingPhaseId = null;
        _phaseForm = new PhaseFormModel();
    }

    private async Task SavePhaseAsync()
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_phaseForm.Name))
        {
            Snackbar.Add("Phase name is required.", Severity.Warning);
            return;
        }

        if (_editingPhaseId.HasValue)
        {
            var phase = await DbContext.Phases.FirstOrDefaultAsync(item => item.PhaseId == _editingPhaseId.Value);
            if (phase is null)
            {
                Snackbar.Add("The selected phase could not be found.", Severity.Error);
                return;
            }

            phase.Name = _phaseForm.Name.Trim();
            phase.Description = NullIfEmpty(_phaseForm.Description);
            await DbContext.SaveChangesAsync();
            await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Update", "Phases", phase.PhaseId, $"Updated phase '{phase.Name}'.");

            Snackbar.Add("Phase updated.", Severity.Success);
        }
        else
        {
            var phase = new Phase
            {
                Name = _phaseForm.Name.Trim(),
                Description = NullIfEmpty(_phaseForm.Description),
                CreatedAt = DateTime.UtcNow.ToString("o")
            };

            DbContext.Phases.Add(phase);
            await DbContext.SaveChangesAsync();
            await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Create", "Phases", phase.PhaseId, $"Created phase '{phase.Name}'.");

            Snackbar.Add("Phase created.", Severity.Success);
        }

        CancelPhaseForm();
        await LoadAsync();
    }

    private async Task DeletePhaseAsync(int phaseId)
    {
        if (AuthService.CurrentUser is null)
        {
            return;
        }

        var assignedHomeowners = await DbContext.Homeowners.CountAsync(homeowner => !homeowner.IsDeleted && homeowner.PhaseId == phaseId);
        var assignedUnits = await DbContext.Units.CountAsync(unit => unit.PhaseId == phaseId);

        if (assignedHomeowners > 0 || assignedUnits > 0)
        {
            Snackbar.Add("This phase cannot be deleted while homeowners or units are still assigned to it.", Severity.Error);
            return;
        }

        var phase = await DbContext.Phases.FirstOrDefaultAsync(item => item.PhaseId == phaseId);
        if (phase is null)
        {
            Snackbar.Add("The selected phase could not be found.", Severity.Error);
            return;
        }

        DbContext.Phases.Remove(phase);
        await DbContext.SaveChangesAsync();
        await AuditService.LogAsync(AuthService.CurrentUser.UserId, "Delete", "Phases", phase.PhaseId, $"Deleted phase '{phase.Name}'.");

        Snackbar.Add("Phase deleted.", Severity.Success);
        await LoadAsync();
    }

    private async Task<List<Homeowner>> GetAvailableHomeownersAsync()
    {
        var linkedHomeownerIds = await DbContext.Users
            .AsNoTracking()
            .Where(user => user.HomeownerId.HasValue)
            .Select(user => user.HomeownerId!.Value)
            .ToListAsync();

        return await DbContext.Homeowners
            .AsNoTracking()
            .Where(homeowner => !homeowner.IsDeleted && !linkedHomeownerIds.Contains(homeowner.HomeownerId))
            .OrderBy(homeowner => homeowner.LastName)
            .ThenBy(homeowner => homeowner.FirstName)
            .ToListAsync();
    }

    private async Task<HOASettings> LoadHoaSettingsAsync()
    {
        var settings = await DbContext.HOASettings
            .AsNoTracking()
            .FirstOrDefaultAsync();

        return settings is null
            ? new HOASettings
            {
                SettingId = 1,
                HOAName = "Homeowners Association",
                Subdivision = "Sample Subdivision",
                City = "Davao City",
                Province = "Davao del Sur"
            }
            : new HOASettings
            {
                SettingId = settings.SettingId,
                HOAName = settings.HOAName,
                Subdivision = settings.Subdivision,
                City = settings.City,
                Province = settings.Province,
                PresidentName = settings.PresidentName,
                SecretaryName = settings.SecretaryName,
                TreasurerName = settings.TreasurerName,
                ContactNumber = settings.ContactNumber,
                LogoPath = settings.LogoPath,
                UpdatedAt = settings.UpdatedAt,
                UpdatedBy = settings.UpdatedBy
            };
    }

    private async Task LoadLogoPreviewAsync(string? path)
    {
        _logoPreviewUrl = null;

        if (string.IsNullOrWhiteSpace(path) || !System.IO.File.Exists(path))
        {
            return;
        }

        var bytes = await System.IO.File.ReadAllBytesAsync(path);
        var extension = System.IO.Path.GetExtension(path).ToLowerInvariant();
        var mimeType = extension switch
        {
            ".svg" => "image/svg+xml",
            _ => "image/png"
        };

        _logoPreviewUrl = $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}";
    }

    private static string GetHomeownerDisplay(Homeowner homeowner)
    {
        var parts = new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }
            .Where(value => !string.IsNullOrWhiteSpace(value));

        return string.Join(" ", parts);
    }

    private static string? NullIfEmpty(string? value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private static string DisplayValue(string? value) =>
        string.IsNullOrWhiteSpace(value) ? "-" : value;

    private static string FormatDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed))
        {
            return "-";
        }

        return parsed.ToString("MMMM dd, yyyy");
    }

    private static DateTime? ParseDate(string? value) =>
        DateTime.TryParse(value, out var parsed) ? parsed : null;

