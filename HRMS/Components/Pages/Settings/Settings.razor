@page "/settings"
@inject AppDbContext DbContext
@inject AuthService AuthService
@inject SubdivisionContextService SubdivisionContextService
@inject SettingsService SettingsService
@inject IJSRuntime JS

<PageHeader Title="Settings" Subtitle="System configuration, user management, and audit logs." />

<SubdivisionSelector OnSubdivisionSelected="HandleSubdivisionChange"
                     IsReadOnly="false" />

@if (_isLoading)
{
    <LoadingSpinner />
}
else
{
    <div role="tablist" class="tabs tabs-bordered mb-0 w-full overflow-x-auto">
        <button role="tab" class="tab @(ActiveTab == "hoa" ? "tab-active font-semibold" : "")" @onclick='() => ActiveTab = "hoa"'>HOA Configuration</button>
        <button role="tab" class="tab @(ActiveTab == "users" ? "tab-active font-semibold" : "")" @onclick='() => ActiveTab = "users"'>User Management</button>
        <button role="tab" class="tab @(ActiveTab == "phases" ? "tab-active font-semibold" : "")" @onclick='() => ActiveTab = "phases"'>Phase Management</button>
        <button role="tab" class="tab @(ActiveTab == "audit" ? "tab-active font-semibold" : "")" @onclick='() => ActiveTab = "audit"'>Audit Log</button>
    </div>

    <div class="card rounded-tl-none border border-base-300 border-t-0 bg-base-100 shadow-none">
        <div class="card-body p-6">
            @if (ActiveTab == "hoa")
            {
                <div class="space-y-6">
                    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                        <FieldGroup Label="HOA Name"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.HOAName" /></FieldGroup>
                        <FieldGroup Label="Subdivision Name"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.Subdivision" /></FieldGroup>
                        <FieldGroup Label="City"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.City" /></FieldGroup>
                        <FieldGroup Label="Province"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.Province" /></FieldGroup>
                        <FieldGroup Label="Contact Number"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.ContactNumber" /></FieldGroup>
                        <div></div>
                        <FieldGroup Label="President Name"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.PresidentName" /></FieldGroup>
                        <FieldGroup Label="Secretary Name"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.SecretaryName" /></FieldGroup>
                        <FieldGroup Label="Treasurer Name"><input type="text" class="input input-bordered w-full" @bind="_hoaSettings.TreasurerName" /></FieldGroup>
                    </div>

                    <div>
                        <p class="mb-2 text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">Logo</p>
                        @if (!string.IsNullOrWhiteSpace(_logoPreviewUrl))
                        {
                            <div class="flex flex-wrap items-center gap-4 rounded border border-base-300 p-4">
                                <img src="@_logoPreviewUrl" alt="HOA logo preview" class="h-16 w-16 rounded object-contain" />
                                <div class="flex-1">
                                    <p class="text-sm font-medium text-base-content">@System.IO.Path.GetFileName(_hoaSettings.LogoPath)</p>
                                    <p class="text-xs text-base-content/40">PNG or SVG, Max 2MB</p>
                                </div>
                                <button class="btn btn-outline btn-sm" @onclick="PickLogoFileAsync">Replace</button>
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-outline btn-sm" @onclick="PickLogoFileAsync">Upload Logo</button>
                        }
                    </div>

                    <div class="flex justify-end gap-3 border-t border-base-300 pt-4">
                        <button class="btn btn-ghost btn-sm" @onclick="DiscardHoaSettingsChangesAsync">Discard</button>
                        <button class="btn btn-primary btn-sm" @onclick="SaveHoaSettingsAsync">Save Settings</button>
                    </div>
                </div>
            }
            else if (ActiveTab == "users")
            {
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-semibold text-base-content">Users</p>
                            <p class="text-xs text-base-content/40">Manage access and account status.</p>
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="ToggleAddUserForm">@(_showAddUserForm ? "Close Form" : "Add User")</button>
                    </div>

                    @if (_showAddUserForm)
                    {
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
                            <FieldGroup Label="Username"><input type="text" class="input input-bordered w-full" @bind="_userForm.Username" /></FieldGroup>
                            <FieldGroup Label="Password"><input type="password" class="input input-bordered w-full" @bind="_userForm.Password" /></FieldGroup>
                            <FieldGroup Label="Role">
                                <select class="select select-bordered w-full" @bind="_userForm.RoleId">
                                    <option value="0">Select Role</option>
                                    @foreach (var role in _roles)
                                    {
                                        <option value="@role.RoleId">@role.RoleName</option>
                                    }
                                </select>
                            </FieldGroup>
                            <FieldGroup Label="Homeowner Link">
                                <select class="select select-bordered w-full" @bind="_userForm.HomeownerId">
                                    <option value="">No linked homeowner</option>
                                    @foreach (var homeowner in _availableHomeowners)
                                    {
                                        <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                                    }
                                </select>
                            </FieldGroup>
                        </div>
                        <div class="flex justify-end gap-3">
                            <button class="btn btn-ghost btn-sm" @onclick="ToggleAddUserForm">Cancel</button>
                            <button class="btn btn-primary btn-sm" @onclick="AddUserAsync">Create User</button>
                        </div>
                    }

                    <div class="grid grid-cols-1 gap-3 md:grid-cols-3">
                        <FieldGroup Label="Username"><input type="text" class="input input-bordered input-sm w-full" @bind-value="_filterUsername" @bind-value:event="oninput" /></FieldGroup>
                        <FieldGroup Label="Role">
                            <select class="select select-bordered select-sm w-full" @bind="_filterRole">
                                <option value="">All Roles</option>
                                <option>Super Admin</option><option>HOA President</option><option>Board Member</option><option>HOA Staff</option><option>Homeowner</option>
                            </select>
                        </FieldGroup>
                        <FieldGroup Label="Status">
                            <select class="select select-bordered select-sm w-full" @bind="_filterStatus">
                                <option value="">All Statuses</option><option>Active</option><option>Inactive</option>
                            </select>
                        </FieldGroup>
                    </div>

                    @if (!FilteredUsers.Any())
                    {
                        <EmptyState Title="No users found" Subtitle="No users match the current filters." Icon="O" />
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="table table-sm">
                                <thead>
                                    <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                        <th>Username</th><th>Role</th><th>Status</th><th>Last Login</th><th class="text-right">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in FilteredUsers)
                                    {
                                        <tr class="h-[52px] hover">
                                            <td class="text-sm font-medium">@user.Username</td>
                                            <td class="text-sm text-base-content/60">@DisplayValue(user.Role?.RoleName)</td>
                                            <td><StatusChip Status="@(user.IsActive ? "Active" : "Inactive")" /></td>
                                            <td class="text-sm text-base-content/60">@FormatDate(user.LastLoginAt)</td>
                                            <td class="text-right">
                                                <button class="btn btn-ghost btn-xs" @onclick="() => BeginEditUser(user)">Edit</button>
                                                @if (user.IsActive)
                                                {
                                                    <button class="btn btn-ghost btn-xs text-error" @onclick="() => DeactivateUserAsync(user.UserId)">Deactivate</button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-ghost btn-xs text-success" @onclick="() => ReactivateUserAsync(user.UserId)">Reactivate</button>
                                                }
                                                <button class="btn btn-ghost btn-xs" @onclick="() => BeginPasswordReset(user)">Reset Password</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <TableRecordCount Count="@FilteredUsers.Count()" EntityLabel="users" />
                    }

                    @if (_editingUser is not null)
                    {
                        <div class="rounded border border-base-300 p-4">
                            <p class="text-sm font-semibold text-base-content">Edit User: @_editingUser.Username</p>
                            <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-2">
                                <FieldGroup Label="Role">
                                    <select class="select select-bordered w-full" @bind="_editUserForm.RoleId">
                                        <option value="0">Select Role</option>
                                        @foreach (var role in _roles)
                                        {
                                            <option value="@role.RoleId">@role.RoleName</option>
                                        }
                                    </select>
                                </FieldGroup>
                                <FieldGroup Label="Homeowner Link">
                                    <select class="select select-bordered w-full" @bind="_editUserForm.HomeownerId">
                                        <option value="">No linked homeowner</option>
                                        @foreach (var homeowner in GetEditableHomeowners(_editingUser))
                                        {
                                            <option value="@homeowner.HomeownerId">@GetHomeownerDisplay(homeowner)</option>
                                        }
                                    </select>
                                </FieldGroup>
                            </div>
                            <div class="mt-4 flex justify-end gap-3">
                                <button class="btn btn-ghost btn-sm" @onclick="CancelEditUser">Cancel</button>
                                <button class="btn btn-primary btn-sm" @onclick="SaveUserEditAsync">Save User</button>
                            </div>
                        </div>
                    }

                    @if (_resetPasswordUser is not null)
                    {
                        <div class="rounded border border-base-300 p-4">
                            <p class="text-sm font-semibold text-base-content">Reset Password for @_resetPasswordUser.Username</p>
                            <div class="mt-4 max-w-md">
                                <FieldGroup Label="New Password"><input type="password" class="input input-bordered w-full" @bind="_resetPasswordValue" /></FieldGroup>
                            </div>
                            <div class="mt-4 flex justify-end gap-3">
                                <button class="btn btn-ghost btn-sm" @onclick="CancelPasswordReset">Cancel</button>
                                <button class="btn btn-primary btn-sm" @onclick="SavePasswordResetAsync">Save Password</button>
                            </div>
                        </div>
                    }
                </div>
            }
            else if (ActiveTab == "phases")
            {
                <div class="space-y-4">
                    <div class="flex flex-wrap items-center justify-between gap-3">
                        <div>
                            <p class="text-sm font-semibold text-base-content">Phases</p>
                            <p class="text-xs text-base-content/40">Maintain phase names and assignments.</p>
                        </div>
                        <button class="btn btn-primary btn-sm" @onclick="BeginAddPhase">@(_editingPhaseId.HasValue ? "Cancel Edit" : "Add Phase")</button>
                    </div>

                    @if (_showPhaseForm)
                    {
                        <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                            <FieldGroup Label="Phase Name"><input type="text" class="input input-bordered w-full" @bind="_phaseForm.Name" /></FieldGroup>
                            <FieldGroup Label="Description"><input type="text" class="input input-bordered w-full" @bind="_phaseForm.Description" /></FieldGroup>
                        </div>
                        <div class="flex justify-end gap-3">
                            <button class="btn btn-ghost btn-sm" @onclick="CancelPhaseForm">Cancel</button>
                            <button class="btn btn-primary btn-sm" @onclick="SavePhaseAsync">Save Phase</button>
                        </div>
                    }

                    <div class="overflow-x-auto">
                        <table class="table table-sm">
                            <thead>
                                <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                    <th>Phase Name</th><th>Description</th><th>Homeowner Count</th><th>Unit Count</th><th class="text-right">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var phase in _phases)
                                {
                                    <tr class="h-[52px] hover">
                                        <td class="text-sm font-medium">@phase.Name</td>
                                        <td class="text-sm text-base-content/60">@DisplayValue(phase.Description)</td>
                                        <td class="text-sm text-base-content/60">@phase.HomeownerCount</td>
                                        <td class="text-sm text-base-content/60">@phase.UnitCount</td>
                                        <td class="text-right">
                                            <button class="btn btn-ghost btn-xs" @onclick="() => BeginEditPhase(phase)">Edit</button>
                                            <button class="btn btn-ghost btn-xs text-error" @onclick="() => DeletePhaseAsync(phase.PhaseId)">Delete</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <TableRecordCount Count="@_phases.Count" EntityLabel="phases" />
                </div>
            }
            else
            {
                <div class="space-y-4">
                    <div class="grid grid-cols-1 gap-3 md:grid-cols-5">
                        <FieldGroup Label="Username"><input type="text" class="input input-bordered input-sm w-full" @bind-value="_auditUsernameFilter" @bind-value:event="oninput" /></FieldGroup>
                        <FieldGroup Label="Action">
                            <select class="select select-bordered select-sm w-full" @bind="_auditActionFilter">
                                <option value="">All Actions</option>
                                @foreach (var action in AuditActionOptions)
                                {
                                    <option value="@action">@action</option>
                                }
                            </select>
                        </FieldGroup>
                        <FieldGroup Label="Table">
                            <select class="select select-bordered select-sm w-full" @bind="_auditTableFilter">
                                <option value="">All Tables</option>
                                @foreach (var table in AuditTableOptions)
                                {
                                    <option value="@table">@table</option>
                                }
                            </select>
                        </FieldGroup>
                        <FieldGroup Label="From"><input type="date" class="input input-bordered input-sm w-full" value="@FormatHtmlDate(_auditFromDate)" @onchange="OnAuditFromDateChanged" /></FieldGroup>
                        <FieldGroup Label="To"><input type="date" class="input input-bordered input-sm w-full" value="@FormatHtmlDate(_auditToDate)" @onchange="OnAuditToDateChanged" /></FieldGroup>
                    </div>

                    @if (!FilteredAuditLogs.Any())
                    {
                        <EmptyState Title="No audit logs found" Subtitle="No audit logs match the current filters." Icon="O" />
                    }
                    else
                    {
                        <div class="overflow-x-auto">
                            <table class="table table-sm">
                                <thead>
                                    <tr class="text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
                                        <th>Timestamp</th><th>Username</th><th>Action</th><th>Table</th><th>Record ID</th><th>Details</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var log in FilteredAuditLogs)
                                    {
                                        <tr class="h-[52px] hover">
                                            <td class="text-sm text-base-content/60">@FormatDate(log.Timestamp)</td>
                                            <td class="text-sm">@DisplayValue(log.User?.Username)</td>
                                            <td class="text-sm text-base-content/60">@DisplayValue(log.Action)</td>
                                            <td class="text-sm text-base-content/60">@DisplayValue(log.TableAffected)</td>
                                            <td class="text-sm text-base-content/60">@DisplayValue(log.RecordId?.ToString())</td>
                                            <td class="text-sm text-base-content/60">@DisplayValue(log.Details)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <TableRecordCount Count="@FilteredAuditLogs.Count()" EntityLabel="audit logs" />
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private static readonly string[] AuditActionOptions = ["Login", "Logout", "Create", "Update", "Delete", "Export", "Generate"];
    private static readonly string[] AuditTableOptions = ["Users", "Homeowners", "Units", "Events", "Attendances", "InteractionLogs", "MSMEs", "DuesRecords", "ViolationRecords", "ClearanceRequests", "AuditLogs", "HOASettings", "Phases", "Reports", "Documents", "Subdivisions"];
    private HOASettings _hoaSettings = new() { SettingId = 1 };
    private List<User> _users = [];
    private List<Role> _roles = [];
    private List<Homeowner> _availableHomeowners = [];
    private List<PhaseSummaryRow> _phases = [];
    private List<AuditLog> _auditLogs = [];
    private UserFormModel _userForm = new();
    private EditUserFormModel _editUserForm = new();
    private PhaseFormModel _phaseForm = new();
    private User? _editingUser;
    private User? _resetPasswordUser;
    private string _resetPasswordValue = string.Empty;
    private string? _logoPreviewUrl;
    private bool _isLoading = true;
    private bool _showAddUserForm;
    private bool _showPhaseForm;
    private int? _editingPhaseId;
    private string _filterUsername = string.Empty;
    private string _filterRole = string.Empty;
    private string _filterStatus = string.Empty;
    private string _auditUsernameFilter = string.Empty;
    private string _auditActionFilter = string.Empty;
    private string _auditTableFilter = string.Empty;
    private DateTime? _auditFromDate;
    private DateTime? _auditToDate;
    private string ActiveTab { get; set; } = "hoa";
    private int? ActiveSubdivisionId => SubdivisionContextService.SelectedSubdivisionId;

    private IEnumerable<User> FilteredUsers => _users.Where(user =>
        (string.IsNullOrEmpty(_filterUsername) || user.Username.Contains(_filterUsername, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_filterRole) || user.Role.RoleName == _filterRole) &&
        (string.IsNullOrEmpty(_filterStatus) || (user.IsActive ? "Active" : "Inactive") == _filterStatus));

    private IEnumerable<AuditLog> FilteredAuditLogs => _auditLogs
        .Where(log => string.IsNullOrWhiteSpace(_auditUsernameFilter) || (log.User?.Username?.Contains(_auditUsernameFilter, StringComparison.OrdinalIgnoreCase) ?? false))
        .Where(log => string.IsNullOrWhiteSpace(_auditActionFilter) || log.Action == _auditActionFilter)
        .Where(log => string.IsNullOrWhiteSpace(_auditTableFilter) || log.TableAffected == _auditTableFilter)
        .Where(log => !_auditFromDate.HasValue || (ParseDate(log.Timestamp)?.Date >= _auditFromDate.Value.Date))
        .Where(log => !_auditToDate.HasValue || (ParseDate(log.Timestamp)?.Date <= _auditToDate.Value.Date))
        .OrderByDescending(log => ParseDate(log.Timestamp));

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _isLoading = true;
        _hoaSettings = await LoadHoaSettingsAsync(ActiveSubdivisionId);
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
        _users = await DbContext.Users.AsNoTracking()
            .Include(user => user.Role)
            .Include(user => user.Homeowner)
            .Where(user => !ActiveSubdivisionId.HasValue || user.SubdivisionId == null || user.SubdivisionId == ActiveSubdivisionId.Value)
            .OrderBy(user => user.Username)
            .ToListAsync();
        _roles = await DbContext.Roles.AsNoTracking().OrderBy(role => role.RoleName).ToListAsync();
        _availableHomeowners = await GetAvailableHomeownersAsync(ActiveSubdivisionId);
        _phases = ActiveSubdivisionId.HasValue
            ? await DbContext.Phases.AsNoTracking()
                .Include(phase => phase.Homeowners)
                .Include(phase => phase.Units)
                .Where(phase => phase.SubdivisionId == ActiveSubdivisionId.Value)
                .OrderBy(phase => phase.Name)
                .Select(phase => new PhaseSummaryRow
                {
                    PhaseId = phase.PhaseId,
                    Name = phase.Name,
                    Description = phase.Description,
                    HomeownerCount = phase.Homeowners.Count(homeowner => !homeowner.IsDeleted),
                    UnitCount = phase.Units.Count
                }).ToListAsync()
            : [];
        _auditLogs = await DbContext.AuditLogs.AsNoTracking().Include(log => log.User).OrderByDescending(log => log.Timestamp).ToListAsync();
        _isLoading = false;
    }

    private async Task SaveHoaSettingsAsync()
    {
        if (AuthService.CurrentUser is null) return;

        try
        {
            if (!ActiveSubdivisionId.HasValue)
            {
                throw new InvalidOperationException("Select a subdivision first.");
            }

            await SettingsService.SaveHoaSettingsAsync(_hoaSettings, ActiveSubdivisionId.Value, AuthService.CurrentUser.UserId);
            _hoaSettings = await LoadHoaSettingsAsync(ActiveSubdivisionId);
            await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
            await ShowToastAsync("HOA settings saved.", "success");
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private async Task DiscardHoaSettingsChangesAsync()
    {
        _hoaSettings = await LoadHoaSettingsAsync(ActiveSubdivisionId);
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
        await ShowToastAsync("Unsaved HOA configuration changes were discarded.", "info");
    }

    private async Task PickLogoFileAsync()
    {
        var result = await Microsoft.Maui.Storage.FilePicker.PickAsync(new Microsoft.Maui.Storage.PickOptions
        {
            PickerTitle = "Select HOA Logo",
            FileTypes = new Microsoft.Maui.Storage.FilePickerFileType(new Dictionary<Microsoft.Maui.Devices.DevicePlatform, IEnumerable<string>>
            {
                [Microsoft.Maui.Devices.DevicePlatform.WinUI] = [".png", ".svg"]
            })
        });

        if (result is null) return;

        var extension = System.IO.Path.GetExtension(result.FileName);
        if (!string.Equals(extension, ".png", StringComparison.OrdinalIgnoreCase) &&
            !string.Equals(extension, ".svg", StringComparison.OrdinalIgnoreCase))
        {
            await ShowToastAsync("Only PNG and SVG logo files are supported.", "warning");
            return;
        }

        _hoaSettings.LogoPath = result.FullPath;
        await LoadLogoPreviewAsync(_hoaSettings.LogoPath);
    }

    private void ToggleAddUserForm()
    {
        _showAddUserForm = !_showAddUserForm;
        if (!_showAddUserForm) _userForm = new UserFormModel();
    }

    private async Task AddUserAsync()
    {
        if (AuthService.CurrentUser is null) return;

        try
        {
            await SettingsService.AddUserAsync(
                _userForm.Username,
                _userForm.Password,
                _userForm.RoleId,
                _userForm.HomeownerId,
                ActiveSubdivisionId,
                AuthService.CurrentUser.UserId);

            await ShowToastAsync("User created successfully.", "success");
            _userForm = new UserFormModel();
            _showAddUserForm = false;
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private void BeginPasswordReset(User user)
    {
        _resetPasswordUser = user;
        _resetPasswordValue = string.Empty;
    }

    private void BeginEditUser(User user)
    {
        _editingUser = user;
        _editUserForm = new EditUserFormModel
        {
            UserId = user.UserId,
            RoleId = user.RoleId,
            HomeownerId = user.HomeownerId
        };
    }

    private void CancelEditUser()
    {
        _editingUser = null;
        _editUserForm = new EditUserFormModel();
    }

    private void CancelPasswordReset()
    {
        _resetPasswordUser = null;
        _resetPasswordValue = string.Empty;
    }

    private async Task SavePasswordResetAsync()
    {
        if (AuthService.CurrentUser is null || _resetPasswordUser is null) return;

        try
        {
            await SettingsService.ResetPasswordAsync(
                _resetPasswordUser.UserId,
                _resetPasswordValue,
                AuthService.CurrentUser.UserId);

            await ShowToastAsync("Password updated successfully.", "success");
            CancelPasswordReset();
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private async Task DeactivateUserAsync(int userId)
    {
        if (AuthService.CurrentUser is null) return;

        try
        {
            await SettingsService.DeactivateUserAsync(userId, AuthService.CurrentUser.UserId);
            await ShowToastAsync("User deactivated.", "success");
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private async Task ReactivateUserAsync(int userId)
    {
        if (AuthService.CurrentUser is null) return;

        try
        {
            await SettingsService.ReactivateUserAsync(userId, AuthService.CurrentUser.UserId);
            await ShowToastAsync("User reactivated.", "success");
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private async Task SaveUserEditAsync()
    {
        if (AuthService.CurrentUser is null || _editingUser is null) return;

        try
        {
            await SettingsService.UpdateUserAsync(
                _editUserForm.UserId,
                _editUserForm.RoleId,
                _editUserForm.HomeownerId,
                ActiveSubdivisionId,
                AuthService.CurrentUser.UserId);

            await ShowToastAsync("User updated successfully.", "success");
            CancelEditUser();
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private void BeginAddPhase()
    {
        if (_editingPhaseId.HasValue || _showPhaseForm)
        {
            CancelPhaseForm();
            return;
        }

        _showPhaseForm = true;
        _phaseForm = new PhaseFormModel();
        _editingPhaseId = null;
    }

    private void BeginEditPhase(PhaseSummaryRow phase)
    {
        _showPhaseForm = true;
        _editingPhaseId = phase.PhaseId;
        _phaseForm = new PhaseFormModel { Name = phase.Name, Description = phase.Description };
    }

    private void CancelPhaseForm()
    {
        _showPhaseForm = false;
        _editingPhaseId = null;
        _phaseForm = new PhaseFormModel();
    }

    private async Task SavePhaseAsync()
    {
        if (AuthService.CurrentUser is null) return;

        try
        {
            if (_editingPhaseId.HasValue)
            {
                await SettingsService.UpdatePhaseAsync(
                    _editingPhaseId.Value,
                    _phaseForm.Name,
                    _phaseForm.Description,
                    AuthService.CurrentUser.UserId);

                await ShowToastAsync("Phase updated.", "success");
            }
            else
            {
                if (!ActiveSubdivisionId.HasValue)
                {
                    throw new InvalidOperationException("Select a subdivision first.");
                }

                await SettingsService.AddPhaseAsync(
                    _phaseForm.Name,
                    _phaseForm.Description,
                    ActiveSubdivisionId.Value,
                    AuthService.CurrentUser.UserId);

                await ShowToastAsync("Phase created.", "success");
            }

            CancelPhaseForm();
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private async Task DeletePhaseAsync(int phaseId)
    {
        if (AuthService.CurrentUser is null) return;

        try
        {
            if (!ActiveSubdivisionId.HasValue)
            {
                throw new InvalidOperationException("Select a subdivision first.");
            }

            await SettingsService.DeletePhaseAsync(
                phaseId,
                ActiveSubdivisionId.Value,
                AuthService.CurrentUser.UserId);

            await ShowToastAsync("Phase deleted.", "success");
            await LoadAsync();
        }
        catch (InvalidOperationException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
        catch (UnauthorizedAccessException ex)
        {
            await ShowToastAsync(ex.Message, "error");
        }
    }

    private async Task<List<Homeowner>> GetAvailableHomeownersAsync(int? subdivisionId)
    {
        var linkedHomeownerIds = await DbContext.Users.AsNoTracking()
            .Where(user => user.HomeownerId.HasValue)
            .Select(user => user.HomeownerId!.Value)
            .ToListAsync();

        return await DbContext.Homeowners.AsNoTracking()
            .Where(homeowner =>
                !homeowner.IsDeleted &&
                !linkedHomeownerIds.Contains(homeowner.HomeownerId) &&
                (!subdivisionId.HasValue || homeowner.SubdivisionId == subdivisionId.Value))
            .OrderBy(homeowner => homeowner.LastName)
            .ThenBy(homeowner => homeowner.FirstName)
            .ToListAsync();
    }

    private IEnumerable<Homeowner> GetEditableHomeowners(User user)
    {
        var homeowners = _availableHomeowners.AsEnumerable();

        if (user.Homeowner is not null && homeowners.All(homeowner => homeowner.HomeownerId != user.Homeowner.HomeownerId))
        {
            homeowners = homeowners.Append(user.Homeowner);
        }

        return homeowners
            .OrderBy(homeowner => homeowner.LastName)
            .ThenBy(homeowner => homeowner.FirstName);
    }

    private async Task<HOASettings> LoadHoaSettingsAsync(int? subdivisionId)
    {
        var settings = subdivisionId.HasValue
            ? await DbContext.HOASettings.AsNoTracking().FirstOrDefaultAsync(item => item.SubdivisionId == subdivisionId.Value)
            : null;

        return settings is null
            ? new HOASettings { SubdivisionId = subdivisionId ?? 0, HOAName = "Homeowners Association", Subdivision = "Sample Subdivision", City = "Davao City", Province = "Davao del Sur" }
            : new HOASettings
            {
                SettingId = settings.SettingId,
                SubdivisionId = settings.SubdivisionId,
                HOAName = settings.HOAName,
                Subdivision = settings.Subdivision,
                City = settings.City,
                Province = settings.Province,
                PresidentName = settings.PresidentName,
                SecretaryName = settings.SecretaryName,
                TreasurerName = settings.TreasurerName,
                ContactNumber = settings.ContactNumber,
                LogoPath = settings.LogoPath,
                UpdatedAt = settings.UpdatedAt,
                UpdatedBy = settings.UpdatedBy
            };
    }

    private async Task HandleSubdivisionChange(int? subdivisionId)
    {
        await LoadAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadLogoPreviewAsync(string? path)
    {
        _logoPreviewUrl = null;
        if (string.IsNullOrWhiteSpace(path) || !System.IO.File.Exists(path)) return;
        var bytes = await System.IO.File.ReadAllBytesAsync(path);
        var mimeType = System.IO.Path.GetExtension(path).ToLowerInvariant() == ".svg" ? "image/svg+xml" : "image/png";
        _logoPreviewUrl = $"data:{mimeType};base64,{Convert.ToBase64String(bytes)}";
    }

    private Task ShowToastAsync(string message, string type) => JS.InvokeVoidAsync("hrms.showToast", message, type).AsTask();
    private void OnAuditFromDateChanged(ChangeEventArgs args) => _auditFromDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;
    private void OnAuditToDateChanged(ChangeEventArgs args) => _auditToDate = DateTime.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;
    private static string FormatHtmlDate(DateTime? value) => value?.ToString("yyyy-MM-dd") ?? string.Empty;
    private static string GetHomeownerDisplay(Homeowner homeowner) => string.Join(" ", new[] { homeowner.FirstName, homeowner.MiddleName, homeowner.LastName }.Where(value => !string.IsNullOrWhiteSpace(value)));
    private static string? NullIfEmpty(string? value) => string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    private static string DisplayValue(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    private static string FormatDate(string? value) => string.IsNullOrWhiteSpace(value) || !DateTime.TryParse(value, out var parsed) ? "-" : parsed.ToString("MMMM dd, yyyy");
    private static DateTime? ParseDate(string? value) => DateTime.TryParse(value, out var parsed) ? parsed : null;

