@page "/reports"
@inject ReportService ReportService
@inject IJSRuntime JS

<PageHeader Title="Reports"
            Subtitle="Export homeowner, dues, violation, and clearance data to PDF or Excel." />

<div class="flex flex-col gap-4">
@foreach (var reportItem in ReportSections)
{
    <div class="card border border-base-300 bg-base-100 shadow-none">
        <div class="card-body p-0">
            <div class="border-b border-base-300 p-5">
                <p class="text-sm font-semibold text-base-content">@reportItem.Title</p>
                <p class="mt-0.5 text-xs text-base-content/40">@reportItem.Description</p>
            </div>

            @if (reportItem.Key == "dues")
            {
                    <div class="px-5 pt-5">
                        <div class="flex flex-wrap gap-3">
                            <div class="form-control min-w-[160px]">
                                <label class="label py-0 pb-1">
                                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Month</span>
                                </label>
                                <select class="select select-bordered select-sm" value="@GetNullableIntValue(_selectedMonth)" @onchange="OnMonthChanged">
                                    <option value="">All Months</option>
                                    @foreach (var month in Enumerable.Range(1, 12))
                                    {
                                        <option value="@month">@GetMonthName(month)</option>
                                    }
                                </select>
                            </div>
                            <div class="form-control min-w-[140px]">
                                <label class="label py-0 pb-1">
                                    <span class="label-text text-[10px] font-semibold uppercase tracking-wide text-base-content/50">Year</span>
                                </label>
                                <select class="select select-bordered select-sm" value="@GetNullableIntValue(_selectedYear)" @onchange="OnYearChanged">
                                    <option value="">All Years</option>
                                    @foreach (var year in _yearOptions)
                                    {
                                        <option value="@year">@year</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                }

                <div class="flex gap-3 p-5">
                    <button class="btn btn-primary btn-sm"
                            disabled="@_isExporting"
                            @onclick="() => ExportPdfAsync(reportItem.Key)">
                        Export to PDF
                    </button>
                    <button class="btn btn-outline btn-primary btn-sm"
                            disabled="@_isExporting"
                            @onclick="() => ExportExcelAsync(reportItem.Key)">
                        Export to Excel
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private static readonly ReportSection[] ReportSections =
    [
        new("homeowners", "Homeowners", "All registered homeowner profiles and status records."),
        new("dues", "Dues", "Monthly dues records with payment status."),
        new("violations", "Violations", "Filed violation and incident reports."),
        new("clearances", "Clearances", "HOA clearance and document requests.")
    ];

    private bool _isExporting;
    private int? _selectedMonth;
    private int? _selectedYear = DateTime.UtcNow.Year;
    private List<int> _yearOptions = [];

    protected override void OnInitialized()
    {
        var currentYear = DateTime.UtcNow.Year;
        _yearOptions = Enumerable.Range(currentYear - 4, 7)
            .OrderByDescending(year => year)
            .ToList();
    }

    private async Task ExportPdfAsync(string key)
    {
        switch (key)
        {
            case "homeowners":
                await ExportAsync(() => ReportService.ExportHomeownersToPdfAsync(), $"homeowners_report_{DateTime.UtcNow:yyyyMMdd}.pdf");
                break;
            case "dues":
                await ExportAsync(() => ReportService.ExportDuesToPdfAsync(_selectedMonth, _selectedYear), $"dues_report_{BuildDuesFileSuffix()}.pdf");
                break;
            case "violations":
                await ExportAsync(() => ReportService.ExportViolationsToPdfAsync(), $"violations_report_{DateTime.UtcNow:yyyyMMdd}.pdf");
                break;
            case "clearances":
                await ExportAsync(() => ReportService.ExportClearancesToPdfAsync(), $"clearances_report_{DateTime.UtcNow:yyyyMMdd}.pdf");
                break;
        }
    }

    private async Task ExportExcelAsync(string key)
    {
        switch (key)
        {
            case "homeowners":
                await ExportAsync(() => ReportService.ExportHomeownersToExcelAsync(), $"homeowners_report_{DateTime.UtcNow:yyyyMMdd}.xlsx");
                break;
            case "dues":
                await ExportAsync(() => ReportService.ExportDuesToExcelAsync(_selectedMonth, _selectedYear), $"dues_report_{BuildDuesFileSuffix()}.xlsx");
                break;
            case "violations":
                await ExportAsync(() => ReportService.ExportViolationsToExcelAsync(), $"violations_report_{DateTime.UtcNow:yyyyMMdd}.xlsx");
                break;
            case "clearances":
                await ExportAsync(() => ReportService.ExportClearancesToExcelAsync(), $"clearances_report_{DateTime.UtcNow:yyyyMMdd}.xlsx");
                break;
        }
    }

    private async Task ExportAsync(Func<Task<byte[]>> exportFunc, string fileName)
    {
        try
        {
            _isExporting = true;
            var bytes = await exportFunc();
            await SaveAndOpenAsync(bytes, fileName);
            await JS.InvokeVoidAsync("hrms.showToast", $"Export generated: {fileName}", "success");
        }
        catch (Exception exception)
        {
            await JS.InvokeVoidAsync("hrms.showToast", exception.Message, "error");
        }
        finally
        {
            _isExporting = false;
        }
    }

    private static async Task SaveAndOpenAsync(byte[] bytes, string fileName)
    {
        var filePath = Path.Combine(Microsoft.Maui.Storage.FileSystem.CacheDirectory, fileName);
        await File.WriteAllBytesAsync(filePath, bytes);

        await Microsoft.Maui.ApplicationModel.Launcher.Default.OpenAsync(
            new Microsoft.Maui.ApplicationModel.OpenFileRequest(
                fileName,
                new Microsoft.Maui.Storage.ReadOnlyFile(filePath)));
    }

    private void OnMonthChanged(ChangeEventArgs args) =>
        _selectedMonth = int.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private void OnYearChanged(ChangeEventArgs args) =>
        _selectedYear = int.TryParse(args.Value?.ToString(), out var parsed) ? parsed : null;

    private string BuildDuesFileSuffix()
    {
        var monthPart = _selectedMonth.HasValue ? GetMonthName(_selectedMonth.Value).Replace(" ", string.Empty) : "all-months";
        var yearPart = _selectedYear.HasValue ? _selectedYear.Value.ToString() : "all-years";
        return $"{monthPart}_{yearPart}_{DateTime.UtcNow:yyyyMMdd}";
    }

    private static string GetNullableIntValue(int? value) => value?.ToString() ?? string.Empty;

    private static string GetMonthName(int month)
    {
        if (month < 1 || month > 12)
        {
            return "-";
        }

        return System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month);
    }

    private sealed record ReportSection(string Key, string Title, string Description);
}
