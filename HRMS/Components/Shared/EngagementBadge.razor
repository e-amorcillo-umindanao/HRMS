<div class="flex min-w-[140px] items-center gap-2">
    <div class="h-2 max-w-[110px] flex-1 overflow-hidden rounded-full bg-base-300">
        <div class="h-2 rounded-full transition-all @GetFillClass()" style="width: @(GetWidth())"></div>
    </div>
    <span class="w-8 text-right text-xs font-mono tabular-nums text-base-content/60">@GetLabel()</span>
</div>

@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public double? Score { get; set; }

    private string GetLabel()
    {
        if (Score.HasValue)
        {
            return $"{Math.Round(Score.Value)}%";
        }

        return string.IsNullOrWhiteSpace(Label) ? "-" : Label;
    }

    private string GetFillClass()
    {
        var value = Score ?? 0;
        return value switch
        {
            >= 75 => "bg-success",
            >= 40 => "bg-warning",
            _ => "bg-error"
        };
    }

    private string GetWidth()
    {
        var value = Math.Clamp(Score ?? 0, 0, 100);
        return $"{value.ToString(System.Globalization.CultureInfo.InvariantCulture)}%";
    }
}
