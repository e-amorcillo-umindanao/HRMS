@inject AuthService AuthSvc
@inject SubdivisionService SubdivisionSvc
@inject SubdivisionContextService CtxSvc

@if (AuthSvc.IsSuperAdmin)
{
    <div class="mb-4 flex items-center gap-3 px-1">
        <span class="whitespace-nowrap text-xs font-semibold uppercase tracking-widest text-base-content/40">
            Viewing
        </span>
        <select class="select select-sm select-bordered max-w-xs"
                @bind="selectedSubdivisionId"
                @bind:event="onchange"
                @bind:after="OnSelectionChangedAsync">
            <option value="0" disabled hidden>Select a subdivision...</option>
            @foreach (var subdivision in subdivisions)
            {
                <option value="@subdivision.SubdivisionId">@subdivision.Name</option>
            }
        </select>
        @if (CtxSvc.SelectedSubdivisionId.HasValue && IsReadOnly)
        {
            <span class="badge badge-warning badge-sm font-medium">Read-only</span>
        }
    </div>
}

@code {
    [Parameter] public EventCallback<int?> OnSubdivisionSelected { get; set; }
    [Parameter] public bool IsReadOnly { get; set; } = true;

    private List<Subdivision> subdivisions = [];
    private int selectedSubdivisionId = 0;

    protected override async Task OnInitializedAsync()
    {
        subdivisions = await SubdivisionSvc.GetActiveAsync();

        if (CtxSvc.SelectedSubdivisionId is int contextSubdivisionId &&
            subdivisions.Any(subdivision => subdivision.SubdivisionId == contextSubdivisionId))
        {
            selectedSubdivisionId = contextSubdivisionId;
            return;
        }

        var firstActive = subdivisions.FirstOrDefault();
        if (firstActive is not null)
        {
            selectedSubdivisionId = firstActive.SubdivisionId;
            CtxSvc.SetSubdivision(firstActive.SubdivisionId, firstActive.Name);
            await OnSubdivisionSelected.InvokeAsync(firstActive.SubdivisionId);
        }
    }

    private async Task OnSelectionChangedAsync()
    {
        if (selectedSubdivisionId <= 0)
        {
            return;
        }

        var subdivision = subdivisions.FirstOrDefault(item => item.SubdivisionId == selectedSubdivisionId);
        if (subdivision is null)
        {
            return;
        }

        CtxSvc.SetSubdivision(subdivision.SubdivisionId, subdivision.Name);
        await OnSubdivisionSelected.InvokeAsync(subdivision.SubdivisionId);
    }
}
