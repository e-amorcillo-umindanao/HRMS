<div class="flex flex-col items-center justify-center px-6 py-16 text-center">
    <div class="mb-4 text-4xl text-base-content/20" aria-hidden="true">@ResolveGlyph()</div>
    <p class="text-sm font-semibold text-base-content">@Title</p>
    <p class="mt-1 max-w-xs text-xs leading-relaxed text-base-content/50">
        @Subtitle
    </p>
</div>

@code {
    [Parameter]
    public string Icon { get; set; } = "o";

    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Subtitle { get; set; } = string.Empty;

    private string ResolveGlyph() => Icon switch
    {
        var value when value.Contains("PersonOff", StringComparison.Ordinal) => "!",
        var value when value.Contains("Description", StringComparison.Ordinal) => "[]",
        var value when value.Contains("Dashboard", StringComparison.Ordinal) => "#",
        var value when value.Contains("Forum", StringComparison.Ordinal) => "i",
        var value when value.Contains("Storefront", StringComparison.Ordinal) => "S",
        var value when value.Contains("ShowChart", StringComparison.Ordinal) => "~",
        var value when value.Contains("BarChart", StringComparison.Ordinal) => "=",
        _ => "o"
    };
}
