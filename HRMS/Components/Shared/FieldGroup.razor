<div class="@BuildClassName()" style="@Style">
    <label class="label pb-1">
        <span class="label-text text-[10.5px] font-semibold uppercase tracking-wide text-base-content/50">
            @Label
        </span>
    </label>
    @ChildContent
</div>

@code {
    [Parameter]
    public string Label { get; set; } = string.Empty;

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public string? Style { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private string BuildClassName() =>
        string.IsNullOrWhiteSpace(Class) ? "form-control w-full" : $"form-control w-full {Class}";
}
