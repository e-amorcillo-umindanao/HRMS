<span class="@BadgeClass">@DisplayStatus</span>

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Status { get; set; }

    private string DisplayStatus => string.IsNullOrWhiteSpace(Status) ? (string.IsNullOrWhiteSpace(Label) ? "-" : Label!) : Status!;

    private string BadgeClass => DisplayStatus switch
    {
        "Active" => "badge badge-sm badge-success",
        "Paid" => "badge badge-sm badge-success",
        "Approved" => "badge badge-sm badge-success",
        "Resolved" => "badge badge-sm badge-success",
        "High" => "badge badge-sm badge-success",
        "High Engagement" => "badge badge-sm badge-success",
        "Pending" => "badge badge-sm badge-warning",
        "Unpaid" => "badge badge-sm badge-warning",
        "Under Review" => "badge badge-sm badge-warning",
        "Suspended" => "badge badge-sm badge-warning",
        "Medium" => "badge badge-sm badge-warning",
        "Medium Engagement" => "badge badge-sm badge-warning",
        "Open" => "badge badge-sm badge-error",
        "Rejected" => "badge badge-sm badge-error",
        "Overdue" => "badge badge-sm badge-error",
        "Deceased" => "badge badge-sm badge-error",
        "Expired" => "badge badge-sm badge-error",
        "Low" => "badge badge-sm badge-error",
        "Low Engagement" => "badge badge-sm badge-error",
        "Inactive" => "badge badge-sm badge-ghost",
        "Closed" => "badge badge-sm badge-ghost",
        "Transferred" => "badge badge-sm badge-info",
        _ => "badge badge-sm badge-ghost"
    };
}
