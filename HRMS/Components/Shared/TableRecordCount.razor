<div class="record-count">
    Showing <strong>@GetRangeText()</strong> of <strong>@Count</strong> @EntityLabel
</div>

@code {
    [Parameter]
    public int Count { get; set; }

    [Parameter]
    public string EntityLabel { get; set; } = "records";

    [Parameter]
    public int? StartIndex { get; set; }

    [Parameter]
    public int? EndIndex { get; set; }

    private string GetRangeText() =>
        Count <= 0
            ? "0"
            : StartIndex.HasValue && EndIndex.HasValue
                ? $"{StartIndex.Value}-{EndIndex.Value}"
                : $"1-{Count}";
}
