@implements IDisposable
@inject AppDbContext DbContext
@inject AuthService AuthService

<header class="hrms-topbar">
    <div class="hrms-topbar__brand">HRMS</div>
    <div class="hrms-topbar__center">@_hoaName</div>
    <div class="hrms-topbar__right">
        <MudMenu Dense="true">
            <ActivatorContent>
                <MudText Style="font-weight: 600; cursor: pointer; color: #1E293B;">
                    @($"{AuthService.CurrentUser?.Username ?? "User"} v")
                </MudText>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem OnClick="LogoutAsync">Logout</MudMenuItem>
            </ChildContent>
        </MudMenu>
    </div>
</header>

@code {
    private string _hoaName = "Homeowners Association";

    protected override async Task OnInitializedAsync()
    {
        AuthService.StateChanged += HandleStateChanged;

        var settings = await DbContext.HOASettings.AsNoTracking().FirstOrDefaultAsync();
        if (settings is not null && !string.IsNullOrWhiteSpace(settings.HOAName))
        {
            _hoaName = settings.HOAName;
        }
    }

    public void Dispose()
    {
        AuthService.StateChanged -= HandleStateChanged;
    }

    private Task LogoutAsync() => AuthService.LogoutAsync();

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
