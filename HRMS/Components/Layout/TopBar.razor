@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="navbar sticky top-0 z-40 min-h-[52px] border-b border-base-300 bg-base-100 px-6">
    <div class="navbar-start">
        <span class="text-sm font-bold text-base-content">@GetPageTitle()</span>
    </div>
    <div class="navbar-center">
        <span class="text-sm text-base-content/50">@_hoaName</span>
    </div>
    <div class="navbar-end gap-2">
        <button class="theme-toggle-btn btn btn-ghost btn-sm btn-square"
                @onclick="OnThemeToggle"
                title="@(IsDark ? "Switch to light mode" : "Switch to dark mode")">
            @if (IsDark)
            {
                <svg xmlns="http://www.w3.org/2000/svg" class="icon-sun h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
                </svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" class="icon-moon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
                </svg>
            }
        </button>
        <div class="dropdown dropdown-end">
            <label tabindex="0" class="btn btn-ghost btn-sm gap-2">
                <div class="avatar placeholder">
                    <div class="w-7 rounded-full bg-primary text-primary-content">
                        <span class="text-xs font-semibold">@GetInitials()</span>
                    </div>
                </div>
                <span class="text-sm">@(AuthService.CurrentUser?.Username ?? "User")</span>
                <span class="text-xs opacity-50">v</span>
            </label>
            <ul tabindex="0" class="dropdown-content menu menu-sm mt-1 w-40 rounded-box border border-base-300 bg-base-100 shadow">
                <li><button @onclick="LogoutAsync">Logout</button></li>
            </ul>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public bool IsDark { get; set; }

    [Parameter]
    public EventCallback OnThemeToggle { get; set; }

    private string _hoaName = "Homeowners Association";

    protected override async Task OnInitializedAsync()
    {
        AuthService.StateChanged += HandleStateChanged;

        await using var dbContext = await DbContextFactory.CreateDbContextAsync();
        var settings = await dbContext.HOASettings.AsNoTracking().FirstOrDefaultAsync();
        if (settings is not null && !string.IsNullOrWhiteSpace(settings.HOAName))
        {
            _hoaName = settings.HOAName;
        }
    }

    public void Dispose()
    {
        AuthService.StateChanged -= HandleStateChanged;
    }

    private Task LogoutAsync() => AuthService.LogoutAsync();

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetInitials()
    {
        var username = AuthService.CurrentUser?.Username;
        if (string.IsNullOrWhiteSpace(username))
        {
            return "U";
        }

        var parts = username
            .Split(['.', '_', '-', ' '], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .ToArray();

        if (parts.Length == 0)
        {
            return username[..1].ToUpperInvariant();
        }

        return string.Concat(parts.Select(part => part[0])).ToUpperInvariant();
    }

    private string GetPageTitle()
    {
        var route = AuthService.NormalizeRoute(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));

        return route switch
        {
            "/" or "/dashboard" => "Dashboard",
            "/homeowners" => "Homeowners",
            var value when value.StartsWith("/homeowners/", StringComparison.Ordinal) => "Homeowners",
            "/units" => "Units",
            var value when value.StartsWith("/units/", StringComparison.Ordinal) => "Units",
            "/engagement" => "Engagement",
            var value when value.StartsWith("/engagement/", StringComparison.Ordinal) => "Engagement",
            "/events" => "Events",
            var value when value.StartsWith("/events/", StringComparison.Ordinal) => "Events",
            "/msme" => "MSME",
            var value when value.StartsWith("/msme/", StringComparison.Ordinal) => "MSME",
            "/dues" => "Dues",
            var value when value.StartsWith("/dues/", StringComparison.Ordinal) => "Dues",
            "/violations" => "Violations",
            var value when value.StartsWith("/violations/", StringComparison.Ordinal) => "Violations",
            "/clearance" => "Clearance",
            var value when value.StartsWith("/clearance/", StringComparison.Ordinal) => "Clearance",
            "/documents" => "Documents",
            "/reports" => "Reports",
            "/settings" => "Settings",
            "/profile" => "My Profile",
            _ => "HRMS"
        };
    }
}
