@implements IDisposable
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject AuthService AuthService
@inject NavigationManager NavigationManager

<div class="navbar sticky top-0 z-40 min-h-[52px] border-b border-base-300 bg-base-100 px-6">
    <div class="navbar-start gap-3">
        <button type="button"
                class="btn btn-ghost btn-sm btn-square"
                @onclick="OnSidebarToggle"
                title="@(IsSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="4" y1="7" x2="20" y2="7" />
                <line x1="4" y1="12" x2="20" y2="12" />
                <line x1="4" y1="17" x2="20" y2="17" />
            </svg>
        </button>
        <span class="text-sm font-bold text-base-content">@GetPageTitle()</span>
    </div>
    <div class="navbar-center">
        <span class="text-sm text-base-content/50">@_hoaName</span>
    </div>
    <div class="navbar-end gap-2">
        <button type="button"
                class="flex h-9 w-9 items-center justify-center rounded-md border border-transparent bg-transparent transition-colors hover:bg-base-200"
                @onclick="OnThemeToggle"
                title="@(IsDark ? "Switch to light mode" : "Switch to dark mode")">
            @if (IsDark)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#e5e7eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="4" />
                    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41 M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
                </svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#374151" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                </svg>
            }
        </button>
        <button type="button"
                class="btn btn-ghost btn-sm"
                @onclick="LogoutAsync">
            Logout
        </button>
    </div>
</div>

@code {
    [Parameter]
    public bool IsDark { get; set; }

    [Parameter]
    public EventCallback OnThemeToggle { get; set; }

    [Parameter]
    public bool IsSidebarCollapsed { get; set; }

    [Parameter]
    public EventCallback OnSidebarToggle { get; set; }

    private string _hoaName = "Homeowners Association";

    protected override async Task OnInitializedAsync()
    {
        AuthService.StateChanged += HandleStateChanged;
        NavigationManager.LocationChanged += HandleLocationChanged;

        await using var dbContext = await DbContextFactory.CreateDbContextAsync();
        var settings = await dbContext.HOASettings.AsNoTracking().FirstOrDefaultAsync();
        if (settings is not null && !string.IsNullOrWhiteSpace(settings.HOAName))
        {
            _hoaName = settings.HOAName;
        }
    }

    public void Dispose()
    {
        AuthService.StateChanged -= HandleStateChanged;
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private Task LogoutAsync() => AuthService.LogoutAsync();

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private string GetPageTitle()
    {
        var route = AuthService.NormalizeRoute(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));

        return route switch
        {
            "/" or "/dashboard" => "Dashboard",
            "/homeowners" => "Homeowners",
            var value when value.StartsWith("/homeowners/", StringComparison.Ordinal) => "Homeowners",
            "/units" => "Units",
            var value when value.StartsWith("/units/", StringComparison.Ordinal) => "Units",
            "/engagement" => "Engagement",
            var value when value.StartsWith("/engagement/", StringComparison.Ordinal) => "Engagement",
            "/events" => "Events & Programs",
            var value when value.StartsWith("/events/", StringComparison.Ordinal) => "Events & Programs",
            "/msme" => "MSME Registry",
            var value when value.StartsWith("/msme/", StringComparison.Ordinal) => "MSME Registry",
            "/dues" => "Dues & Fees",
            var value when value.StartsWith("/dues/", StringComparison.Ordinal) => "Dues & Fees",
            "/violations" => "Violations & Incidents",
            var value when value.StartsWith("/violations/", StringComparison.Ordinal) => "Violations & Incidents",
            "/clearance" => "Clearance & Documents",
            var value when value.StartsWith("/clearance/", StringComparison.Ordinal) => "Clearance & Documents",
            "/documents" => "Documents",
            "/reports" => "Reports",
            "/settings" => "Settings",
            "/profile" => "My Profile",
            _ => "HRMS"
        };
    }
}
