@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject AuthService AuthService
@inject SessionHelper SessionHelper
@inject ThemeService ThemeService

<div class="drawer drawer-open min-h-screen">
    <input id="sidebar-toggle" type="checkbox" class="drawer-toggle" checked />

    <div class="drawer-side z-50">
        <label for="sidebar-toggle" class="drawer-overlay"></label>
        <Sidebar />
    </div>

    <div class="drawer-content flex flex-col">
        <TopBar IsDark="@ThemeService.IsDark"
                OnThemeToggle="ToggleThemeAsync" />

        <main class="flex-1 overflow-y-auto bg-base-200 p-6">
            @Body
        </main>
    </div>
</div>

@code {
    private DotNetObjectReference<MainLayout>? _layoutReference;
    private bool _isActivityRegistered;

    protected override void OnInitialized()
    {
        AuthService.StateChanged += HandleAuthStateChanged;
        ThemeService.OnThemeChanged += HandleThemeChanged;
        SessionHelper.SessionWarningRaised += HandleSessionWarningRaised;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _layoutReference = DotNetObjectReference.Create(this);
            var savedTheme = await JSRuntime.InvokeAsync<string>("hrms.initTheme");
            ThemeService.SetTheme(savedTheme);
            StateHasChanged();
        }

        if (AuthService.IsAuthenticated && !_isActivityRegistered && _layoutReference is not null)
        {
            await JSRuntime.InvokeVoidAsync("hrmsSession.registerActivity", _layoutReference);
            _isActivityRegistered = true;
            SessionHelper.Start();
        }
        else if (!AuthService.IsAuthenticated && _isActivityRegistered)
        {
            await JSRuntime.InvokeVoidAsync("hrmsSession.unregisterActivity");
            _isActivityRegistered = false;
            SessionHelper.Stop();
        }
    }

    [JSInvokable]
    public Task HandleUserActivity()
    {
        SessionHelper.RecordActivity();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        AuthService.StateChanged -= HandleAuthStateChanged;
        ThemeService.OnThemeChanged -= HandleThemeChanged;
        SessionHelper.SessionWarningRaised -= HandleSessionWarningRaised;
        SessionHelper.Stop();

        if (_isActivityRegistered)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("hrmsSession.unregisterActivity");
            }
            catch
            {
            }
        }

        _layoutReference?.Dispose();
    }

    private void HandleAuthStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleSessionWarningRaised()
    {
        _ = InvokeAsync(async () =>
            await JSRuntime.InvokeVoidAsync("hrms.showToast", "Session will lock in 2 minutes due to inactivity.", "warning"));
    }

    private async Task ToggleThemeAsync()
    {
        ThemeService.Toggle();
        await JSRuntime.InvokeVoidAsync("hrms.setTheme", ThemeService.CurrentTheme);
    }
}
