@implements IDisposable
@inject AuthService AuthService
@inject NavigationManager Nav

<aside class="flex min-h-full h-full flex-col" style="background-color: #1e2433; color: #e2e8f0;">
    <div class="px-4 py-5 text-base font-medium tracking-tight">
        @(IsCollapsed ? "H" : "HRMS")
    </div>

    <nav class="flex-1 @(IsCollapsed ? "px-2" : "px-3")">
        @if (AuthService.IsHomeowner())
        {
            @RenderSection("Main", HomeownerItems)
        }
        else
        {
            @RenderSection("Main", MainItems)
            @RenderSection("Operations", OperationsItems)

            if (AdminItems.Count > 0)
            {
                @RenderSection("Admin", AdminItems)
            }
        }
    </nav>

    <div class="border-t border-base-content/10 p-3">
        <button type="button"
                class="btn btn-sm w-full border-transparent bg-transparent text-[#94a3b8] hover:border-transparent hover:bg-white/5 hover:text-[#e2e8f0] @(IsCollapsed ? "justify-center px-0" : "justify-start")"
                title="Logout"
                @onclick="LogoutAsync">
            @if (IsCollapsed)
            {
                <span class="text-[11px] font-semibold uppercase">LO</span>
            }
            else
            {
                <span>Logout</span>
            }
        </button>
    </div>
</aside>

@code {
    [Parameter]
    public bool IsCollapsed { get; set; }

    protected override void OnInitialized()
    {
        AuthService.StateChanged += HandleStateChanged;
        Nav.LocationChanged += HandleLocationChanged;
    }

    public void Dispose()
    {
        AuthService.StateChanged -= HandleStateChanged;
        Nav.LocationChanged -= HandleLocationChanged;
    }

    private List<NavItem> HomeownerItems =>
    [
        new("My Profile", "/profile")
    ];

    private List<NavItem> MainItems
    {
        get
        {
            var items = new List<NavItem>
            {
                new("Dashboard", "/dashboard")
            };

            if (AuthService.IsAtLeast("Staff"))
            {
                items.Add(new("Homeowners", "/homeowners"));
                items.Add(new("Units", "/units"));
            }

            return items;
        }
    }

    private List<NavItem> OperationsItems
    {
        get
        {
            var items = new List<NavItem>();

            if (AuthService.IsAtLeast("Board Member"))
            {
                items.Add(new("Engagement", "/engagement"));
            }

            if (AuthService.IsAtLeast("Staff"))
            {
                items.Add(new("Events", "/events"));
            }

            if (AuthService.IsAtLeast("Board Member"))
            {
                items.Add(new("MSME", "/msme"));
            }

            if (AuthService.IsAtLeast("Staff"))
            {
                items.Add(new("Dues", "/dues"));
            }

            if (AuthService.IsAtLeast("Board Member"))
            {
                items.Add(new("Violations", "/violations"));
            }

            items.Add(new("Clearance", "/clearance"));

            if (AuthService.IsAtLeast("HOA President"))
            {
                items.Add(new("Documents", "/documents"));
            }

            if (AuthService.IsAtLeast("Staff"))
            {
                items.Add(new("Reports", "/reports"));
            }

            return items;
        }
    }

    private List<NavItem> AdminItems =>
        AuthService.HasRole("Super Admin")
            ? [new NavItem("Settings", "/settings")]
            : [];

    private RenderFragment RenderSection(string label, IReadOnlyList<NavItem> items) => builder =>
    {
        if (items.Count == 0)
        {
            return;
        }

        var sequence = 0;
        if (!IsCollapsed)
        {
            builder.OpenElement(sequence++, "p");
            builder.AddAttribute(sequence++, "class", "mt-4 mb-2 px-2 text-[9.5px] font-semibold uppercase tracking-widest");
            builder.AddAttribute(sequence++, "style", "color: rgba(226, 232, 240, 0.6); letter-spacing: 0.08em;");
            builder.AddContent(sequence++, label);
            builder.CloseElement();
        }

        builder.OpenElement(sequence++, "ul");
        builder.AddAttribute(sequence++, "class", "menu menu-compact gap-0.5");

        foreach (var item in items)
        {
            builder.OpenElement(sequence++, "li");
            builder.OpenElement(sequence++, "button");
            builder.AddAttribute(sequence++, "type", "button");
            builder.AddAttribute(sequence++, "class", GetNavItemClass(item.Href));
            builder.AddAttribute(sequence++, "title", item.Label);
            builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => NavigateTo(item.Href)));

            if (IsCollapsed)
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "flex h-8 w-8 items-center justify-center rounded-md bg-white/5 text-[11px] font-semibold uppercase");
                builder.AddContent(sequence++, GetAbbreviation(item.Label));
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(sequence++, "span");
                builder.AddAttribute(sequence++, "class", "nav-dot h-2 w-2 rounded-full flex-shrink-0");
                builder.CloseElement();

                builder.OpenElement(sequence++, "span");
                builder.AddContent(sequence++, item.Label);
                builder.CloseElement();
            }

            builder.CloseElement();
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private string GetNavItemClass(string href) =>
        IsActive(href)
            ? $"nav-link active flex items-center rounded py-2 text-sm font-medium bg-white/10 text-[#e2e8f0] transition-colors {(IsCollapsed ? "justify-center px-0" : "gap-2 px-2")}"
            : $"nav-link flex items-center rounded py-2 text-sm text-[#94a3b8] transition-colors hover:bg-white/5 hover:text-[#e2e8f0] {(IsCollapsed ? "justify-center px-0" : "gap-2 px-2")}";

    private bool IsActive(string href)
    {
        var currentRoute = AuthService.NormalizeRoute(Nav.ToBaseRelativePath(Nav.Uri));
        var targetRoute = AuthService.NormalizeRoute(href);

        if (targetRoute == "/dashboard")
        {
            return currentRoute is "/" or "/dashboard";
        }

        return currentRoute == targetRoute || currentRoute.StartsWith($"{targetRoute}/", StringComparison.Ordinal);
    }

    private void NavigateTo(string href) => Nav.NavigateTo(href);

    private Task LogoutAsync() => AuthService.LogoutAsync();

    private static string GetAbbreviation(string label)
    {
        if (string.IsNullOrWhiteSpace(label))
        {
            return "?";
        }

        var parts = label
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .ToArray();

        return parts.Length == 0
            ? label[..1].ToUpperInvariant()
            : string.Concat(parts.Select(part => part[0])).ToUpperInvariant();
    }

    private void HandleStateChanged() => _ = InvokeAsync(StateHasChanged);

    private void HandleLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e) =>
        _ = InvokeAsync(StateHasChanged);

    private sealed record NavItem(string Label, string Href);
}
